---
const navItems = [
  { href: "/th/best/air-conditioners/", label: "แอร์ 2026" },
  { href: "/th/best/rainy-season-gear/", label: "ของสู้หน้าฝน" },
  { href: "/th/guides/btu-calculator/", label: "เครื่องคิด BTU" },
  { href: "/th/compare/air-conditioners/", label: "เทียบแอร์" },
  { href: "/th/reviews/air-conditioners/", label: "รีวิวละเอียด" },
  { href: "/editorial-policy/", label: "มาตรฐานรีวิว" }
];
---

<header class="site-header">
  <div class="container nav">
    <a class="brand" href="/th/" aria-label="Friendsay home">
      <span class="brand-mark">F</span>
      <span>Friendsay</span>
    </a>
    <nav class="nav-links" aria-label="เมนูหลัก">
      {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
    </nav>
    <div class="nav-actions">
      <form class="nav-search" action="/th/" method="get" role="search">
        <input type="search" name="q" placeholder="ค้นหา เช่น แอร์ต่ำกว่า 10000" aria-label="ค้นหาสินค้าที่ตรวจแล้ว" />
      </form>
      <a class="pill-link" href="/affiliate-disclosure/">Affiliate โปร่งใส</a>
    </div>
  </div>
</header>
