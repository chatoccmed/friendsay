---
import { topAirFryerPicks } from "../data/airFryers";
import { legacyProducts } from "../data/legacyProducts";

const heroSignals = [
  { value: "50+", label: "หมวดสินค้ายอดนิยมที่วางแผนรีวิว", href: "#product-worlds" },
  { value: "3", label: "เช็กราคา Shopee Lazada TikTok", href: "/affiliate-disclosure/" },
  { value: "2", label: "รีวิวรวมและรีวิวเจาะลึกรายรุ่น", href: "/editorial-policy/" },
  { value: "100%", label: "บอกจุดควรระวังก่อนปุ่มซื้อ", href: "/editorial-policy/" }
];

const decisionPaths = [
  { label: "เริ่มจากคนใช้", value: "คอนโด ครอบครัว นักท่องเที่ยว" },
  { label: "ตัดตัวเลือกเสี่ยง", value: "เสียง ขนาด ราคา เคลมเกินจริง" },
  { label: "ค่อยกดซื้อ", value: "เทียบ Shopee Lazada TikTok" }
];

const readingPaths = [
  {
    step: "01",
    title: "อ่านสรุปใน 3 นาที",
    text: "เหมาะกับวันที่อยากได้คำตอบเร็ว เห็นตัวเลือกเด่น ข้อควรระวัง และรุ่นที่ควรข้ามก่อน",
    href: "/th/best/air-fryers/",
    cue: "เริ่มจาก shortlist"
  },
  {
    step: "02",
    title: "เทียบให้เห็นภาพ",
    text: "ดูราคา ความจุ คะแนน จุดเด่น และข้อสังเกตในกราฟหรือตารางเดียว ก่อนเสียเวลาเปิดหลายร้าน",
    href: "/th/best/air-fryers/#compare-lab",
    cue: "เหมาะก่อนกดซื้อ"
  },
  {
    step: "03",
    title: "เจาะลึกรายรุ่น",
    text: "อ่านข้อดี ข้อเสีย เสียงจากผู้ใช้จริง และเงื่อนไขที่ทำให้รุ่นนั้นเหมาะหรือไม่เหมาะกับคุณ",
    href: "/th/reviews/sample-air-fryer-pro/",
    cue: "อ่านก่อนจ่ายจริง"
  }
];

const productWorlds = [
  {
    title: "บ้านและครัว",
    label: "หม้อทอดไร้น้ำมัน เครื่องครัว อุปกรณ์ทำอาหาร และของที่ใช้ทุกวันในบ้าน",
    href: "/th/best/air-fryers/",
    image: "/images/air-fryers/air-fryer-family-photo.png",
    alt: "หม้อทอดไร้น้ำมันในครัวพร้อมตะกร้าด้านหน้า",
    status: "เปิดอ่านแล้ว"
  },
  {
    title: "เครื่องใช้ไฟฟ้าในบ้าน",
    label: "เครื่องทำน้ำอุ่น เครื่องฟอกอากาศ พัดลม เครื่องดูดฝุ่น และของที่ควรเทียบสเปกให้ชัด",
    href: "#product-worlds",
    image: legacyProducts[0].oldImageUrl,
    alt: "เครื่องทำน้ำอุ่น Haier สีขาว",
    status: "หมวดยอดนิยม"
  },
  {
    title: "สุขภาพและความปลอดภัย",
    label: "อุปกรณ์ตรวจวัดเบื้องต้น เครื่องฟอกอากาศ ไฟฉุกเฉิน และของที่ต้องระวังคำเคลมเป็นพิเศษ",
    href: "#product-worlds",
    image: legacyProducts[2].oldImageUrl,
    alt: "เครื่องวัดออกซิเจนปลายนิ้ว ChoiceMMed",
    status: "ต้องเช็กแหล่งอ้างอิง"
  },
  {
    title: "นักท่องเที่ยวในไทย",
    label: "ซิม ของใช้เดินทาง ปลั๊ก อุปกรณ์กันแดด ของฝาก และของที่ต่างชาติควรซื้อในไทย",
    href: "/en/tourist/",
    image: "/images/friendsay-hero.png",
    alt: "โต๊ะรีวิวสินค้าพร้อมของใช้หลายหมวด",
    status: "Tourist guide"
  },
  {
    title: "Gadget และงาน",
    label: "หูฟัง ที่ชาร์จ โต๊ะทำงาน เก้าอี้ คีย์บอร์ด และของที่ช่วยให้ชีวิตประจำวันลื่นขึ้น",
    href: "#product-worlds",
    image: "/images/friendsay-hero.png",
    alt: "โต๊ะรีวิวสินค้าหลากหลายหมวดสำหรับเปรียบเทียบ",
    status: "ของใช้ทุกวัน"
  },
  {
    title: "Beauty และของใช้ส่วนตัว",
    label: "กันแดด ไดร์เป่าผม เครื่องโกนหนวด อุปกรณ์ดูแลผิว และของที่ต้องดูผลลัพธ์จริง",
    href: "#product-worlds",
    image: "/images/air-fryers/air-fryer-cleaning-photo.png",
    alt: "มือกำลังดูแลทำความสะอาดอุปกรณ์ในบ้าน",
    status: "ใช้จริงสำคัญกว่าเคลม"
  },
  {
    title: "แม่และเด็ก",
    label: "คาร์ซีท รถเข็น เครื่องนึ่งขวดนม กล้องดูเด็ก และของที่ต้องคิดเรื่องความปลอดภัยก่อนราคา",
    href: "#product-worlds",
    image: "/images/friendsay-hero.png",
    alt: "สินค้าหลายหมวดบนโต๊ะสำหรับรีวิวก่อนเลือกซื้อ",
    status: "ต้องเลือกละเอียด"
  },
  {
    title: "ดีไซน์และไลฟ์สไตล์",
    label: "ของที่หน้าตาดีต้องตอบด้วยว่าใช้ดีจริงไหม คุ้มไหม และเหมาะกับบ้านแบบไหน",
    href: "#product-worlds",
    image: legacyProducts[9].oldImageUrl,
    alt: "เครื่องทำน้ำอุ่น Sharp Modi ดีไซน์เรียบ",
    status: "ของสวยต้องใช้ดี"
  }
];

const flagship = topAirFryerPicks[0];
---

<section class="home-hero home-hero-v2" aria-labelledby="home-hero-title">
  <img class="home-hero-image" src="/images/friendsay-hero.png" alt="โต๊ะรีวิวสินค้าพรีเมี่ยมพร้อมของใช้หลายหมวดสำหรับเปรียบเทียบ" loading="eager" />
  <div class="home-hero-shade" aria-hidden="true"></div>
  <div class="wide-container home-hero-inner home-hero-inner-v2">
    <div class="home-hero-copy">
      <div class="promise-row" aria-label="คำมั่นของ Friendsay">
        <span>มีข้อเสียให้เห็น</span>
        <span>เทียบให้เข้าใจง่าย</span>
        <span>ไม่ให้ affiliate นำคำตอบ</span>
      </div>
      <h1 id="home-hero-title" class="home-brand-title">Friendsay</h1>
      <p class="home-hero-kicker">เว็บรีวิวสินค้าแบบเพื่อนช่วยเลือก ที่จริงใจกับคนอ่านก่อนจริงใจกับยอดขาย</p>
      <p class="home-hero-subhead">
        เราทำให้การซื้อของออนไลน์ตัดสินใจง่ายขึ้นด้วยรีวิวรวม รีวิวเจาะลึก ตารางเทียบ กราฟ ภาพสินค้า
        และข้อควรระวังจากรีวิวจริง เพื่อให้คุณรู้ว่าอะไรเหมาะกับคุณ และอะไรควรข้าม
      </p>
      <form class="hero-search" action="/th/best/air-fryers/" method="get">
        <input name="q" type="search" placeholder="ค้นหา: หม้อทอด เครื่องทำน้ำอุ่น ของใช้ในไทย" aria-label="ค้นหาสินค้า" />
        <button class="button button-primary" type="submit">ค้นหารีวิว</button>
      </form>
      <div class="home-hero-actions">
        <a class="button button-dark" href="/th/best/air-fryers/">ดูรีวิวเด่น</a>
        <a class="hero-text-link" href="#product-worlds">ดูหมวดสินค้ายอดนิยม</a>
      </div>
    </div>

    <aside class="home-hero-lens" aria-label="ระบบคัดเลือกสินค้าของ Friendsay">
      <div class="lens-media">
        <img src={flagship.image.url} alt={flagship.image.alt} loading="lazy" />
        <span>{flagship.score.toFixed(1)} / 10</span>
      </div>
      <div class="lens-copy">
        <span>Editor’s desk</span>
        <strong>เริ่มจาก “เหมาะกับใคร” ก่อน “ซื้อที่ไหน”</strong>
        <p>ทุกบทความต้องช่วยตัดสินใจให้เร็วขึ้น โดยยังเหลือรายละเอียดให้คนที่อยากอ่านลึกตรวจต่อได้</p>
      </div>
      <div class="lens-steps">
        {decisionPaths.map((path) => (
          <div>
            <span>{path.label}</span>
            <strong>{path.value}</strong>
          </div>
        ))}
      </div>
    </aside>

    <div class="home-proof-strip" aria-label="สถานะเว็บ Friendsay">
      {heroSignals.map((signal) => (
        <a href={signal.href}>
          <strong>{signal.value}</strong>
          <span>{signal.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="home-reading-section" aria-labelledby="home-reading-title">
  <div class="wide-container home-reading-shell">
    <div class="home-reading-intro">
      <p class="eyebrow">How to read Friendsay</p>
      <h2 id="home-reading-title">เลือกทางอ่านที่เหมาะกับเวลาของคุณ</h2>
      <p>บางวันอยากได้คำตอบเร็ว บางวันอยากเทียบให้ชัวร์ หน้าแรกควรพาคุณไปถูกทางตั้งแต่คลิกแรก</p>
    </div>
    <div class="home-reading-grid">
      {readingPaths.map((path) => (
        <a class="home-reading-card" href={path.href}>
          <span>{path.step}</span>
          <strong>{path.title}</strong>
          <p>{path.text}</p>
          <small>{path.cue}</small>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section home-showcase-section">
  <div class="wide-container home-showcase-grid">
    <a class="home-feature-story" href="/th/best/air-fryers/">
      <img src={flagship.image.url} alt={flagship.image.alt} loading="lazy" />
      <div>
        <span class="eyebrow">Flagship Review</span>
        <h2>หม้อทอดไร้น้ำมันรุ่นไหนดี 2026</h2>
        <p>บทความตัวอย่างที่แสดงแนวทางเว็บใหม่: อ่านเร็วได้ เทียบลึกได้ มีภาพ มีตาราง มีกราฟ และมีรีวิวแยกรายรุ่นต่อยอด</p>
      </div>
      <div class="home-feature-meta">
        <span>{topAirFryerPicks.length} รุ่นเด่น</span>
        <span>Compare Lab</span>
        <span>สรุปตามความต้องการ</span>
      </div>
    </a>

    <div class="home-editorial-rail" aria-label="ทางลัดสำคัญ">
      <a href="#product-worlds">
        <span>Popular in Thailand</span>
        <strong>เริ่มจากสินค้าที่คนไทยค้นหาก่อนซื้อจริง</strong>
      </a>
      <a href="/editorial-policy/">
        <span>Review Standard</span>
        <strong>บอกก่อนว่าเราตรวจอะไร และยังไม่ฟันธงอะไร</strong>
      </a>
      <a href="/en/tourist/">
        <span>Tourist Mode</span>
        <strong>ต่อยอดเป็นรีวิวของที่นักท่องเที่ยวควรซื้อในไทย</strong>
      </a>
    </div>
  </div>
</section>

<section class="section home-world-section" id="product-worlds">
  <div class="container">
    <div class="section-heading home-section-split">
      <div>
        <p class="eyebrow">Popular Thai product reviews</p>
        <h2 class="headline">รีวิวสินค้ายอดนิยมที่คนไทยค้นหาก่อนซื้อ</h2>
      </div>
      <p>
        เป้าหมายของ Friendsay คือรีวิวทุกหมวดสินค้าที่คนไทยใช้จริง ตั้งแต่เครื่องใช้ไฟฟ้า ของใช้ในบ้าน สุขภาพ ความงาม
        Gadget แม่และเด็ก ไปจนถึงของที่นักท่องเที่ยวควรซื้อในไทย โดยทุกหมวดต้องตอบให้ชัดว่าเหมาะกับใคร ไม่เหมาะกับใคร จุดเด่น จุดเสี่ยง และควรเช็กราคาที่ไหน
      </p>
    </div>
    <div class="home-world-grid">
      {productWorlds.map((world) => (
        <a class="home-world-card" href={world.href}>
          <img src={world.image} alt={world.alt} loading="lazy" />
          <div>
            <span>{world.status}</span>
            <strong>{world.title}</strong>
            <p>{world.label}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section home-trust-section">
  <div class="container home-trust-grid">
    <div>
      <p class="eyebrow">Why trust Friendsay</p>
      <h2 class="headline">หน้าแรกต้องทำให้คนรู้สึกว่าเราอยู่ข้างเขา ไม่ใช่ข้างปุ่มซื้อ</h2>
    </div>
    <div class="home-trust-points">
      <article>
        <span>01</span>
        <h3>รีวิวรวมเพื่อ shortlist</h3>
        <p>ช่วยตัดจากหลายสิบรุ่นให้เหลือรุ่นที่ควรดูจริง พร้อมเหตุผลตามสถานการณ์ใช้งาน</p>
      </article>
      <article>
        <span>02</span>
        <h3>รีวิวเดี่ยวเพื่อความมั่นใจ</h3>
        <p>ลงลึกข้อดี จุดสังเกต รีวิวผู้ใช้จริง ราคา และเงื่อนไขที่ทำให้รุ่นนั้นเหมาะหรือไม่เหมาะ</p>
      </article>
      <article>
        <span>03</span>
        <h3>โปร่งใสเรื่อง affiliate</h3>
        <p>ปุ่มซื้อช่วยให้เว็บอยู่ได้ แต่บทสรุปต้องเริ่มจากประโยชน์ของคนอ่านเสมอ</p>
      </article>
    </div>
  </div>
</section>
