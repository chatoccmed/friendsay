      ))}
      <a class="home-feature-tool" href="/th/guides/btu-calculator/">
        <span class="eyebrow">เครื่องมือฟรี</span>
        <strong>เครื่องคิด BTU</strong>
        <p>กรอกขนาดห้อง แดด และเพดาน — ได้ BTU ที่ควรซื้อใน 30 วินาที พร้อมรุ่นที่ตรวจแล้วในช่วงนั้น</p>
        <span class="button button-primary">ลองคิดเลย</span>
      </a>
    </div>
  </div>
</section>

<section class="section band" aria-labelledby="home-how-title">
  <div class="container">
    <p class="eyebrow">Why trust Friendsay</p>
    <h2 class="headline" id="home-how-title">เราทำงานยังไง</h2>
    <div class="home-work-grid">
      {workSteps.map((step, index) => (
        <article class="home-work-card">
          <span>{String(index + 1).padStart(2, "0")}</span>
          <h3>{step.title}</h3>
          <p>{step.text}</p>
        </article>
      ))}
    </div>
    <p class="muted" style="margin-top: 16px;">
      อ่านเกณฑ์เต็มได้ที่ <a href="/editorial-policy/">มาตรฐานรีวิวของเรา</a> · รายได้ affiliate เปิดเผยที่
      <a href="/affiliate-disclosure/">หน้าความโปร่งใส</a>
    </p>
  </div>
</section>

<section class="section" aria-labelledby="home-roadmap-title">
  <div class="container">
    <p class="eyebrow">หมวดถัดไป</p>
    <h2 class="headline" id="home-roadmap-title">กำลังทยอยตรวจทีละหมวด</h2>
    <p class="muted">เราเปิดหมวดใหม่เมื่อหลักฐานครบเท่านั้น — หมวดที่ยังไม่พร้อมจะไม่มีตัวเลขมั่วขึ้นเว็บ</p>
    <div class="home-roadmap-grid">
      {roadmapOpen.map((item) => (
        <a class="home-roadmap-card" href={item.href}>
          <span class="badge badge-teal">เปิดอ่านได้</span>
          <strong>{item.title}</strong>
          <p>{item.status}</p>
        </a>
      ))}
      {roadmapSoon.map((item) => (
        <div class="home-roadmap-card is-soon">
          <span class="badge">เร็ว ๆ นี้</span>
          <strong>{item.title}</strong>
          <p>{item.note}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="section band" aria-labelledby="home-latest-title">
  <div class="container">
    <p class="eyebrow">อัปเดตล่าสุด</p>
    <h2 class="headline" id="home-latest-title">บทความและเครื่องมือทั้งหมด</h2>
    <div class="home-latest-list">
      {latestArticles.map((article) => (
        <a class="home-latest-row" href={article.href}>
          <span class="badge badge-coral">{article.tag}</span>
          <strong>{article.title}</strong>
          <span class="home-latest-date">{article.date}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script id="search-data" type="application/json" set:html={JSON.stringify(searchIndex)} />

<script is:inline data-astro-rerun>
  (() => {
    // รันใหม่ทุกครั้งที่ ClientRouter เข้าหน้านี้ — ยกเลิก listener ระดับ document/window ของรอบก่อนกันซ้อน
    if (window.__friendsayHomeAbort) window.__friendsayHomeAbort.abort();
    const homeAbort = new AbortController();
    window.__friendsayHomeAbort = homeAbort;
    const homeSignal = homeAbort.signal;

    const dataEl = document.getElementById("search-data");
    const form = document.getElementById("home-search-form");
    const input = document.getElementById("home-search-input");
    const resultsSection = document.getElementById("search-results");
    const resultsTitle = document.getElementById("search-results-title");
    const resultsNote = document.getElementById("search-results-note");
    const resultsGrid = document.getElementById("search-results-grid");
    const resultsEmpty = document.getElementById("search-results-empty");
    if (!dataEl || !form || !input || !resultsSection || !resultsGrid) return;

    let items = [];
    try {
      items = JSON.parse(dataEl.textContent || "[]");
    } catch {
      return;
    }

    const CATEGORY_RULES = [
      { match: ["แอร์", "เครื่องปรับอากาศ"], categories: ["แอร์"] },
      { match: ["อบผ้า", "ตากผ้า", "ผ้าไม่แห้ง", "ผ้าเหม็นอับ"], categories: ["เครื่องอบผ้า", "ตู้อบผ้า"] },
      { match: ["รองเท้า"], categories: ["เครื่องอบรองเท้า"] },
      { match: ["ความชื้น", "ลดชื้น", "ห้องชื้น", "ขึ้นรา", "เหม็นอับ"], categories: ["เครื่องลดความชื้น"] },
      { match: ["หน้าฝน", "ฤดูฝน", "สู้ฝน"], categories: ["เครื่องอบผ้า", "ตู้อบผ้า", "เครื่องอบรองเท้า", "เครื่องลดความชื้น"] }
    ];

    const PRICE_CAP_RE = /(?:ต่ำกว่า|ไม่เกิน|ไม่ถึง|งบ|ถูกกว่า)\s*([\d,]+)/;

    const parsePriceCap = (query) => {
      const m = query.match(PRICE_CAP_RE);
      if (m) {
        const cap = parseInt(m[1].replace(/,/g, ""), 10);
        return Number.isFinite(cap) && cap > 0 ? cap : null;
      }
      if (/(?:ต่ำกว่า|ไม่เกิน|ไม่ถึง|งบ)\s*หมื่น/.test(query)) return 10000;
      if (/(?:ต่ำกว่า|ไม่เกิน|ไม่ถึง|งบ)\s*พัน/.test(query)) return 1000;
      return null;
    };

    const search = (rawQuery) => {
      const query = rawQuery.trim().toLowerCase();
      if (!query) return { matches: [], cap: null };

      const cap = parsePriceCap(query);

      const matchedCategories = new Set();
      for (const rule of CATEGORY_RULES) {
        if (rule.match.some((token) => query.includes(token))) {
          rule.categories.forEach((c) => matchedCategories.add(c));
        }
      }

      let scored = items
        .map((item) => {
          let score = 0;
          if (matchedCategories.has(item.category)) score += 1;
          for (const keyword of item.keywords) {
            if (keyword.length >= 2 && query.includes(keyword.toLowerCase())) score += 1;
          }
          return { item, score };
        })
        .filter((entry) => entry.score > 0);

      // มีแต่เพดานราคาโดยไม่บอกหมวด → ค้นทั้งฐานตามราคา
      if (!scored.length && cap) {
        scored = items.map((item) => ({ item, score: 1 }));
      }

      let matches = scored.map((entry) => entry);
      if (cap) matches = matches.filter((entry) => entry.item.priceNum <= cap);

      matches.sort((a, b) => {
        if (b.score !== a.score) return b.score - a.score;
        const soldA = a.item.soldNum || 0;
        const soldB = b.item.soldNum || 0;
        if (soldB !== soldA) return soldB - soldA;
        return b.item.ratingsCount - a.item.ratingsCount;
      });

      return { matches: matches.map((entry) => entry.item), cap };
    };

    const esc = (value) =>
      String(value).replace(/[&<>"']/g, (ch) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;", "'": "&#39;" }[ch]));

    const renderCard = (item, index) => `
      <article class="rainy-pick-card search-result-card">
        <div class="badge-row">
          <span class="badge badge-teal">${esc(item.category)}</span>
          <span class="badge">อันดับ ${index + 1}</span>
        </div>
        <a href="${esc(item.affiliateUrl)}" target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="home-search">
          <img class="rainy-img" src="${esc(item.image)}" alt="ภาพสินค้าจริง ${esc(item.name)}" loading="lazy" />
        </a>
        <h3>${esc(item.name)}</h3>
        <p class="search-result-meta"><strong>${esc(item.priceLabel)}</strong><br />${esc(item.soldLabel)} · ${Number(item.rating).toFixed(1)} ★</p>
        <p>${esc(item.blurb)}</p>
        <div class="search-result-actions">
          <a class="button button-primary" href="${esc(item.affiliateUrl)}" target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="home-search">เช็กราคา Shopee</a>
          <a class="button" href="${esc(item.href)}">อ่านรีวิวของเรา</a>
          ${item.category === "แอร์" ? `<a class="button" href="/th/compare/air-conditioners/?items=${encodeURIComponent(item.id)}">⚖ เทียบรุ่นนี้</a>` : ""}
        </div>
      </article>`;

    const runSearch = (rawQuery, { scroll = true } = {}) => {
      const query = rawQuery.trim();
      if (!query) return;

      const { matches } = search(query);
      const top = matches.slice(0, 5);

      resultsSection.hidden = false;
      resultsTitle.textContent = `ผลการค้นหา “${query}”`;

      const compareCta = document.getElementById("search-compare-cta");

      if (top.length) {
        resultsGrid.innerHTML = top.map((item, index) => renderCard(item, index)).join("");
        resultsGrid.hidden = false;
        resultsEmpty.hidden = true;
        // ผลค้นหาเป็นแอร์ ≥2 รุ่น → เสนอเทียบทั้งชุดในคลิกเดียว (พาเข้าระบบเปรียบเทียบ)
        if (compareCta) {
          const acIds = top.filter((item) => item.category === "แอร์").map((item) => item.id).slice(0, 4);
          if (acIds.length >= 2) {
            compareCta.innerHTML = `<a class="button button-primary" href="/th/compare/air-conditioners/?items=${encodeURIComponent(acIds.join(","))}">⚖ เทียบ ${acIds.length} รุ่นนี้พร้อมกัน ดูคำตัดสินรายคู่</a>`;
            compareCta.hidden = false;
          } else {
            compareCta.hidden = true;
          }
        }
        resultsNote.textContent =
          (matches.length > 5
            ? `เจอ ${matches.length} รุ่นที่ตรวจแล้ว โชว์ 5 อันดับแรก`
            : `เจอ ${matches.length} รุ่นที่ตรวจแล้ว`) +
          " · เรียงจากยอดขายจริงที่เห็นบนหน้าร้าน · ราคาเปลี่ยนได้ทุกวัน กดเช็กหน้าร้านก่อนซื้อ";
      } else {
        resultsGrid.innerHTML = "";
        resultsGrid.hidden = true;
        resultsEmpty.hidden = false;
        resultsNote.textContent = "";
        if (compareCta) compareCta.hidden = true;
      }

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push({ event: "friendsay_home_search", query, results: matches.length });
      // gtag.js ไม่แปลง object push เป็น event — ต้องยิงผ่าน gtag() ตรง ๆ ถึงจะถึง GA4
      if (typeof window.gtag === "function") {
        window.gtag("event", "friendsay_home_search", { search_term: query, results: matches.length });
      }

      if (scroll) resultsSection.scrollIntoView({ behavior: "smooth", block: "start" });
    };

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      runSearch(input.value);
      const url = new URL(location.href);
      if (input.value.trim()) url.searchParams.set("q", input.value.trim());
      else url.searchParams.delete("q");
      history.replaceState(null, "", url);
    });

    document.addEventListener("click", (event) => {
      const chip = event.target instanceof Element ? event.target.closest("[data-search-chip]") : null;
      if (!chip) return;
      const value = chip.getAttribute("data-search-chip") || "";
      input.value = value;
      runSearch(value);
      const url = new URL(location.href);
      url.searchParams.set("q", value);
      history.replaceState(null, "", url);
    }, { signal: homeSignal });

    // parallax เบา ๆ บน glow ของ hero (transform อย่างเดียว + เคารพ reduced-motion)
    const heroGlow = document.querySelector(".home-hero-glow");
    if (heroGlow && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
      let glowTicking = false;
      window.addEventListener(
        "scroll",
        () => {
          if (glowTicking) return;
          glowTicking = true;
          window.requestAnimationFrame(() => {
            heroGlow.style.transform = `translateY(${window.scrollY * 0.22}px)`;
            glowTicking = false;
          });
        },
        { passive: true, signal: homeSignal }
      );
    }

    // รับคำค้นจากช่องบน header ของหน้าอื่น (GET /th/?q=...)
    const initialQuery = new URLSearchParams(location.search).get("q");
    if (initialQuery && initialQuery.trim()) {
      input.value = initialQuery.trim();
      runSearch(initialQuery, { scroll: true });
    }
  })();
</script>
