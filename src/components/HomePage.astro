---
import { searchIndex, searchIndexCount } from "../data/searchIndex";

// ตัวเลขจริงเท่านั้น — อัปเดตทุกครั้งที่รอบเก็บหลักฐานเปลี่ยน (ล่าสุด 2026-07-02)
const dataUpdatedLabel = "2 ก.ค. 2026";

const heroChips = ["แอร์ต่ำกว่า 10,000", "เครื่องอบผ้า", "ของสู้หน้าฝน", "แอร์ประหยัดไฟ"];

const heroSignals = [
  { value: String(searchIndexCount), count: searchIndexCount, label: "รุ่นที่ตรวจหลักฐานจริงแล้ว", href: "/th/best/air-conditioners/" },
  { value: "10,000+", count: 10000, suffix: "+", label: "ยอดขายจริงสูงสุดที่เห็นบนหน้าร้าน", href: "/th/best/air-conditioners/" },
  { value: "0", count: 0, label: "อันดับที่รับเงินเพื่อจัดให้ — ไม่มีขายอันดับ", href: "/editorial-policy/" },
  { value: dataUpdatedLabel, label: "รอบเก็บข้อมูลล่าสุด", href: "/th/best/rainy-season-gear/" }
];

const featured = [
  {
    title: "แอร์ยี่ห้อไหนดี 2026: 10 อันดับจากหลักฐานจริง",
    text: "ทุกรุ่นเปิดหน้าร้านจริงก่อนจัดอันดับ — ตารางเทียบ กราฟ และจุดระวังก่อนจ่ายเงิน",
    href: "/th/best/air-conditioners/",
    image: "/images/air-conditioners/wall-ac-condo-hero.jpg",
    alt: "แอร์ติดผนังในคอนโดโทนอบอุ่น",
    meta: ["10 อันดับ", "ตารางเทียบ + กราฟ", "อัปเดต " + dataUpdatedLabel]
  },
  {
    title: "ของสู้หน้าฝน 2026: 7 ตัวช่วยผ้าแห้ง บ้านไม่ขึ้นรา",
    text: "เครื่องอบผ้า เครื่องอบรองเท้า เครื่องลดความชื้น — คัดจากยอดขายจริงหลักพันถึงหมื่นชิ้น",
    href: "/th/best/rainy-season-gear/",
    image: "/images/rainy-gear/tcl-wt09kfdyw-real-product.jpg",
    alt: "เครื่องอบผ้า TCL ภาพสินค้าจริงจากหน้าร้าน",
    meta: ["7 ตัวช่วย", "3 ปัญหาหน้าฝน", "อัปเดต " + dataUpdatedLabel]
  }
];

const workSteps = [
  { title: "เปิดหน้าสินค้าจริงทีละหน้า", text: "เก็บราคา ยอดขาย รีวิว พร้อมวันที่เก็บข้อมูล ไม่เดาตัวเลขที่มองไม่เห็น" },
  { title: "คัดเฉพาะตัวที่หลักฐานถึงเกณฑ์", text: "ยอดขายหรือรีวิวต้องแน่นพอให้ตามอ่านได้จริง ตัวที่ไม่ผ่านไม่ขึ้นหน้าเว็บ" },
  { title: "บอกจุดระวังก่อนปุ่มซื้อ", text: "ค่าติดตั้งเพิ่ม คิวช่าง เงื่อนไขเคลม พรีออเดอร์ — ความเสี่ยงจริงต้องเห็นก่อนจ่าย" },
  { title: "โปร่งใสเรื่องรายได้", text: "ลิงก์ไปร้านเป็นลิงก์พันธมิตร คุณไม่จ่ายแพงขึ้น และอันดับไม่มีขาย" }
];

const roadmapOpen = [
  { title: "หม้อทอดไร้น้ำมัน", href: "/th/best/air-fryers/", status: "รอรีเฟรชมาตรฐานใหม่" },
  { title: "เครื่องทำน้ำอุ่น", href: "/th/best/water-heaters/", status: "รอรีเฟรชมาตรฐานใหม่" }
];

const roadmapSoon = [
  { title: "ตู้เย็น", note: "กำลังเก็บหลักฐาน" },
  { title: "เครื่องดูดฝุ่น", note: "คิวถัดไปหลังหน้าฝน" },
  { title: "เครื่องฟอกอากาศ", note: "วางแผนรับฤดูฝุ่น" }
];

const latestArticles = [
  { title: "พัดลม 10 อันดับขายดีจริงบน Shopee (เรียงตามยอดขาย/เดือน)", href: "/th/c/fan/", tag: "ยอดฮิต", date: "7 ก.ค. 2026" },
  { title: "ราคาย้อนหลัง: ลดจริงหรือลดหลอก — บันทึกราคาที่เห็นจริง", href: "/th/guides/price-history/", tag: "เครื่องมือ", date: "6 ก.ค. 2026" },
  { title: "แอร์แบรนด์ญี่ปุ่น 2026: Daikin / Mitsubishi / Panasonic ตรวจหลักฐานจริง", href: "/th/best/air-conditioners-japanese-brands/", tag: "จัดอันดับ", date: "6 ก.ค. 2026" },
  { title: "แอร์ห้องนอนเสียงเงียบ 2026: 6 รุ่นที่รีวิวผู้ซื้อชมเรื่องเสียงจริง", href: "/th/best/air-conditioners-quiet-bedroom/", tag: "จัดอันดับ", date: "6 ก.ค. 2026" },
  { title: "แอร์ประหยัดไฟที่สุด 2026: จัดอันดับ 9 รุ่นอินเวอร์เตอร์จากหลักฐานจริง", href: "/th/best/air-conditioners-energy-saving/", tag: "จัดอันดับ", date: "5 ก.ค. 2026" },
  { title: "แอร์ยี่ห้อไหนดี 2026: 10 อันดับจากรีวิวผู้ซื้อจริง", href: "/th/best/air-conditioners/", tag: "จัดอันดับ", date: dataUpdatedLabel },
  { title: "แอร์ต่ำกว่า 10,000 บาท 2026: 6 รุ่นอินเวอร์เตอร์ที่ตรวจของจริง", href: "/th/best/air-conditioners-under-10000/", tag: "จัดอันดับ", date: dataUpdatedLabel },
  { title: "ของสู้หน้าฝน 2026: 7 ตัวช่วยผ้าแห้ง รองเท้าหอม บ้านไม่ขึ้นรา", href: "/th/best/rainy-season-gear/", tag: "จัดอันดับ", date: dataUpdatedLabel },
  { title: "เครื่องคิด BTU: ห้องคุณต้องใช้แอร์กี่ BTU", href: "/th/guides/btu-calculator/", tag: "เครื่องมือ", date: dataUpdatedLabel },
  { title: "เทียบแอร์ 8 แกนแบบเลือกเองได้", href: "/th/compare/air-conditioners/", tag: "เปรียบเทียบ", date: dataUpdatedLabel },
  { title: "รีวิวละเอียดแอร์รายรุ่น", href: "/th/reviews/air-conditioners/", tag: "รีวิวเดี่ยว", date: dataUpdatedLabel }
];
---

<section class="home-search-hero" aria-labelledby="home-hero-title">
  <div class="home-hero-glow" aria-hidden="true"></div>
  <div class="container home-search-inner">
    <div class="promise-row" aria-label="คำมั่นของ Friendsay">
      <span>มีข้อเสียให้เห็น</span>
      <span>ตัวเลขจากหน้าร้านจริง</span>
      <span>ไม่ให้ affiliate นำคำตอบ</span>
    </div>
    <h1 id="home-hero-title" class="home-brand-title" aria-label="Friendsay">
      {"Friendsay".split("").map((ch, i) => (
        <span class="brand-ch" style={`--ch-i:${i}`} aria-hidden="true">{ch}</span>
      ))}
    </h1>
    <p class="home-search-kicker">พิมพ์สิ่งที่กำลังหา เดี๋ยวเพื่อนเช็กหลักฐานให้</p>
    <form class="home-search-form" id="home-search-form" role="search" action="/th/" method="get">
      <input
        id="home-search-input"
        name="q"
        type="search"
        placeholder="เช่น แอร์ราคาต่ำกว่า 10000"
        aria-label="ค้นหาสินค้าที่ตรวจหลักฐานแล้ว"
        autocomplete="off"
      />
      <button class="button button-primary" type="submit">ค้นหา</button>
    </form>
    <div class="home-search-chips" aria-label="คำค้นแนะนำ">
      {heroChips.map((chip) => (
        <button class="search-chip" type="button" data-search-chip={chip}>{chip}</button>
      ))}
    </div>
    <p class="home-search-scope">
      ค้นจากของจริง {searchIndexCount} รุ่นที่เราเปิดหน้าร้านตรวจหลักฐานแล้ว (ไม่ใช่ทั้ง Shopee) · ราคา ณ รอบเก็บข้อมูล {dataUpdatedLabel}
    </p>
  </div>
</section>

<section class="section home-search-results" id="search-results" hidden>
  <div class="container">
    <p class="eyebrow">ผลการค้นหา</p>
    <h2 class="headline" id="search-results-title">ผลการค้นหา</h2>
    <p class="muted" id="search-results-note"></p>
    <div class="scenario-grid" id="search-results-grid" style="margin-top: 18px;"></div>
    <div class="roundup-actions" id="search-compare-cta" hidden style="margin-top: 16px;"></div>
    <div class="home-search-empty" id="search-results-empty" hidden>
      <p>
        ยังไม่เจอในฐานที่ตรวจแล้ว — ตอนนี้เราตรวจลึกทีละหมวดเพื่อไม่ให้มีตัวเลขมั่ว
        ลองคำค้นที่ฐานรองรับ หรือเปิดดูหมวดที่เปิดแล้วก่อนได้เลย
      </p>
      <div class="home-search-chips">
        {heroChips.map((chip) => (
          <button class="search-chip" type="button" data-search-chip={chip}>{chip}</button>
        ))}
      </div>
      <div class="roundup-actions" style="margin-top: 14px;">
        <a class="button" href="/th/best/air-conditioners/">ดู 10 อันดับแอร์</a>
        <a class="button" href="/th/best/rainy-season-gear/">ดูของสู้หน้าฝน</a>
      </div>
    </div>
  </div>
</section>

<section class="section home-proof-section" aria-label="สถานะเว็บ Friendsay">
  <div class="container">
    <div class="home-proof-strip">
      {heroSignals.map((signal) => (
        <a href={signal.href}>
          <strong data-countup={signal.count} data-suffix={signal.suffix}>{signal.value}</strong>
          <span>{signal.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<section class="section" aria-labelledby="home-featured-title">
  <div class="container">
    <p class="eyebrow">เริ่มจากหมวดที่ตรวจเสร็จแล้ว</p>
    <h2 class="headline" id="home-featured-title">งานที่หลักฐานครบ พร้อมให้เปิดอ่าน</h2>
    <div class="home-featured-grid">
      {featured.map((item) => (
        <a class="home-feature-story" href={item.href}>
          <img src={item.image} alt={item.alt} loading="lazy" />
