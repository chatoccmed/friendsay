<script is:inline>
  (() => {
    // delegation ระดับ document — ผูกครั้งเดียวพอ ใช้ได้กับทุกหน้า/ทุกครั้งที่ ClientRouter สลับ DOM
    if (window.__friendsayAffiliateTrackerBound) return;
    window.__friendsayAffiliateTrackerBound = true;

    const storageKey = "friendsay:affiliate-clicks";

    const saveLocalClick = (eventData) => {
      try {
        const current = JSON.parse(localStorage.getItem(storageKey) || "[]");
        const next = Array.isArray(current) ? [eventData, ...current].slice(0, 30) : [eventData];
        localStorage.setItem(storageKey, JSON.stringify(next));
      } catch {
        // Analytics should never block the buying flow.
      }
    };

    document.addEventListener("click", (event) => {
      const link = event.target instanceof Element ? event.target.closest("[data-affiliate-link]") : null;
      if (!(link instanceof HTMLAnchorElement)) return;

      const eventData = {
        event: "friendsay_affiliate_click",
        store: link.dataset.affiliateStore || "unknown",
        context: link.dataset.affiliateContext || "unknown",
        path: location.pathname,
        href: link.href,
        ts: new Date().toISOString()
      };

      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(eventData);
      window.dispatchEvent(new CustomEvent("friendsay:affiliate-click", { detail: eventData }));
      saveLocalClick(eventData);
    }, { passive: true });
  })();
</script>
