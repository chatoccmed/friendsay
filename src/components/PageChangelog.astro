---
// PageChangelog — "อัปเดตล่าสุด เพราะอะไร" + ประวัติย่อ (trust แบบ Wirecutter)
// ดึงจาก src/data/pageUpdates.ts ด้วย pageKey · ถ้าไม่มี entry จะไม่ render อะไรเลย
import { pageUpdates, type PageUpdate } from "../data/pageUpdates";

interface Props {
  pageKey: string;
}

const { pageKey } = Astro.props;
const entries: PageUpdate[] = pageUpdates[pageKey] ?? [];
const latest = entries[0];
---

{latest && (
  <div class="page-changelog" aria-label="ประวัติการอัปเดตหน้านี้">
    <p class="page-changelog-latest">
      <span class="page-changelog-badge">อัปเดตล่าสุด</span>
      <strong>{latest.date}</strong> — {latest.note}
    </p>
    {entries.length > 1 && (
      <details class="page-changelog-history">
        <summary>ดูประวัติการอัปเดตทั้งหมด ({entries.length} ครั้ง)</summary>
        <ul>
          {entries.map((e) => (
            <li><b>{e.date}</b> — {e.note}</li>
          ))}
        </ul>
      </details>
    )}
    <p class="page-changelog-foot">
      เราบันทึกทุกครั้งที่แตะข้อมูลหน้านี้ เพื่อให้คุณรู้ว่าตัวเลขสดแค่ไหน · ราคาบนหน้าคือราคา ณ วันอัปเดต เปลี่ยนได้ทุกวัน กดเช็กหน้าร้านก่อนซื้อเสมอ
    </p>
  </div>
)}

<style>
  .page-changelog {
    display: grid;
    gap: 10px;
    max-width: 820px;
    margin-top: 22px;
    border: 1px solid rgba(46, 196, 182, 0.32);
    border-radius: 14px;
    background:
      linear-gradient(135deg, rgba(233, 251, 247, 0.7), rgba(255, 255, 255, 0.92));
    padding: 18px 20px;
    box-shadow: var(--shadow-soft);
  }

  .page-changelog-latest {
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.98rem;
    line-height: 1.6;
  }

  .page-changelog-badge {
    display: inline-flex;
    align-items: center;
    margin-right: 8px;
    border-radius: 999px;
    background: #08756e;
    padding: 3px 11px;
    color: #fff;
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.01em;
    vertical-align: 2px;
  }

  .page-changelog-latest strong {
    color: var(--ink);
  }

  .page-changelog-history {
    border-top: 1px solid rgba(46, 196, 182, 0.24);
    padding-top: 10px;
  }

  .page-changelog-history summary {
    cursor: pointer;
    color: var(--coral-dark);
    font-weight: 800;
    font-size: 0.92rem;
  }

  .page-changelog-history ul {
    margin: 12px 0 0;
    padding-left: 18px;
    display: grid;
    gap: 8px;
  }

  .page-changelog-history li {
    color: var(--ink-soft);
    font-size: 0.92rem;
    line-height: 1.55;
  }

  .page-changelog-foot {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    line-height: 1.5;
  }
</style>
