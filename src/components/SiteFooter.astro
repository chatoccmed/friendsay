---
const year = new Date().getFullYear();

// กติกาลิงก์ (Audit 2 ข้อ 7): ทุกหน้า content ต้องมีทางเข้า ≥3 ทาง — footer คือทางที่สาม
const contentLinks = [
  { href: "/th/best/air-conditioners/", label: "แอร์ยี่ห้อไหนดี 2026" },
  { href: "/th/best/air-conditioners-under-10000/", label: "แอร์ต่ำกว่า 10,000 บาท" },
  { href: "/th/best/air-conditioners-energy-saving/", label: "แอร์ประหยัดไฟที่สุด 2026" },
  { href: "/th/best/air-conditioners-quiet-bedroom/", label: "แอร์ห้องนอนเสียงเงียบ 2026" },
  { href: "/th/best/air-conditioners-japanese-brands/", label: "แอร์แบรนด์ญี่ปุ่น 2026" },
  { href: "/th/best/rainy-season-gear/", label: "ของสู้หน้าฝน 2026" },
  { href: "/th/reviews/air-conditioners/", label: "รีวิวละเอียดแอร์รายรุ่น" },
  { href: "/th/compare/air-conditioners/", label: "เปรียบเทียบแอร์" },
  { href: "/th/guides/btu-calculator/", label: "เครื่องคิด BTU" },
  { href: "/th/guides/price-history/", label: "ราคาย้อนหลัง ลดจริงหรือลดหลอก" }
];

const metaLinks = [
  { href: "/about/", label: "About" },
  { href: "/editorial-policy/", label: "มาตรฐานรีวิว" },
  { href: "/affiliate-disclosure/", label: "Affiliate โปร่งใส" },
  { href: "/en/tourist/", label: "Tourist Hub" }
];
---

<footer class="footer">
  <div class="container footer-grid">
    <div>
      <a class="brand" href="/th/">
        <span class="brand-mark">F</span>
        <span>Friendsay</span>
      </a>
      <p class="muted">
        รีวิวสินค้าแบบเพื่อนช่วยเลือก ด้วยมาตรฐานข้อมูลที่ชัดเจน โปร่งใส และเป็นประโยชน์กับคนซื้อจริง
      </p>
      <p class="muted">ทำโดยคนหนึ่งคนกับ AI ที่ถูกคุมเข้ม — ทุกตัวเลขบนเว็บตรวจย้อนได้เสมอ</p>
      <p class="muted">© {year} Friendsay</p>
    </div>
    <nav class="footer-col" aria-label="รีวิวและเครื่องมือ">
      <strong>รีวิวและเครื่องมือ</strong>
      {contentLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
    <nav class="footer-col" aria-label="เกี่ยวกับ Friendsay">
      <strong>เกี่ยวกับเรา</strong>
      {metaLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
</footer>
