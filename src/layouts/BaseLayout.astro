---
import { ClientRouter } from "astro:transitions";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import "../styles/global.css";

type Props = {
  title: string;
  description: string;
  lang?: "th" | "en";
  canonical?: string;
  ogImage?: string;
  noindex?: boolean;
};

const {
  title,
  description,
  lang = "th",
  canonical = Astro.url.href,
  ogImage = "/images/friendsay-hero.png",
  noindex = false
} = Astro.props;

const ogImageUrl = new URL(ogImage, "https://friendsay.com").href;

// Google Analytics 4 — โหลดเฉพาะ build จริง (Cloudflare Pages) กัน traffic จาก npm run dev ปนข้อมูลจริง
const GA_MEASUREMENT_ID = "G-WY18XP1JEJ";

const siteJsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "Friendsay",
  url: "https://friendsay.com",
  description,
  potentialAction: {
    "@type": "SearchAction",
    target: "https://friendsay.com/th/?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {import.meta.env.PROD && (
      <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
    )}
    {import.meta.env.PROD && (
      <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
        window.dataLayer = window.dataLayer || [];
        // ต้องเป็น window.gtag (global) — Astro ห่อสคริปต์ define:vars ใน closure ทำให้ function ธรรมดาไม่ global
        // และสคริปต์อื่น (affiliate tracker / search / BTU share) ต้องเรียกใช้ยิง event ได้
        window.gtag = window.gtag || function () { window.dataLayer.push(arguments); };
        const gtag = window.gtag;
        gtag("js", new Date());
        // ปิด page_view อัตโนมัติ แล้วยิงเองทุกครั้งที่ ClientRouter เปลี่ยนหน้า (astro:page-load ยิงตอนโหลดแรกด้วย)
        gtag("config", GA_MEASUREMENT_ID, { send_page_view: false });
        document.addEventListener("astro:page-load", () => {
          if (location.hostname === "localhost" || location.hostname === "127.0.0.1") return;
          gtag("event", "page_view", { page_location: location.href, page_title: document.title });
        });
      </script>
    )}
    <link rel="preconnect" href="https://www.googletagmanager.com" />
    <link rel="preconnect" href="https://www.google-analytics.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Anuphan:wght@400;500;600;700&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#ff6b5a" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageUrl} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={ogImageUrl} />
    {noindex && <meta name="robots" content="noindex, follow" />}
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(siteJsonLd)} />
  </head>
  <body>
    <SiteHeader />
    <main>
      <slot />
    </main>
    <SiteFooter />
    <script>
      // Motion pass: scroll reveal + count-up + score-bar fill (ปิดเองเมื่อ prefers-reduced-motion)
      // ผูกกับ astro:page-load ให้ทำงานซ้ำทุกครั้งที่ ClientRouter สลับหน้า (ยิงตอนโหลดแรกด้วย)
      const initFriendsayMotion = () => {
      const prefersReduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      if (!prefersReduced) {
        document.documentElement.classList.add("js-motion");

        const selector = [
          ".product-card",
          ".home-persona-card",
          ".home-reading-card",
          ".home-world-card",
          ".scenario-grid article",
          ".source-grid article",
          ".faq-item",
          ".score-bar",
          ".home-proof-strip a",
          ".btu-calc",
          ".compare-table tbody tr"
        ].join(", ");

        const targets = Array.from(document.querySelectorAll<HTMLElement>(selector));
        const viewportCut = window.innerHeight * 0.92;

        const io = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-revealed");
                io.unobserve(entry.target);
              }
            }
          },
          { rootMargin: "0px 0px -6% 0px", threshold: 0.05 }
        );

        for (const el of targets) {
          const rect = el.getBoundingClientRect();
          if (rect.top < viewportCut) {
            // อยู่ในจอแรกแล้ว — ไม่ซ่อนเพื่อกันภาพวูบ (FOUC) แต่ยังให้ score bar เติมค่า
            el.classList.add("is-revealed");
            continue;
          }
          const siblings = el.parentElement ? Array.from(el.parentElement.children) : [el];
          const order = Math.max(0, siblings.indexOf(el)) % 6;
          el.style.setProperty("--reveal-delay", `${order * 70}ms`);
          el.classList.add("reveal-init");
          io.observe(el);
        }

        // score bars ในจอแรก: เติมค่าหลังโหลดเล็กน้อยให้เห็น animation
        requestAnimationFrame(() => {
          document.documentElement.classList.add("js-motion-ready");
        });

        // count-up ตัวเลข
        const easeOut = (t: number) => 1 - Math.pow(1 - t, 3);
        document.querySelectorAll<HTMLElement>("[data-countup]").forEach((el) => {
          const target = parseFloat(el.dataset.countup || "0");
          if (!target) return;
          const suffix = el.dataset.suffix || "";
          const duration = 1100;
          let started = false;
          const run = () => {
            if (started) return;
            started = true;
            const t0 = performance.now();
            const tick = (now: number) => {
              const p = Math.min(1, (now - t0) / duration);
              const value = Math.round(easeOut(p) * target);
              el.textContent = value.toLocaleString("th-TH") + suffix;
              if (p < 1) requestAnimationFrame(tick);
            };
            requestAnimationFrame(tick);
          };
          const cio = new IntersectionObserver((entries) => {
            if (entries.some((e) => e.isIntersecting)) {
              run();
              cio.disconnect();
            }
          });
          cio.observe(el);
        });
      }
      };
      document.addEventListener("astro:page-load", initFriendsayMotion);
    </script>
  </body>
</html>
