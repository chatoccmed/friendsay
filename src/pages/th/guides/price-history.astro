---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";
import { searchIndex } from "../../../data/searchIndex";
import acCsvRaw from "../../../data/price-history/air-conditioners.csv?raw";
import rainyCsvRaw from "../../../data/price-history/rainy-gear.csv?raw";
import { faqSchema } from "../../../utils/jsonLd";

const updatedLabel = "6 กรกฎาคม 2026";

// อ่าน ledger ราคา (append-only) — หนึ่งแถว = หนึ่งครั้งที่เห็นราคาจริงบนหน้าร้าน ห้ามเดาราคาที่ไม่เห็น
type PricePoint = { productKey: string; date: string; price: number; priceType: "list" | "promo"; source: string };
const parseCsv = (raw: string): PricePoint[] =>
  raw
    .trim()
    .split(/\r?\n/)
    .slice(1)
    .filter(Boolean)
    .map((line) => {
      const [productKey, date, price, priceType, source] = line.split(",");
      return { productKey, date, price: Number(price), priceType: priceType as PricePoint["priceType"], source };
    });

const THAI_MONTHS = ["ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
const thaiDate = (iso: string) => {
  const [y, m, d] = iso.split("-").map(Number);
  return `${d} ${THAI_MONTHS[m - 1]} ${y}`;
};
const baht = (n: number) => `฿${n.toLocaleString("th-TH")}`;
const typeLabel = (t: string) => (t === "list" ? "ราคาตั้ง" : "ราคาโปร");

const byId = new Map(searchIndex.map((item) => [item.id, item]));

// จัดกลุ่มราย productKey (คงลำดับตามไฟล์ ledger)
const groupPoints = (points: PricePoint[]) => {
  const groups: { key: string; name: string; href: string; affiliateUrl: string; points: PricePoint[] }[] = [];
  const seen = new Map<string, number>();
  for (const p of points) {
    if (!seen.has(p.productKey)) {
      const item = byId.get(p.productKey);
      seen.set(p.productKey, groups.length);
      groups.push({
        key: p.productKey,
        name: item?.name ?? p.productKey,
        href: item?.href ?? "/th/",
        affiliateUrl: item?.affiliateUrl ?? "",
        points: []
      });
    }
    groups[seen.get(p.productKey)!].points.push(p);
  }
  return groups;
};

const acGroups = groupPoints(parseCsv(acCsvRaw));
const rainyGroups = groupPoints(parseCsv(rainyCsvRaw));
const totalPoints = acGroups.concat(rainyGroups).reduce((sum, g) => sum + g.points.length, 0);
const totalProducts = acGroups.length + rainyGroups.length;

// บทเรียน "ลดจริงหรือลดหลอก" คำนวณจาก ledger ตรง ๆ (คู่ list/promo วันเดียวกัน)
const findPoint = (groups: typeof acGroups, key: string, type: string) =>
  groups.find((g) => g.key === key)?.points.find((p) => p.priceType === type);
const xiaomiList = findPoint(rainyGroups, "xiaomi-smart-dehumidifier", "list");
const xiaomiPromo = findPoint(rainyGroups, "xiaomi-smart-dehumidifier", "promo");
const hafeleList = findPoint(rainyGroups, "hafele-dehumidifier", "list");
const hafelePromo = findPoint(rainyGroups, "hafele-dehumidifier", "promo");
const pctOff = (list?: PricePoint, promo?: PricePoint) =>
  list && promo ? Math.round(((list.price - promo.price) / list.price) * 100) : null;
const xiaomiPct = pctOff(xiaomiList, xiaomiPromo);
const hafelePct = pctOff(hafeleList, hafelePromo);

const faqs = [
  {
    q: "จะรู้ได้ยังไงว่าป้ายลดราคาเป็นการลดจริงหรือลดหลอก?",
    a: "หลักง่าย ๆ คือเทียบกับ \"ราคาที่เคยขายจริง\" ไม่ใช่เทียบกับราคาตั้งบนป้าย เพราะราคาตั้ง (ราคาก่อนลด) เป็นตัวเลขที่ร้านกำหนดเองได้ ตัวอย่างจริงจากข้อมูลรอบแรกของเรา: เครื่องลดความชื้น Xiaomi เห็นราคาตั้งกับราคาโปรบนหน้าเดียวกันวันเดียวกัน ต่างกันเกือบครึ่ง ป้ายเปอร์เซ็นต์ลดจึงดูใหญ่มาก ทั้งที่ราคาโปรนั้นอาจเป็นราคาที่ขายกันปกติอยู่แล้ว วิธีที่เราช่วยได้คือจดราคาที่เห็นจริงไว้เป็นประวัติ พอถึงวันแคมเปญค่อยเทียบว่าถูกลงจากที่เคยเห็นจริงหรือเปล่า"
  },
  {
    q: "ทำไมประวัติราคายังมีไม่กี่จุด?",
    a: "เพราะเราเพิ่งเริ่มเก็บเมื่อมิถุนายน 2026 และเราบันทึกเฉพาะราคาที่เห็นจริงบนหน้าร้านเท่านั้น ไม่ย้อนแต่งประวัติที่เราไม่เห็น ไม่ดึงตัวเลขจากที่อื่นมามั่ว ทุกแถวมีวันที่และลิงก์หน้าสินค้ากำกับ ฐานข้อมูลจะหนาขึ้นทุกรอบเก็บหลักฐาน โดยเฉพาะช่วงก่อน-หลังแคมเปญใหญ่อย่าง 9.9 ที่เราตั้งใจเก็บถี่ขึ้น"
  },
  {
    q: "\"ราคาตั้ง\" กับ \"ราคาโปร\" ในตารางต่างกันยังไง?",
    a: "ราคาตั้ง (list) คือราคาก่อนลดที่แสดงบนหน้าสินค้า ส่วนราคาโปร (promo) คือราคาที่จ่ายจริงหลังโค้ด/Flash Sale ณ วันที่เราเห็น สองตัวนี้ต้องอ่านคู่กัน: ถ้าราคาตั้งสูงกว่าราคาโปรมาก ๆ ตลอดเวลา แปลว่าราคาตั้งแทบไม่มีความหมาย ให้ยึดราคาโปรที่เห็นซ้ำ ๆ เป็นราคาจริงของสินค้านั้น"
  },
  {
    q: "ควรใช้หน้านี้ยังไงก่อนแคมเปญ 9.9?",
    a: "สามขั้น: (1) เปิดหน้านี้ดูราคาล่าสุดที่เราเห็นของรุ่นที่คุณเล็ง (2) ก่อนวันแคมเปญ กดเช็กราคาปัจจุบันจากปุ่มในตาราง แล้วจดไว้ (3) วันแคมเปญจริง เทียบราคาที่เห็นกับประวัติ ถ้าถูกกว่าที่เคยเห็นจริงถึงค่อยรีบ ถ้าเท่าเดิมแต่ป้ายลดใหญ่ขึ้น แปลว่าเป็นการจัดฉากตัวเลข ไม่ต้องรีบตาม"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "ราคาย้อนหลัง: ลดจริงหรือลดหลอก — บันทึกราคาที่เห็นจริงบน Shopee",
  description:
    "เครื่องมือดูราคาย้อนหลังของสินค้าที่ Friendsay ตรวจหลักฐานแล้ว บันทึกเฉพาะราคาที่เห็นจริงบนหน้าร้าน พร้อมวิธีจับป้ายลดหลอกก่อนแคมเปญ 9.9",
  inLanguage: "th",
  dateModified: "2026-07-06",
  author: { "@type": "Organization", name: "Friendsay" }
};

const faqJsonLd = faqSchema(faqs);
---

<BaseLayout
  title="ราคาย้อนหลัง: ลดจริงหรือลดหลอก — บันทึกราคาที่เห็นจริง | Friendsay"
  description={`ประวัติราคาสินค้า ${totalProducts} รุ่นที่ Friendsay ตรวจหลักฐานแล้ว (${totalPoints} จุดราคา) บันทึกเฉพาะราคาที่เห็นจริงบนหน้าร้าน Shopee พร้อมวิธีจับป้ายลดหลอกก่อน 9.9 อัปเดต 6 ก.ค. 2026`}
  canonical="https://friendsay.com/th/guides/price-history/"
  ogImage="/images/friendsay-hero.png"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="page-hero ph-hero">
    <div class="container">
      <div class="badge-row">
        <span class="badge badge-coral">เครื่องมือ v1</span>
        <span class="badge badge-teal">อัปเดต {updatedLabel}</span>
        <span class="badge badge-blue">{totalProducts} รุ่น · {totalPoints} จุดราคา</span>
      </div>
      <h1>ราคาย้อนหลัง: ลดจริงหรือลดหลอก</h1>
      <p class="muted ph-hero-kicker">
        เราจดราคาที่ "เห็นจริงบนหน้าร้าน" ของทุกรุ่นที่ตรวจหลักฐานแล้ว แบบบันทึกเพิ่มอย่างเดียว ไม่แก้ย้อนหลัง ไม่เดาราคาที่ไม่เห็น —
        เพื่อให้วันที่ป้ายลดใหญ่ ๆ มาถึง คุณเทียบกับราคาที่เคยขายจริงได้ ไม่ใช่เทียบกับราคาตั้งที่ร้านกำหนดเอง
      </p>
      <div class="roundup-actions">
        <a class="button button-primary" href="#air">ดูราคาแอร์</a>
        <a class="button" href="#rainy">ดูของสู้หน้าฝน</a>
        <a class="button" href="#lesson">บทเรียนลดหลอกจากข้อมูลจริง</a>
      </div>
    </div>
  </section>

  <section class="section" id="lesson">
    <div class="container">
      <p class="eyebrow">บทเรียนจากข้อมูลรอบแรก</p>
      <h2 class="headline">ราคาตั้งกับราคาจริง ห่างกันได้ขนาดไหน</h2>
      <div class="ph-lesson-grid">
        {xiaomiList && xiaomiPromo && (
          <article class="ph-lesson-card">
            <span class="badge badge-coral">ตัวอย่างป้ายลดที่ต้องตั้งคำถาม</span>
            <h3>เครื่องลดความชื้น Xiaomi 22 ลิตร/วัน</h3>
            <p class="ph-lesson-numbers">
              <span>ราคาตั้ง {baht(xiaomiList.price)}</span>
              <strong>→ ราคาโปร {baht(xiaomiPromo.price)} (ต่างกัน {xiaomiPct}%)</strong>
            </p>
            <p>
              เห็นทั้งสองราคาบนหน้าเดียวกัน วันเดียวกัน ({thaiDate(xiaomiPromo.date)}) — เมื่อราคาตั้งสูงกว่าราคาที่ขายจริงเกือบครึ่ง
              ป้าย "ลด {xiaomiPct}%" จึงไม่ได้บอกว่าคุณประหยัดเท่านั้นจริง ๆ ให้ยึดราคาโปรที่เห็นซ้ำ ๆ เป็นราคาจริงของสินค้า
            </p>
          </article>
        )}
        {hafeleList && hafelePromo && (
          <article class="ph-lesson-card">
            <span class="badge badge-teal">ตัวอย่างส่วนลดขนาดปกติ</span>
            <h3>เครื่องลดความชื้น HAFELE 20 ตร.ม.</h3>
            <p class="ph-lesson-numbers">
              <span>ราคาตั้ง {baht(hafeleList.price)}</span>
              <strong>→ ราคาโปร {baht(hafelePromo.price)} (ต่างกัน {hafelePct}%)</strong>
            </p>
            <p>
              วันเดียวกัน ({thaiDate(hafelePromo.date)}) ราคาตั้งกับราคาโปรห่างกันราว {hafelePct}% — ระดับส่วนลดที่สมเหตุสมผลกว่า
              การเทียบสองเคสนี้คือเหตุผลที่เราเก็บทั้งราคาตั้งและราคาโปรแยกประเภทไว้เสมอ
            </p>
          </article>
        )}
      </div>
      <p class="muted" style="max-width: 780px; margin-top: 16px;">
        ฐานข้อมูลนี้เพิ่งเริ่มเก็บเมื่อมิถุนายน 2026 จึงยังมีไม่กี่จุดต่อรุ่น เราจะเก็บถี่ขึ้นช่วงก่อน-หลังแคมเปญใหญ่
        โดยเฉพาะรอบ 9.9 — และเราไม่ย้อนแต่งประวัติที่ไม่เห็นเด็ดขาด ทุกแถวมีวันที่กับหน้าสินค้าที่เห็นกำกับ
      </p>
    </div>
  </section>

  <section class="section band" id="air">
    <div class="wide-container">
      <p class="eyebrow">หมวดแอร์ · {acGroups.length} รุ่น</p>
      <h2 class="headline">ประวัติราคาแอร์ที่ตรวจหลักฐานแล้ว</h2>
      <div class="compare-shell">
        <table class="compare-table ph-table">
          <thead>
            <tr>
              <th>รุ่น</th>
              <th>ราคาที่เคยเห็นจริง (เรียงตามวันที่)</th>
              <th>เช็กราคาวันนี้</th>
            </tr>
          </thead>
          <tbody>
            {acGroups.map((g) => (
              <tr>
                <td><a href={g.href}><strong>{g.name}</strong></a></td>
                <td>
                  {g.points.map((p, i) => (
                    <span class={`ph-point ${p.priceType === "list" ? "is-list" : ""}`}>
                      {i > 0 ? " · " : ""}{thaiDate(p.date)}: <strong>{baht(p.price)}</strong> ({typeLabel(p.priceType)})
                    </span>
                  ))}
                </td>
                <td>
                  {g.affiliateUrl && (
                    <a class="button button-primary compare-buy" href={g.affiliateUrl} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`price-history-${g.key}`}>Shopee</a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="section" id="rainy">
    <div class="wide-container">
      <p class="eyebrow">หมวดของสู้หน้าฝน · {rainyGroups.length} รุ่น</p>
      <h2 class="headline">ประวัติราคาของสู้หน้าฝน</h2>
      <div class="compare-shell">
        <table class="compare-table ph-table">
          <thead>
            <tr>
              <th>รุ่น</th>
              <th>ราคาที่เคยเห็นจริง (เรียงตามวันที่)</th>
              <th>เช็กราคาวันนี้</th>
            </tr>
          </thead>
          <tbody>
            {rainyGroups.map((g) => (
              <tr>
                <td><a href={g.href}><strong>{g.name}</strong></a></td>
                <td>
                  {g.points.map((p, i) => (
                    <span class={`ph-point ${p.priceType === "list" ? "is-list" : ""}`}>
                      {i > 0 ? " · " : ""}{thaiDate(p.date)}: <strong>{baht(p.price)}</strong> ({typeLabel(p.priceType)})
                    </span>
                  ))}
                </td>
                <td>
                  {g.affiliateUrl && (
                    <a class="button button-primary compare-buy" href={g.affiliateUrl} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`price-history-${g.key}`}>Shopee</a>
                  )}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="compare-note">
        "ราคาตั้ง" = ราคาก่อนลดบนหน้าสินค้า · "ราคาโปร" = ราคาหลังโค้ด/Flash Sale ณ วันที่เห็น · ทุกจุดราคามาจากการเปิดหน้าร้านจริง
        มีวันที่และหน้าสินค้ากำกับใน ledger ของเรา · ราคาปัจจุบันเปลี่ยนได้ทุกวัน กดปุ่ม Shopee เพื่อดูราคาสด
      </p>
    </div>
  </section>

  <section class="section band" id="how-to">
    <div class="container">
      <p class="eyebrow">ใช้ก่อน 9.9</p>
      <h2 class="headline">วิธีใช้หน้านี้จับป้ายลดหลอก</h2>
      <div class="home-work-grid">
        <article class="home-work-card">
          <span>01</span>
          <h3>ดูราคาล่าสุดที่เราเห็น</h3>
          <p>เปิดตารางด้านบน ดูราคาโปรล่าสุดของรุ่นที่คุณเล็ง — นั่นคือ "ราคาจริง" ที่ใกล้เคียงที่สุด</p>
        </article>
        <article class="home-work-card">
          <span>02</span>
          <h3>จดราคาก่อนวันแคมเปญ</h3>
          <p>ก่อน 9.9 สักสองสามวัน กดเช็กราคาปัจจุบันแล้วจดไว้ ราคาบางร้านถูก "ปรับขึ้นก่อนลด"</p>
        </article>
        <article class="home-work-card">
          <span>03</span>
          <h3>วันจริง เทียบกับประวัติ</h3>
          <p>ถ้าราคาแคมเปญถูกกว่าที่เคยเห็นจริง ค่อยรีบ ถ้าเท่าเดิมแต่ป้ายลดใหญ่ขึ้น คือการจัดฉากตัวเลข</p>
        </article>
        <article class="home-work-card">
          <span>04</span>
          <h3>อย่าลืมค่าใช้จ่ายแฝง</h3>
          <p>แอร์มีค่าติดตั้ง/อุปกรณ์หน้างานเพิ่มเกือบทุกเคส ราคาเครื่องถูกลงร้อยสองร้อยอาจไม่คุ้มถ้าเงื่อนไขติดตั้งแย่กว่า</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="faq">
    <div class="container">
      <p class="eyebrow">คำถามที่ถามบ่อย</p>
      <h2 class="headline">เรื่องราคาที่ควรรู้ก่อนแคมเปญ</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
      <div class="roundup-actions" style="margin-top: 24px;">
        <a class="button button-primary" href="/th/best/air-conditioners/">ดู 10 อันดับแอร์ →</a>
        <a class="button" href="/th/best/rainy-season-gear/">ดูของสู้หน้าฝน</a>
        <a class="button" href="/th/guides/btu-calculator/">เครื่องคิด BTU</a>
      </div>
      <p class="compare-note" style="margin-top: 18px;">
        ledger ราคาเป็นแบบบันทึกเพิ่มอย่างเดียว (append-only) แก้ย้อนหลังไม่ได้ · อ่านมาตรฐานของเราที่ <a href="/editorial-policy/">Editorial Policy</a> ·
