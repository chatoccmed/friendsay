---
// หน้า catalog: "สินค้ายอดฮิตตามคีย์เวิร์ด" — tier-2 ของระบบเทียบ
// ข้อมูลจากหน้าค้นหา Shopee เรียงตามยอดขาย เก็บผ่านรอบ capture (ดู method ในไฟล์ data)
// ราคาเป็นราคาโดยประมาณ ณ วันเก็บ — ปุ่มซื้อคือ short link affiliate ที่สร้างจริงต่อรายการ
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";

export async function getStaticPaths() {
  const modules = import.meta.glob("../../../data/catalog/*.json", { eager: true });
  return Object.values(modules).map((mod: any) => {
    const catalog = mod.default ?? mod;
    return { params: { slug: catalog.slug }, props: { catalog } };
  });
}

const { catalog } = Astro.props;
const items = catalog.items;

// หมวดยอดฮิตอื่น — glob เดียวกับ getStaticPaths ลิงก์หากันอัตโนมัติเมื่อเพิ่มไฟล์ catalog ใหม่
const allCatalogs = Object.values(import.meta.glob("../../../data/catalog/*.json", { eager: true }))
  .map((mod: any) => mod.default ?? mod)
  .filter((c: any) => c.slug !== catalog.slug)
  .sort((a: any, b: any) => a.slug.localeCompare(b.slug));

const THAI_MONTHS = ["ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
const [cy, cm, cd] = catalog.collectedAt.split("-").map(Number);
const collectedLabel = `${cd} ${THAI_MONTHS[cm - 1]} ${cy}`;

const baht = (n: number) => `฿${n.toLocaleString("th-TH")}`;

// best-in-column จากข้อมูลจริง
const minPrice = Math.min(...items.map((p: any) => p.priceApprox));
const maxSold = Math.max(...items.map((p: any) => p.soldPerMonthNum));
const maxDiscount = Math.max(...items.map((p: any) => p.discountPct ?? 0));

const quickPicks = [
  { label: "ขายดีที่สุด", item: items.find((p: any) => p.soldPerMonthNum === maxSold) },
  { label: "ราคาเริ่มต่ำสุด", item: items.find((p: any) => p.priceApprox === minPrice) },
  maxDiscount > 0 ? { label: "ส่วนลดแรงสุด", item: items.find((p: any) => p.discountPct === maxDiscount) } : null
].filter(Boolean) as { label: string; item: any }[];

const chartMax = Math.max(...items.map((p: any) => p.priceApprox));

// ภาพรวมหมวด — คำนวณจากข้อมูลที่เก็บล้วน ๆ
const sortedPrices = items.map((p: any) => p.priceApprox).sort((a: number, b: number) => a - b);
const medianPrice = sortedPrices[Math.floor(sortedPrices.length / 2)];
// นับเฉพาะแบรนด์จริง — "ไม่ระบุแบรนด์" ขึ้นเป็นสถิติ "แบรนด์ครองลิสต์" แล้วชวนงง
const brandCounts = items.reduce((acc: Record<string, number>, p: any) => {
  if (p.brand && p.brand !== "ไม่ระบุแบรนด์") acc[p.brand] = (acc[p.brand] || 0) + 1;
  return acc;
}, {});
const topBrandEntry = Object.entries(brandCounts).sort((a: any, b: any) => b[1] - a[1])[0] as [string, number] | undefined;
const topBrandStat = topBrandEntry
  ? { value: `${topBrandEntry[0]}`, label: `แบรนด์ที่ครองลิสต์ (${topBrandEntry[1]}/${items.length} อันดับ)` }
  : { value: "หลากแบรนด์", label: "ลิสต์นี้ไม่มีแบรนด์ไหนครองชัด" };
const overviewStats = [
  { value: `${baht(minPrice)}–${baht(chartMax)}`, label: "ช่วงราคาที่เห็นในลิสต์" },
  { value: `~${baht(medianPrice)}`, label: "ราคากลางของลิสต์ (มัธยฐาน)" },
  topBrandStat,
  { value: items[0].soldPerMonth, label: `ยอดขาย/เดือนของแชมป์ (${items[0].brand})` }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: `${catalog.title}: ${items.length} อันดับขายดีบน Shopee`,
  description: `รวม${catalog.title}ขายดี ${items.length} อันดับจากหน้าค้นหา Shopee เรียงตามยอดขายจริง พร้อมราคาโดยประมาณ ยอดขายต่อเดือน และจุดสังเกตก่อนซื้อ`,
  inLanguage: "th",
  dateModified: catalog.collectedAt,
  author: { "@type": "Organization", name: "Friendsay" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: items.map((p: any) => ({
      "@type": "ListItem",
      position: p.rank,
      name: p.name,
      url: `https://friendsay.com/th/c/${catalog.slug}/#rank-${p.rank}`
    }))
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: (catalog.faqs || []).map((f: any) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a }
  }))
};

const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "หน้าแรก", item: "https://friendsay.com/th/" },
    { "@type": "ListItem", position: 2, name: "สินค้ายอดฮิต", item: "https://friendsay.com/th/c/" },
    { "@type": "ListItem", position: 3, name: catalog.title, item: `https://friendsay.com/th/c/${catalog.slug}/` }
  ]
};
---

<BaseLayout
  title={`${catalog.title}ยี่ห้อไหนดี ${cy}: ${items.length} อันดับขายดีจริงบน Shopee | Friendsay`}
  description={`${catalog.title}ขายดี ${items.length} อันดับจากหน้าค้นหา Shopee เรียงตามยอดขายต่อเดือนจริง พร้อมราคาโดยประมาณ คะแนนรีวิว จุดสังเกตก่อนซื้อ และปุ่มเช็กราคาสด อัปเดต ${collectedLabel}`}
  canonical={`https://friendsay.com/th/c/${catalog.slug}/`}
  ogImage={items[0].image}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  {catalog.faqs?.length ? <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} /> : null}
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <section class="page-hero cat-hero">
    <div class="container">
      <nav class="cat-breadcrumb" aria-label="ตำแหน่งหน้านี้">
        <a href="/th/">หน้าแรก</a>
        <span aria-hidden="true">›</span>
        <a href="/th/c/">สินค้ายอดฮิต</a>
        <span aria-hidden="true">›</span>
        <span aria-current="page">{catalog.title}</span>
      </nav>
      <div class="badge-row">
        <span class="badge badge-coral">สินค้ายอดฮิต</span>
        <span class="badge badge-teal">เก็บข้อมูล {collectedLabel}</span>
        <span class="badge badge-blue">เรียงตามยอดขายจริง/เดือน</span>
      </div>
      <h1>{catalog.title}: {items.length} อันดับขายดีบน Shopee</h1>
      <p class="muted cat-hero-kicker">
        อันดับมาจากหน้าค้นหา Shopee เรียงตามยอดขาย ณ วันที่เก็บข้อมูล — ไม่ใช่อันดับที่เราแต่งเอง
        ราคาเป็นราคาโดยประมาณที่เห็นวันนั้น กดปุ่มเช็กราคาเพื่อดูราคาสดก่อนตัดสินใจเสมอ
      </p>
      <div class="roundup-actions">
        <a class="button button-primary" href="#list">ดูทั้ง {items.length} อันดับ</a>
        <a class="button" href="#compare">ตารางเทียบ</a>
        <a class="button" href="#watch">จุดสังเกตก่อนซื้อ</a>
      </div>
    </div>
  </section>

  <section class="section band" id="quick-pick">
    <div class="container">
      <p class="eyebrow">เลือกด่วนใน 15 วินาที</p>
      <h2 class="headline">ตัวเด่นของหมวดนี้</h2>
      <div class="scenario-grid" style="margin-top: 18px;">
        {quickPicks.map((pick) => (
          <article class="rainy-pick-card">
            <div class="badge-row">
              <span class="badge badge-coral">{pick.label}</span>
              <span class="badge badge-blue">{pick.item.rating.toFixed(1)} ★</span>
            </div>
            <a href={`#rank-${pick.item.rank}`}>
              <picture>
                <source srcset={pick.item.image.replace(/\.jpg$/, ".webp")} type="image/webp" />
                <img class="rainy-img" src={pick.item.image} alt={`ภาพสินค้า ${pick.item.name}`} loading="lazy" width="800" height="800" />
              </picture>
            </a>
            <h3>{pick.item.brand} · ~{baht(pick.item.priceApprox)}</h3>
            <p>{pick.item.name.slice(0, 90)}</p>
            <a class="button button-primary" href={`#rank-${pick.item.rank}`}>ดูรายละเอียด ↓</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="overview">
    <div class="container">
      <p class="eyebrow">อ่านตลาดใน 10 วินาที</p>
      <h2 class="headline">ภาพรวมหมวด{catalog.title}จากลิสต์นี้</h2>
      <div class="cat-stats">
        {overviewStats.map((s) => (
          <div class="cat-stat">
            <strong>{s.value}</strong>
            <span>{s.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="list">
    <div class="wide-container">
      <p class="eyebrow">{items.length} อันดับ · เรียงตามยอดขาย/เดือนที่เห็นจริง</p>
      <h2 class="headline">{catalog.title}ขายดี เรียงตามยอดขายจริง</h2>
      <div class="cat-grid">
        {items.map((p: any) => (
          <article class="cat-card" id={`rank-${p.rank}`}>
            <a
              class="cat-card-media"
              href={p.link}
              target="_blank"
              rel="sponsored noopener"
              data-affiliate-link
              data-affiliate-store="shopee"
              data-affiliate-context={`catalog-${catalog.slug}-photo-${p.rank}`}
            >
              <span class="cat-rank">อันดับ {p.rank}</span>
              <picture>
                <source srcset={p.image.replace(/\.jpg$/, ".webp")} type="image/webp" />
                <img src={p.image} alt={`ภาพสินค้า ${p.name}`} loading="lazy" width="800" height="800" />
              </picture>
            </a>
            <div class="cat-card-body">
              <div class="badge-row">
                <span class="badge badge-teal">ขายได้ {p.soldPerMonth} ชิ้น/เดือน</span>
                <span class="badge badge-blue">{p.rating.toFixed(1)} ★</span>
                {p.ratingsCount ? <span class="badge">รีวิว {p.ratingsCount.toLocaleString("th-TH")} รายการ</span> : null}
              </div>
              <h3>{p.name}</h3>
              <div class="cat-facts">
                <div><span>ราคาโดยประมาณ</span><strong>~{baht(p.priceApprox)}</strong></div>
                <div><span>ส่วนลดที่เห็น</span><strong>{p.discountPct ? `-${p.discountPct}%` : "—"}</strong></div>
                <div><span>ส่งจาก</span><strong>{p.province ?? "—"}</strong></div>
                <div><span>แบรนด์</span><strong>{p.brand}</strong></div>
              </div>
              {p.insight ? <p class="cat-insight"><b>อ่านเกมให้:</b> {p.insight}</p> : null}
              {(p.reviewGood?.length || p.reviewWatch?.length) ? (
                <div class="compare-card-reviews">
                  {p.reviewGood?.length ? (
                    <div class="compare-reviews-good">
                      <strong>ข้อดีที่รีวิวพูดซ้ำ</strong>
                      <ul>{p.reviewGood.map((s: string) => <li>{s}</li>)}</ul>
                    </div>
                  ) : null}
                  {p.reviewWatch?.length ? (
                    <div class="compare-reviews-bad">
                      <strong>จุดสังเกตจากรีวิว</strong>
                      <ul>{p.reviewWatch.map((s: string) => <li>{s}</li>)}</ul>
                    </div>
                  ) : null}
                </div>
              ) : null}
              <a class="button button-primary cat-buy" href={p.link} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`catalog-${catalog.slug}-${p.rank}`}>
                เช็กราคาจริงวันนี้ →
              </a>
            </div>
          </article>
        ))}
      </div>
      <p class="compare-note" style="margin-top: 16px;">
        ราคาโดยประมาณ ณ {collectedLabel} ส่วนใหญ่เป็นราคาช่วงโปร เปลี่ยนได้ทุกวัน · "ขายได้/เดือน" คือตัวเลขที่ Shopee แสดงบนหน้าค้นหาวันนั้น
      </p>
    </div>
  </section>

  <section class="section band" id="compare">
    <div class="wide-container">
      <p class="eyebrow">ตารางเปรียบเทียบ</p>
      <h2 class="headline">เทียบทั้ง {items.length} อันดับในตาเดียว</h2>
      <p class="cat-table-scroll-hint" aria-hidden="true">เลื่อนตารางไปทางขวาได้ →</p>
      <div class="compare-shell">
        <table class="compare-table">
          <thead>
            <tr>
              <th>อันดับ · รุ่น</th>
              <th>ราคาโดยประมาณ</th>
              <th>ขายได้/เดือน</th>
              <th>คะแนน</th>
              <th>ส่วนลดที่เห็น</th>
              <th>เช็กราคา</th>
            </tr>
          </thead>
          <tbody>
            {items.map((p: any) => (
              <tr>
                <td><strong>{p.rank}. {p.brand}</strong><br /><a class="compare-detail-link" href={`#rank-${p.rank}`}>{p.name.slice(0, 48)}…</a></td>
                <td class={p.priceApprox === minPrice ? "is-best" : undefined}>~{baht(p.priceApprox)}</td>
                <td class={p.soldPerMonthNum === maxSold ? "is-best" : undefined}>{p.soldPerMonth}</td>
                <td>{p.rating.toFixed(1)} ★</td>
                <td class={maxDiscount > 0 && p.discountPct === maxDiscount ? "is-best" : undefined}>{p.discountPct ? `-${p.discountPct}%` : "—"}</td>
                <td><a class="button button-primary compare-buy" href={p.link} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`catalog-${catalog.slug}-table-${p.rank}`}>Shopee</a></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="compare-note">✓ เขียว = ค่าที่ดีที่สุดของคอลัมน์ · คะแนนบนหน้าค้นหาเป็นคะแนนรวมของร้าน/สินค้าแบบย่อ อ่านรีวิวจริงบนหน้าสินค้าประกอบ</p>

      <h3 class="headline" style="margin-top: 36px; font-size: 1.3rem;">เทียบราคาแบบเห็นภาพ</h3>
      <div class="rainy-chart" role="img" aria-label={`กราฟแท่งเทียบราคาโดยประมาณของ${catalog.title} ${items.length} อันดับ สั้นกว่าคือถูกกว่า`}>
        <svg viewBox={`0 0 900 ${items.length * 46 + 10}`}>
          {items.map((p: any, i: number) => {
            const y = i * 46 + 8;
            const barW = Math.max(40, (p.priceApprox / chartMax) * 440);
            return (
              <g class="rainy-bar" style={`animation-delay:${i * 80}ms`}>
                <text x="0" y={y + 19} class="rainy-bar-name">{p.rank}. {p.brand}</text>
                <rect x="215" y={y} width={barW} height="28" rx="8" fill={p.priceApprox === minPrice ? "#0ea5a0" : "#ff6b5a"} opacity="0.85" />
                <text x={222 + barW} y={y + 19} class="rainy-bar-value">~{baht(p.priceApprox)} · ขาย {p.soldPerMonth}/เดือน</text>
              </g>
            );
          })}
        </svg>
        <p class="compare-note">ความยาวแท่ง = ราคาโดยประมาณ (สั้น = ถูกกว่า) · <span style="color:#0ea5a0">■</span> ถูกสุดในลิสต์</p>
      </div>
    </div>
  </section>

  <section class="section" id="watch">
    <div class="container">
      <p class="eyebrow">ก่อนกดซื้อ</p>
      <h2 class="headline">จุดสังเกตของหมวด{catalog.title}</h2>
      <ul class="cat-watch-list">
        {(catalog.categoryWatch || []).map((w: string) => <li>{w}</li>)}
      </ul>
    </div>
  </section>

  {catalog.faqs?.length ? (
    <section class="section band" id="faq">
      <div class="container">
        <p class="eyebrow">คำถามที่ถามบ่อย</p>
        <h2 class="headline">เรื่องที่คนหา{catalog.title}อยากรู้</h2>
        <div class="faq-list">
          {catalog.faqs.map((f: any) => (
            <details class="faq-item">
              <summary>{f.q}</summary>
              <p>{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  ) : null}

  <section class="section" id="method">
    <div class="container">
      <p class="eyebrow">ที่มาของอันดับ</p>
      <h2 class="headline">อันดับนี้มาจากไหน</h2>
      <p class="muted" style="max-width: 760px;">
        {catalog.method} — เราคัดเฉพาะรายการที่ Shopee แสดงยอดขายต่อเดือนจริง (ตัดโฆษณา/รายการที่ไม่มีตัวเลขออก)
        อันดับจึงสะท้อนว่า "คนซื้ออะไรมากที่สุดตอนนี้" ไม่ใช่ความเห็นของเรา และเราไม่รับเงินเพื่อจัดอันดับ
        หมวดนี้เป็นหน้าข้อมูลจากหน้าค้นหา (ยังไม่ใช่หมวดที่เราตรวจเจาะลึกรายรุ่นแบบหมวดแอร์) —
        ลิงก์ในหน้าเป็นลิงก์ affiliate ถ้ากดซื้อผ่านเรา เราอาจได้ค่าคอมมิชชั่นเล็กน้อยโดยคุณไม่จ่ายเพิ่ม
        (<a href="/affiliate-disclosure/">รายละเอียด</a>)
      </p>
      <div class="roundup-actions" style="margin-top: 20px;">
        <a class="button button-primary" href="/th/">ค้นหาสินค้าอื่นที่ตรวจแล้ว</a>
        <a class="button" href="/th/guides/price-history/">ราคาย้อนหลัง ลดจริงหรือลดหลอก</a>
      </div>
    </div>
  </section>

  {allCatalogs.length ? (
    <section class="section band" id="more-catalogs">
      <div class="container">
        <p class="eyebrow">หมวดยอดฮิตอื่น</p>
        <h2 class="headline">ดูอันดับขายดีหมวดอื่นต่อ</h2>
        <div class="roundup-actions" style="margin-top: 18px;">
          {allCatalogs.map((c: any) => (
            <a class="button" href={`/th/c/${c.slug}/`}>{c.title}ขายดี {c.items.length} อันดับ</a>
          ))}
        </div>
      </div>
    </section>
  ) : null}

  <AffiliateClickTracker />
</BaseLayout>

<style>
  .cat-hero {
    background:
      radial-gradient(1100px 480px at 50% -80px, rgba(255, 214, 186, 0.55), transparent 70%),
      linear-gradient(180deg, #fff8ee, #fffdf8);
  }

  .cat-hero-kicker {
    max-width: 760px;
    font-size: 1.06rem;
  }

  .cat-breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
    color: var(--muted);
    font-size: 0.86rem;
  }

  .cat-breadcrumb a {
    color: inherit;
    text-decoration: none;
  }

  .cat-breadcrumb a:hover {
    color: var(--coral);
    text-decoration: underline;
  }

  .cat-table-scroll-hint {
    display: none;
    margin: 10px 0 0;
    color: var(--muted);
