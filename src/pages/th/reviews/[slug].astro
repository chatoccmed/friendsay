const articleTitle = titleOverrides[review.productKey] ?? `${review.shortName}: แอร์ ${firstBtu} สำหรับคนอยากซื้อให้จบแบบสบายใจ`;
const description = `${review.name} รีวิวแบบเพื่อนช่วยดู เหมาะกับห้องแบบไหน จุดเด่น จุดต้องถามร้าน BTU ค่าติดตั้ง ประกัน และลิงก์เช็กราคา Shopee Lazada TikTok`;

const product = {
  slug: review.productKey,
  name: review.name,
  shortName: review.shortName,
  statusLabel: hasReviewProof ? `${review.sourceName} มีข้อมูลให้เทียบ ${proofCountText}+ รายการ` : "เช็กสเปก ราคา และร้านก่อนซื้อ",
