---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PriceButtons from "../../../components/PriceButtons.astro";
import ScoreBars from "../../../components/ScoreBars.astro";
import AirCompareTray from "../../../components/AirCompareTray.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";
import { airConditioners } from "../../../data/airConditioners";
import { queuedAirConditionerReviews, type QueuedAirConditionerReview } from "../../../data/airConditionerReviewQueue";

export function getStaticPaths() {
  return queuedAirConditionerReviews.map((review) => ({
    params: { slug: review.reviewSlug },
    props: { review }
  }));
}

type Props = {
  review: QueuedAirConditionerReview;
};

const { review } = Astro.props;

const firstBtu = review.btuOptions[0] ?? "9,000 BTU";
const proofText =
  review.proofCount > 5
    ? `${review.sourceName} มีรีวิว/คะแนนให้ตรวจ ${review.proofCount.toLocaleString("th-TH")} รายการ`
    : `${review.sourceName} มีข้อมูลสินค้าให้เริ่มเทียบ`;
const articleTitle = `รีวิว ${review.shortName}: แอร์ ${firstBtu} ที่ควรเก็บไว้เทียบก่อนซื้อ`;
const description = `${review.name} เหมาะกับใคร จุดดี จุดต้องถามร้าน BTU ค่าติดตั้ง ประกัน และลิงก์เช็กราคา Shopee Lazada TikTok แบบอ่านง่ายก่อนจ่ายเงินจริง`;
const btuText = review.btuOptions.join(" / ");

const scoreItems = [
  { label: "ความน่าเข้ารอบ", value: review.score },
  { label: "ความมั่นใจผู้ซื้อ", value: review.buyerConfidence },
  { label: "ความคุ้มค่า", value: review.value },
  { label: "เลือก BTU ง่าย", value: review.roomFit },
  { label: "ข้อมูลติดตั้งชัด", value: review.installClarity },
  { label: "ประกัน/บริการ", value: review.warrantySafety }
];

const imagePool = [
  "/images/air-conditioners/wall-ac-condo-hero.png",
  "/images/air-conditioners/wall-ac-btu-bedroom.png",
  "/images/air-conditioners/wall-ac-installation-check.png",
  "/images/air-conditioners/wall-ac-cost-warranty.png",
  "/images/air-conditioners/midea-celest-hero-bedroom.png",
  "/images/air-conditioners/midea-celest-energy-day.png",
  "/images/air-conditioners/midea-celest-install-plan.png",
  "/images/air-conditioners/midea-celest-review-room-fit.png",
  "/images/air-conditioners/tcl-savein-ai-clean-unit.png",
  "/images/air-conditioners/tcl-savein-ai-install-concrete.png",
  "/images/air-conditioners/xiaomi-mijia-quiet-night.png",
  "/images/air-conditioners/xiaomi-mijia-cost-checklist.png"
];
const imageOffset = review.queueRank % imagePool.length;
const rotatedImages = [...imagePool.slice(imageOffset), ...imagePool.slice(0, imageOffset)];
const pageImages = Array.from(new Set([review.heroImage, review.secondaryImage, ...rotatedImages])).slice(0, 6);

const cockpitSteps = [
  {
    label: "1",
    title: "ดูห้องจริงก่อนดูโปร",
    body: `${review.shortName} มีตัวเลือก ${btuText} ให้เริ่มจากขนาดห้อง แดด หน้าต่าง ความสูงฝ้า และจำนวนคนในห้องก่อน`
  },
  {
    label: "2",
    title: "รวมราคาจบให้ได้",
    body: `ราคาอ้างอิงคือ ${review.priceLabel} แต่แอร์ต้องคิดค่าติดตั้ง ท่อ ราง ขาแขวน สายไฟ และงานเจาะเพิ่มด้วย`
  },
  {
    label: "3",
    title: "ถามร้านให้ชัด",
    body: `ก่อนจ่ายให้ยืนยันรุ่นเต็ม ${review.model}, BTU, วันช่าง, เงื่อนไขประกัน และอุปกรณ์ที่รวมในราคา`
  }
];

const buyerSnapshotCards = [
  {
    label: "ควรเข้ารอบ",
    title: review.shortName,
    body: review.bestFor
  },
  {
    label: "ต้องคิดก่อน",
    title: "อย่าดูแค่ราคาเครื่อง",
    body: "รุ่นที่ราคาดีอาจไม่ใช่รุ่นที่จบถูกที่สุด ถ้าค่าติดตั้งและอุปกรณ์เพิ่มไม่ชัดตั้งแต่แรก"
  },
  {
    label: "เหมาะกับห้อง",
    title: review.roomHint,
    body: `ถ้าห้องของคุณใกล้เคียงกับโจทย์นี้ ${review.shortName} ถือว่าน่าเอาไปเทียบกับรุ่นราคาใกล้กัน`
  }
];

const visualCards = [
  {
    image: pageImages[0],
    label: "ภาพหลัก",
    title: `ดูทรงเครื่องของ ${review.shortName}`,
    body: "ใช้จับภาพรวมว่าหน้าตา สี และทรงเครื่องเข้ากับห้องไหม ก่อนอ่านรายละเอียดลึก"
  },
  {
    image: pageImages[1],
    label: "ขนาดห้อง",
    title: "ลองนึกภาพกับห้องจริง",
    body: "แอร์ตัวเดียวกันอาจเหมาะหรือไม่เหมาะต่างกันมาก ถ้าห้องโดนแดดหรือกระจกเยอะ"
  },
  {
    image: pageImages[2],
    label: "ติดตั้ง",
    title: "คุยเรื่องช่างก่อนจ่าย",
    body: "ตำแหน่งคอยล์เย็น คอยล์ร้อน และทางเดินท่อมีผลกับราคาและความเรียบร้อยของงาน"
  },
  {
    image: pageImages[3],
    label: "ต้นทุนจริง",
    title: "ราคาเครื่องไม่ใช่ราคาสุดท้าย",
    body: "ก่อนตัดสินใจให้ถามราคาแบบจบงาน เพื่อเทียบกับรุ่นอื่นได้ตรงกว่า"
  },
  {
    image: pageImages[4],
    label: "ใช้งานจริง",
    title: "ห้องนอนต้องดูเสียงและความนิ่ง",
    body: "ถ้าใช้ตอนกลางคืน ให้ไล่อ่านรีวิวเรื่องเสียง รีโมต และการคุมอุณหภูมิเป็นพิเศษ"
  },
  {
    image: pageImages[5],
    label: "หลังซื้อ",
    title: "ประกันและศูนย์สำคัญกว่าที่คิด",
    body: "แอร์เป็นของติดบ้านหลายปี รุ่นที่ดูแลหลังซื้อชัดจะสบายใจกว่าเวลามีปัญหา"
  }
];

const reviewTakeaways = [
  {
    label: "01",
    title: "เหตุผลที่รุ่นนี้น่าเข้ารอบ",
    body: review.strengths[0] ?? "เป็นรุ่นที่มีข้อมูลให้เปรียบเทียบได้พอสมควร และเหมาะกับคนที่อยากซื้อแบบมีเหตุผล"
  },
  {
    label: "02",
    title: "ใครน่าจะชอบ",
    body: review.bestFor
  },
  {
    label: "03",
    title: "ใครควรเทียบรุ่นอื่นก่อน",
    body: review.notFor
  },
  {
    label: "04",
    title: "จุดที่ต้องถามร้าน",
    body: review.watchouts[0]
      ? `${review.watchouts[0]} ดังนั้นให้ถามร้านเป็นตัวเลขชัด ๆ ว่าราคาเครื่อง รวมติดตั้ง และอุปกรณ์เพิ่มคิดอย่างไร`
      : "ถามราคาแบบรวมติดตั้ง อุปกรณ์ วันช่าง และเงื่อนไขประกันให้ครบก่อนจ่าย"
  },
  {
    label: "05",
    title: "เรื่องที่ไม่ควรเดาเอง",
    body: `ให้ร้านยืนยันชื่อรุ่นเต็ม ${review.model}, BTU ${btuText}, วันติดตั้ง และเงื่อนไขประกันเป็นข้อความในแชทก่อนจ่าย เพราะแอร์หลายรุ่นมีรหัสใกล้กันและแพ็กเกจติดตั้งไม่เหมือนกัน`
  },
  {
    label: "06",
    title: "วิธีตัดสินแบบเร็ว",
    body: `ถ้าราคา ${review.priceLabel} รวมงานติดตั้งชัด และ BTU ตรงกับห้องของคุณ รุ่นนี้ควรอยู่ใน shortlist แล้วค่อยเทียบกับอีก 2 รุ่นในงบเดียวกัน`
  }
];

const btuCards = review.btuOptions.map((btu) => {
  const value = Number.parseInt(btu.replace(/[^0-9]/g, ""), 10);
  const isLarge = value >= 12000;
  const isVeryLarge = value >= 18000;

  return {
    btu,
    room: isVeryLarge ? "ห้องใหญ่ / ห้องรับแขก / แดดแรง" : isLarge ? "ห้องนอนกลาง / ห้องทำงานใหญ่" : "ห้องนอนเล็ก / คอนโด / ห้องทำงาน",
    note: isVeryLarge
      ? "เหมาะเมื่อพื้นที่เปิดกว้างหรือมีภาระความร้อนสูง แต่ต้องเช็กไฟ จุดวางคอยล์ร้อน และค่าติดตั้งให้ชัด"
      : isLarge
        ? "เป็นช่วงที่คนใช้บ่อยในห้องนอนกลาง แต่ถ้าห้องไม่ร้อนมากอาจไม่ต้องขยับเกินจำเป็น"
        : "เริ่มต้นดีสำหรับห้องเล็กถึงกลางที่แดดไม่จัด ถ้าห้องโดนแดดบ่ายหรือกระจกเยอะให้ถามร้านก่อน"
  };
});

const alternatives = queuedAirConditionerReviews
  .filter((item) => item.productKey !== review.productKey)
  .sort((a, b) => {
    const brandA = a.brand === review.brand ? 0 : 1;
    const brandB = b.brand === review.brand ? 0 : 1;
    if (brandA !== brandB) return brandA - brandB;
    return Math.abs(a.queueRank - review.queueRank) - Math.abs(b.queueRank - review.queueRank);
  })
  .slice(0, 4);

const questions = [
  `รุ่นที่ส่งจริงคือ ${review.model} ใช่ไหม และ BTU ตรงกับที่เลือกหรือเปล่า`,
  "ราคานี้รวมติดตั้งมาตรฐานกี่เมตร รวมท่อ ราง ขาแขวน และสายไฟไหม",
  "ถ้าหน้างานเกินมาตรฐาน มีค่าอะไรเพิ่ม และคิดราคาอย่างไร",
  "นัดช่างได้เร็วสุดวันไหน ถ้าเลื่อนคิวต้องติดต่อใคร",
  "ประกันเครื่อง คอมเพรสเซอร์ อะไหล่ และค่าแรง ครอบคลุมกี่ปี",
  "ถ้าเป็นคอนโด ต้องใช้เอกสารช่างหรือแจ้งนิติบุคคลก่อนหรือไม่"
];

const faqItems = [
  {
    q: `${review.shortName} เหมาะกับห้องแบบไหน`,
    a: `ดูจากตัวเลือก BTU หลักคือ ${btuText} เหมาะกับ ${review.roomHint} แต่ควรให้ร้านช่วยประเมินแดด กระจก ความสูงฝ้า และจำนวนคนในห้องก่อนตัดสินใจ`
  },
  {
    q: "ควรซื้อทันทีไหมถ้าเจอโปรดี",
    a: "ถ้าโปรดีแต่ยังไม่รู้ค่าติดตั้งและวันช่าง ผมยังไม่อยากให้รีบกดจ่าย ควรถามราคาแบบจบงานก่อน เพราะแอร์มีค่าใช้จ่ายหลังตะกร้ามากกว่าสินค้าทั่วไป"
  },
  {
    q: "ก่อนจ่ายควรเช็กร้านยังไง",
    a: "ดูชื่อรุ่นเต็ม BTU รีวิวล่าสุด รูปงานติดตั้งจริง วิธีคุยของร้าน เงื่อนไขประกัน และถามให้ร้านสรุปราคาจบเป็นข้อความไว้ในแชท"
  }
];

const compareProducts = [
  ...airConditioners.map((item) => ({ slug: item.slug, name: item.name, shortName: item.shortName })),
  ...queuedAirConditionerReviews.map((item) => ({ slug: item.productKey, name: item.name, shortName: item.shortName }))
].filter((item, index, list) => list.findIndex((candidate) => candidate.slug === item.slug) === index);

const compareHref = `/th/compare/air-conditioners/?items=${encodeURIComponent(
  [review.productKey, ...airConditioners.slice(0, 3).map((item) => item.slug)].join(",")
)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: review.name,
    brand: review.brand,
    category: "Wall mounted air conditioner"
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: review.score,
    bestRating: 10,
    worstRating: 1
  },
  author: {
    "@type": "Organization",
    name: "Friendsay"
  }
};
---

<BaseLayout
  title={`${articleTitle} | Friendsay`}
  description={description}
  canonical={`https://friendsay.com/th/reviews/${review.reviewSlug}/`}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="review-shell" style={`--accent:${review.accent};`}>
    <section class="review-hero">
      <div class="hero-copy">
        <p class="eyebrow">รีวิวแอร์ 2026 / เลือกก่อนจ่ายจริง</p>
        <h1>{articleTitle}</h1>
        <p class="hero-lead">
          ถ้าเพื่อนส่งรุ่นนี้มาให้ดู ผมจะบอกว่าให้เก็บไว้เทียบได้ครับ จุดขายคือ {review.buyerAngle}
          แต่ก่อนกดซื้อให้เช็ก BTU ราคาจบ วันช่าง และประกันให้ครบก่อน
        </p>
        <div class="hero-actions">
          <PriceButtons links={review.links} context={`${review.productKey}-hero`} />
          <button class="button compare-hero-button" type="button" data-air-compare-slug={review.productKey}>
            เลือกไว้เทียบ
          </button>
          <a class="button subtle" href="/th/reviews/air-conditioners/">ดูรีวิวแอร์ทั้งหมด</a>
        </div>
      </div>

      <a
        class="hero-visual"
        href={review.links.shopee}
        target="_blank"
        rel="sponsored noopener"
        data-affiliate-link
        data-affiliate-store="shopee"
        data-affiliate-context={`${review.productKey}-hero-image`}
      >
        <img src={pageImages[0]} alt={`ภาพประกอบรีวิว ${review.name}`} loading="eager" />
        <div class="hero-score-card">
          <span>{proofText}</span>
          <strong>{review.score.toFixed(1)}/10</strong>
          <p>น่าเอาเข้ารอบ ถ้า BTU ตรงห้องและร้านตอบเรื่องติดตั้งชัด</p>
        </div>
      </a>
    </section>

    <section class="section" id="buying-cockpit">
      <div class="container cockpit-grid">
        <a
          class="cockpit-visual"
          href={review.links.shopee}
          target="_blank"
          rel="sponsored noopener"
          data-affiliate-link
          data-affiliate-store="shopee"
          data-affiliate-context={`${review.productKey}-cockpit-image`}
        >
          <img src={pageImages[1]} alt={`ภาพช่วยตัดสินใจสำหรับ ${review.name}`} loading="lazy" />
          <div>
            <span>คำตอบเร็ว</span>
            <strong>{review.score.toFixed(1)}/10</strong>
            <p>เข้ารอบได้ แต่ต้องถามราคาจบและงานติดตั้งก่อนจ่าย</p>
          </div>
        </a>

        <div class="cockpit-panel">
          <p class="eyebrow">ตัดสินใจใน 90 วินาที</p>
          <h2>ถ้าจะซื้อ {review.shortName} ให้เริ่มจากตรงนี้</h2>
          <div class="cockpit-steps">
            {cockpitSteps.map((step) => (
              <article>
                <span>{step.label}</span>
                <div>
                  <h3>{step.title}</h3>
                  <p>{step.body}</p>
                </div>
              </article>
            ))}
          </div>
        </div>

        <div class="price-panel">
          <span>เช็กราคาแบบมีสติ</span>
          <h3>{review.priceLabel}</h3>
          <p>ราคาเครื่องอย่างเดียวอาจยังไม่ใช่ราคาจบ ให้เปิดร้านแล้วถามค่าอุปกรณ์และวันช่างก่อน</p>
          <PriceButtons links={review.links} context={`${review.productKey}-cockpit-price`} />
        </div>
      </div>
    </section>

    <section class="section compact-section" id="snapshot">
      <div class="container">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Buyer Snapshot</p>
            <h2>เห็นภาพรวมก่อนอ่านยาว</h2>
          </div>
          <p>ส่วนนี้ตั้งใจให้สแกนเร็ว ๆ ว่ารุ่นนี้ตรงโจทย์ไหม แล้วค่อยลงรายละเอียดด้านล่าง</p>
        </div>
        <div class="snapshot-grid">
          {buyerSnapshotCards.map((card) => (
            <article>
              <span>{card.label}</span>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="visual-proof">
      <div class="container">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Visual Guide</p>
            <h2>ภาพประกอบช่วยคิดก่อนซื้อ</h2>
          </div>
          <p>ทุกภาพกดไปเช็กราคาหรือค้นรุ่นบนร้านค้าได้ทันที</p>
        </div>
        <div class="photo-wall">
          {visualCards.map((card, index) => (
            <a
              class={index === 0 ? "photo-card large" : "photo-card"}
              href={review.links.shopee}
              target="_blank"
              rel="sponsored noopener"
              data-affiliate-link
              data-affiliate-store="shopee"
              data-affiliate-context={`${review.productKey}-visual-${index + 1}`}
            >
              <img src={card.image} alt={`${card.title} ${review.shortName}`} loading="lazy" />
              <div>
                <span>{card.label}</span>
                <strong>{card.title}</strong>
                <p>{card.body}</p>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <section class="section" id="review-proof">
      <div class="container">
        <div class="section-heading split">
          <div>
            <p class="eyebrow">Review Takeaways</p>
            <h2>6 ข้อสรุปที่ควรรู้ก่อนกดซื้อ</h2>
          </div>
          <p>ตัดเฉพาะประเด็นที่ช่วยตัดสินใจจริง ไม่ซ้ำกับตาราง BTU และไม่เล่ารอบเดิมหลายครั้ง</p>
        </div>
