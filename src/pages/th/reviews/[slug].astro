const askBeforeBuy = [
  `รุ่นที่ส่งจริงคือ ${review.model} ใช่ไหม และ BTU ตรงกับที่เลือกหรือเปล่า`,
  "ราคารวมติดตั้งมาตรฐานกี่เมตร รวมท่อ ราง ขาแขวน สายไฟ และงานเจาะหรือไม่",
  "ถ้าหน้างานเกินมาตรฐาน มีค่าอะไรเพิ่ม และคิดราคายังไง",
  "นัดช่างได้เร็วสุดวันไหน ถ้าเลื่อนคิวต้องติดต่อใคร",
  "ประกันเครื่อง คอมเพรสเซอร์ อะไหล่ และค่าแรง ครอบคลุมกี่ปี",
  "ถ้าเป็นคอนโด ต้องใช้เอกสารช่างหรือแจ้งนิติก่อนหรือไม่"
];

const faqs = [
  {
    question: `${review.shortName} เหมาะกับห้องแบบไหน?`,
    answer: `ดูจาก BTU หลักคือ ${btuText} เหมาะกับ ${review.roomHint} แต่ควรให้ร้านช่วยประเมินแดด กระจก ความสูงฝ้า และจำนวนคนในห้องก่อนตัดสินใจ`
  },
  {
    question: `ควรซื้อ ${review.shortName} ทันทีไหมถ้าเจอโปรดี?`,
    answer: "ถ้าราคาโปรยังไม่รู้ค่าติดตั้งและวันช่าง ผมยังไม่อยากให้รีบกดจ่าย ควรถามราคาจบและเงื่อนไขประกันให้ครบก่อน"
  },
  {
    question: "ก่อนจ่ายควรเช็กร้านยังไง?",
    answer: "ดูชื่อรุ่นเต็ม BTU รีวิวล่าสุด รูปงานติดตั้งจริง วิธีตอบแชท เงื่อนไขประกัน และให้ร้านสรุปราคาจบเป็นข้อความไว้ในแชท"
  },
  {
    question: "ควรเทียบกับรุ่นอื่นไหม?",
    answer: "ควรเทียบอย่างน้อย 2-3 รุ่นในงบเดียวกัน โดยดูราคาเครื่องพร้อมติดตั้ง BTU ประกัน ฟีเจอร์ และความชัดเจนของร้าน"
  }
];

const compareProducts = [
  ...airConditioners.map((item) => ({ slug: item.slug, name: item.name, shortName: item.shortName })),
  ...queuedAirConditionerReviews.map((item) => ({ slug: item.productKey, name: item.name, shortName: item.shortName }))
].filter((item, index, list) => list.findIndex((candidate) => candidate.slug === item.slug) === index);

const compareHref = `/th/compare/air-conditioners/?items=${encodeURIComponent(
  [review.productKey, ...alternatives.slice(0, 3).map((item) => item.productKey)].join(",")
)}`;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: review.name,
    brand: { "@type": "Brand", name: review.brand },
    category: "Wall mounted air conditioner"
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: review.score,
    bestRating: 10,
    worstRating: 1
  },
  author: { "@type": "Organization", name: "Friendsay" },
  inLanguage: "th",
  dateModified: "2026-06-17",
  headline: articleTitle
};
---

<BaseLayout
  title={`${articleTitle} | Friendsay`}
  description={description}
  canonical={`https://friendsay.com/th/reviews/${review.reviewSlug}/`}
  noindex={!isIndexable}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="pilot-review dynamic-air-review" style={`--accent:${review.accent};`}>
    <div class="read-progress" aria-hidden="true"><i></i></div>
    <section class="air-review-hero">
      <a class="air-image-link air-hero-image-link" {...imageLinkAttrs}>
        <img src={heroImage} alt={`ภาพเปิดรีวิว ${review.name}`} loading="eager" />
      </a>
      <div class="air-review-shade" aria-hidden="true"></div>
      <div class="container air-review-hero-inner">
        <div class="air-review-title">
          <p class="eyebrow">คู่มือเลือกซื้อแบบเพื่อนช่วยดู / แอร์ 2026</p>
          <h1>{articleTitle}</h1>
          <p>
            ถ้าเพื่อนส่งรุ่นนี้มาให้ดู ผมจะบอกว่า “เอาเข้ารอบได้” โดยเฉพาะถ้าคุณอยากได้แอร์จากแบรนด์ที่ไว้ใจง่าย
            และยอมจ่ายเพื่อความสบายใจมากกว่าการไล่หาราคาถูกที่สุด แต่ก่อนจ่ายต้องเช็ก BTU ราคาจบ งานติดตั้ง
            และประกันให้ครบก่อนครับ
          </p>
          <div class="air-review-actions">
            <a class="button button-primary" href="#buying-cockpit">ดูคำตอบ 90 วินาที</a>
            <a class="button button-dark" href="#review-proof">ดูรีวิวผู้ซื้อ 6 ข้อ</a>
            <button class="button compare-hero-button" type="button" data-air-compare-slug={review.productKey}>
              + เปรียบเทียบ
            </button>
          </div>
        </div>

        <aside class="air-verdict-card">
          <div class="air-product-card-image">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={productSetImage} alt={`ภาพสินค้า ${review.name}`} loading="eager" />
            </a>
          </div>
          <span class="badge badge-coral">{product.statusLabel}</span>
          <div class="air-score-ring" role="img" aria-label={`คะแนนรวม ${product.score.toFixed(1)} จาก 10`} style={`--ring-offset:${(326.73 * (1 - product.score / 10)).toFixed(1)};`}>
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <circle class="air-ring-track" cx="60" cy="60" r="52" />
              <circle class="air-ring-fill" cx="60" cy="60" r="52" />
            </svg>
            <div><strong>{product.score.toFixed(1)}</strong><small>/10</small></div>
          </div>
          <p>{review.buyerAngle}</p>
          <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context={`${review.productKey}-hero-card`} />
        </aside>
      </div>
    </section>

    <section class="air-decision-cockpit" id="buying-cockpit" aria-label="สรุปตัดสินใจก่อนซื้อแบบเร็ว">
      <div class="wide-container air-cockpit-inner">
        <div class="air-cockpit-head">
          <p class="eyebrow">สรุปให้ก่อนเลือก</p>
          <h2>ตัดสินใจซื้อใน 90 วินาที</h2>
          <p>ถ้าไม่อยากอ่านยาว ให้เริ่มจาก 3 ช่องนี้ก่อนครับ ถ้าตอบได้ครบ ค่อยลงรายละเอียดเรื่องรีวิวจริง ขนาดห้อง และค่าใช้จ่ายต่อ</p>
        </div>

        <div class="air-cockpit-grid">
          <article class="air-cockpit-verdict">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={cleanUnitImage} alt={`ภาพตัวเครื่อง ${review.name}`} loading="lazy" />
            </a>
            <div>
              <span>{product.statusLabel}</span>
              <strong>{product.score.toFixed(1)}/10</strong>
              <p>เข้ารอบได้ ถ้าคุณให้ความสำคัญกับแบรนด์ ความมั่นใจหลังซื้อ และร้านตอบเรื่องติดตั้งชัด</p>
            </div>
          </article>

          <article class="air-cockpit-panel air-cockpit-steps">
            <span class="air-panel-label">คิดตามนี้ก่อนจ่าย</span>
            {cockpitSteps.map((step) => (
              <div>
                <b>{step.label}</b>
                <strong>{step.title}</strong>
                <p>{step.body}</p>
              </div>
            ))}
          </article>

          <article class="air-cockpit-panel air-cockpit-price">
            <span class="air-panel-label">ราคาที่ต้องคิดจริง</span>
            <strong>{product.priceLabel}</strong>
            <div>
              {costChecks.map((item) => (
                <span>{item.label}: {item.value}</span>
              ))}
            </div>
            <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context={`${review.productKey}-decision-price`} />
          </article>
        </div>

        <div class="air-buying-snapshot" aria-label="สรุปก่อนซื้อแบบเร็ว">
          {buyerSnapshotCards.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section air-proof-stage" id="images">
      <div class="wide-container">
        <section class="air-review-proof-section" id="review-proof" aria-label="ภาพและรีวิวผู้ซื้อ">
          <div class="air-review-proof-head">
            <div>
              <p class="eyebrow">ภาพและรีวิวที่ควรดู</p>
              <h2>ดูภาพสินค้า แล้วอ่านคำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ</h2>
              <p>
                ส่วนนี้ตั้งใจให้ใช้ก่อนกดซื้อจริงครับ ไม่ใช่เล่าว่า “มีรีวิวเยอะ” เฉย ๆ แต่สรุปออกมาเป็นเรื่องที่ต้องตรวจ:
                ห้องแบบไหนเหมาะ ราคาแอบบวกตรงไหน รหัสรุ่นต้องดูอะไร และร้านควรตอบอะไรให้ชัด
              </p>
            </div>
            <div class="air-review-proof-stats" aria-label="จำนวนข้อมูลที่ใช้ประกอบการรีวิว">
              <strong>{review.score.toFixed(1)}/10</strong>
              <span>{proofBadgeText}</span>
              <span>{review.sourceName}</span>
              <span>{review.model}</span>
            </div>
          </div>

          <div class="air-evidence-strip" aria-label="วิธีใช้ภาพและรีวิวในบทความนี้">
            {visualEvidenceCards.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="air-source-photo-grid" aria-label={`ภาพสินค้า ${review.name}`}>
            {realShopImages.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.title} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                  <em>{item.note}</em>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-photo-wall" aria-label="ภาพประกอบการตัดสินใจก่อนซื้อ">
            {reviewPhotoWall.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.alt} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-real-review-grid" aria-label="คำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ">
            {reviewTakeaways.map((item) => (
              <article>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={`ภาพประกอบ ${item.quote}`} loading="lazy" />
                </a>
                <div>
                  <span>{item.buyer} · {item.date} · {item.variation}</span>
                  <strong>{item.quote}</strong>
                  <p>{item.signal}</p>
                  <em>{item.takeaway}</em>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>

    <section class="section air-btu-stage" id="btu">
      <div class="wide-container">
        <div class="air-btu-selector" aria-label="ตัวช่วยเลือก BTU แบบเร็ว">
          <div>
            <p class="eyebrow">เลือก BTU แบบเร็ว</p>
            <h3>เลือก BTU ให้ตรงห้องก่อนดูราคา</h3>
            <p>
              รุ่นนี้มีตัวเลือก {btuText} จุดสำคัญคืออย่าเลือกจากราคาอย่างเดียวครับ ห้องขนาดเท่ากันแต่แดด หน้าต่าง
              และจำนวนคนต่างกัน อาจต้องใช้ BTU ไม่เท่ากัน
            </p>
          </div>
          <div class="air-btu-selector-grid">
            {btuCards.map((item) => (
              <article>
                <span>{item.btu}</span>
                <strong>{item.room}</strong>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section air-article-section">
      <div class="container article-layout">
        <article class="article-body">
          <section id="quick">
            <p class="eyebrow">คำตอบเร็ว</p>
            <h2>{review.shortName} น่าซื้อไหม</h2>
            <p>
              น่าซื้อถ้าโจทย์ของคุณตรงกับ {review.roomHint} และคุณให้ความสำคัญกับ {review.strengths.slice(0, 2).join(" กับ ")}
              มากกว่าการไล่หาราคาต่ำที่สุด รุ่นนี้ไม่ใช่ตัวที่ควรกดซื้อแบบไม่คิด แต่เป็นรุ่นที่ควรเอาเข้ารอบแล้วถามร้านให้ครบก่อนจ่าย
            </p>
          </section>

          <section id="fit">
            <div class="fit-grid">
              <article>
                <span>เหมาะกับใคร</span>
                <p>{review.bestFor}</p>
              </article>
              <article>
                <span>ไม่เหมาะกับใคร</span>
                <p>{review.notFor}</p>
              </article>
            </div>
          </section>

          <section class="score-section" id="score">
            <p class="eyebrow">Friendsay Score</p>
            <h2>คะแนนแบบ Friendsay</h2>
            <ScoreBars scores={scoreItems} />
            <p>
              คะแนนนี้มองแบบคนจะซื้อจริงครับ ดูรวมกันทั้งความน่าไว้ใจ ราคา ความชัดเรื่อง BTU งานติดตั้ง
              และความสบายใจหลังซื้อ ไม่ได้ให้คะแนนจากชื่อแบรนด์อย่างเดียว
            </p>
          </section>

          <section id="good">
            <p class="eyebrow">ข้อดี</p>
            <h2>ข้อดีที่ทำให้รุ่นนี้น่าเข้ารอบ</h2>
            <ul class="air-checklist">
              {review.strengths.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section id="watch">
            <p class="eyebrow">จุดต้องระวัง</p>
            <h2>ก่อนกดซื้อ ต้องเช็กอะไรบ้าง</h2>
            <ul class="air-checklist warning">
              {review.watchouts.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section id="cost">
            <p class="eyebrow">ต้นทุนจริง</p>
            <h2>ราคาเครื่องไม่ใช่ราคาสุดท้าย</h2>
            <p>
              แอร์เป็นของที่มี “ราคาหน้างาน” เสมอครับ ก่อนเทียบถูกแพง ให้รวมราคาเครื่อง ค่าติดตั้ง ท่อ ราง ขาแขวน
              สายไฟ เบรกเกอร์ งานเจาะ และค่าเดินทางของช่างก่อน ไม่งั้นรุ่นที่ดูถูกอาจจบแพงกว่ารุ่นที่ร้านตอบชัดตั้งแต่แรก
            </p>
            <div class="mini-check-grid">
              {costChecks.map((item) => <span>{item.label}: {item.value}</span>)}
            </div>
          </section>

          <section id="install">
            <p class="eyebrow">ติดตั้ง</p>
            <h2>ติดตั้งดี ชีวิตง่ายขึ้นเยอะ</h2>
            <figure class="air-article-image">
              <a class="air-image-link" {...imageLinkAttrs}>
                <img src={installPlanImage} alt={`ภาพประกอบงานติดตั้ง ${review.shortName}`} loading="lazy" />
              </a>
              <figcaption>ก่อนให้ช่างเจาะผนัง ควรดูทิศทางลม จุดวางเตียง ระยะท่อ และตำแหน่งคอยล์ร้อนให้จบตั้งแต่แรก</figcaption>
            </figure>
            <ul class="air-checklist">
              {product.installNotes.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section id="warranty">
            <p class="eyebrow">ประกัน</p>
            <h2>ประกันต้องรู้ว่าเคลมกับใคร</h2>
            <p>
              แบรนด์ใหญ่ช่วยให้สบายใจขึ้น แต่ยังต้องถามให้ชัดว่าร้านออกเอกสารอย่างไร เคลมผ่านร้านหรือศูนย์
              คอมเพรสเซอร์กับอะไหล่ครอบคลุมกี่ปี และค่าแรงหลังปีแรกคิดอย่างไร
            </p>
            <ul class="air-checklist">
              {product.warrantyNotes.map((item) => <li>{item}</li>)}
            </ul>
          </section>

          <section id="compare">
            <p class="eyebrow">เทียบรุ่นอื่น</p>
            <h2>อย่าเพิ่งดูรุ่นนี้เดี่ยว ๆ</h2>
            <p>
              ก่อนซื้อจริง ผมอยากให้เทียบ {review.shortName} กับรุ่นใกล้ราคาอย่างน้อย 2-3 ตัว โดยดู BTU ราคาแบบรวมติดตั้ง
              ประกัน ฟีเจอร์ และความชัดเจนของร้านพร้อมกัน จะเห็นทันทีว่าคุ้มเพราะอะไร หรือแพงเพราะอะไร
            </p>
            <div class="air-alternative-grid">
              {alternativeCards.map((item, index) => (
                <article class={index === 0 ? "is-current" : ""}>
                  <span>{item.role}</span>
                  <strong>{item.name}</strong>
                  <p>{item.note}</p>
                </article>
              ))}
            </div>

            <div class="air-mid-compare-cta">
              <div>
                <span>ถ้ายังลังเล</span>
                <strong>เปิดหน้าเทียบแอร์ แล้ววางรุ่นข้างกัน</strong>
                <p>เหมาะกับตอนเลือกไม่ถูกระหว่างหลายแบรนด์ หรืออยากดูคะแนน ราคา และจุดต้องถามร้านแบบเร็ว ๆ</p>
              </div>
              <div>
                <a class="button button-primary" href={compareHref}>เปิดหน้าเปรียบเทียบ</a>
                <button class="button" type="button" data-air-compare-slug={review.productKey}>เลือกรุ่นนี้ไว้เทียบ</button>
              </div>
            </div>
          </section>

          <section class="air-questions-section" id="questions">
            <p class="eyebrow">ก่อนกดซื้อ</p>
            <h2>ส่งคำถาม 6 ข้อนี้ให้ร้านก่อนจ่าย</h2>
            <ol class="air-question-list">
              {askBeforeBuy.map((item) => <li>{item}</li>)}
            </ol>
          </section>

          <section id="buy">
            <p class="eyebrow">เช็กราคา</p>
