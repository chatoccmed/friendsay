---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PriceButtons from "../../../components/PriceButtons.astro";
import ScoreBars from "../../../components/ScoreBars.astro";
import AirCompareTray from "../../../components/AirCompareTray.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";
import { airConditioners } from "../../../data/airConditioners";
import { queuedAirConditionerReviews, type QueuedAirConditionerReview } from "../../../data/airConditionerReviewQueue";
import { airConditionerShopeeProofByKey } from "../../../data/airConditionerShopeeProof";

export function getStaticPaths() {
  return queuedAirConditionerReviews.map((review) => ({
    params: { slug: review.reviewSlug },
    props: { review }
  }));
}

type Props = {
  review: QueuedAirConditionerReview;
};

const { review } = Astro.props;

const firstBtu = review.btuOptions[0] ?? "9,000 BTU";
const btuText = review.btuOptions.join(" / ");
const proofCountText = review.proofCount.toLocaleString("th-TH");
const hasReviewProof = review.proofCount > 0;
// noindex จนกว่ารุ่นนั้นจะมีหลักฐาน Shopee ระดับ detail_verified — กัน scaled content abuse
const shopeeProof = airConditionerShopeeProofByKey[review.productKey];
const isIndexable = shopeeProof?.status === "detail_verified";
// ถ้ารุ่นนี้มี affiliate short link ที่ mint ไว้แล้วใน proof ledger ให้ปุ่ม Shopee ใช้ลิงก์ tracked แทนลิงก์ค้นหา (ไม่งั้นคลิกที่ได้จะไม่นับค่าคอม)
const trackedLinks = shopeeProof?.affiliateUrl
  ? { ...review.links, shopee: shopeeProof.affiliateUrl }
  : review.links;
const proofBadgeText = hasReviewProof ? `${proofCountText}+ ข้อมูลให้ตรวจ` : "เช็กสเปก ราคา และร้านก่อนซื้อ";
