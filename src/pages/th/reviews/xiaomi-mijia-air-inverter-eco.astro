    answer: "ให้ดูรีวิวที่มีภาพและพูดถึงความเย็น เสียง การเชื่อมต่อแอป งานติดตั้ง ร้านตอบแชท และการแก้ปัญหาหลังสั่งซื้อ เพราะจุดเหล่านี้สะท้อนประสบการณ์จริงมากกว่าดาวรวม"
  }
];

const scoreItems = [
  { label: "ความนิยม", value: 9.4 },
  { label: "ความมั่นใจผู้ซื้อ", value: 8.6 },
  { label: "ความคุ้มค่า", value: 8.8 },
  { label: "เลือก BTU ง่าย", value: 8.5 },
  { label: "ประหยัดไฟ/สบาย", value: 8.8 },
  { label: "ความเสี่ยงติดตั้ง", value: 7.2 },
  { label: "ประกัน/ความปลอดภัย", value: 8.0 },
  { label: "ความเสี่ยงคำบ่น", value: 7.5 }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: "Xiaomi Mijia Air Inverter Eco",
    brand: { "@type": "Brand", name: "Xiaomi" },
    category: "Wall mounted air conditioner"
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: "8.5",
    bestRating: "10",
    worstRating: "1"
  },
  author: { "@type": "Organization", name: "Friendsay" },
  inLanguage: "th",
  dateModified: "2026-06-16",
  headline: "Xiaomi Mijia Air Inverter Eco แอร์ Smart Home ราคาดี คุมผ่านแอป เหมาะกับสาย Xiaomi"
};
---

<BaseLayout
  title="Xiaomi Mijia Air Inverter Eco แอร์ Smart Home ราคาดี คุมผ่านแอป | Friendsay"
  description="Xiaomi Mijia Air Inverter Eco แอร์ติดผนังสาย Smart Home ราคาเข้าถึงง่าย เหมาะกับคนใช้ Xiaomi Home ดู BTU ค่าติดตั้ง ประกัน รีวิวผู้ซื้อ และปุ่มเช็กราคา"
  canonical="https://friendsay.com/th/reviews/xiaomi-mijia-air-inverter-eco/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="pilot-review">
    <section class="air-review-hero">
      <a class="air-image-link air-hero-image-link" {...imageLinkAttrs}>
        <img src={heroImage} alt="ภาพห้องนอนสว่างกับแอร์ Xiaomi Mijia Air Inverter Eco สำหรับเปิดรีวิว" loading="eager" />
      </a>
      <div class="air-review-shade" aria-hidden="true"></div>
      <div class="container air-review-hero-inner">
        <div class="air-review-title">
          <p class="eyebrow">คู่มือเลือกซื้อแบบเพื่อนช่วยดู / Shopee 2026</p>
          <h1>Xiaomi Mijia Air Inverter Eco แอร์ Smart Home ราคาดี คุมผ่านแอป เหมาะกับสาย Xiaomi</h1>
          <p>
            รุ่นนี้น่าเอาเข้ารอบถ้าคุณอยากได้แอร์ราคาเปิดดี มีรีวิวเยอะ และอยากใช้ร่วมกับ Xiaomi Home
            แต่แอร์ไม่เหมือน gadget ชิ้นเล็กครับ ก่อนกดซื้อให้ถามให้ชัดว่าราคารวมติดตั้งไหม BTU ตรงห้องหรือเปล่า และประกันดูแลผ่านช่องทางไหน
          </p>
          <div class="air-review-actions">
            <a class="button button-primary" href="#buying-cockpit">ดูคำตอบ 90 วินาที</a>
            <a class="button button-dark" href="#review-proof">ดูรีวิวผู้ซื้อจริง</a>
            <button class="button compare-hero-button" type="button" data-air-compare-slug={product.slug}>
              + เปรียบเทียบ
            </button>
          </div>
        </div>

        <aside class="air-verdict-card">
          <div class="air-product-card-image">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={productSetImage} alt="ภาพ Xiaomi Mijia Air Inverter Eco พร้อมคอยล์ร้อน รีโมต และอุปกรณ์ติดตั้ง" loading="eager" />
            </a>
          </div>
          <span class="badge badge-coral">{product.statusLabel}</span>
          <strong>{product.score.toFixed(1)}/10</strong>
          <p>น่าเก็บไว้เทียบเป็นรุ่นต้น ๆ ถ้าร้านตอบเรื่อง BTU ติดตั้ง และประกันได้ชัด</p>
          <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context="xiaomi-hero-card" />
        </aside>
      </div>
    </section>

    <section class="air-decision-cockpit" id="buying-cockpit" aria-label="สรุปตัดสินใจซื้อแบบเร็ว">
      <div class="wide-container air-cockpit-inner">
        <div class="air-cockpit-head">
          <p class="eyebrow">สรุปให้ก่อนเลือก</p>
          <h2>ตัดสินใจซื้อใน 90 วินาที</h2>
          <p>ถ้าไม่อยากอ่านยาว ให้เริ่มจาก 3 ช่องนี้ก่อนครับ ถ้าตอบได้ครบ ค่อยลงรายละเอียดเรื่องรีวิวจริง ขนาดห้อง และค่าใช้จ่ายต่อ</p>
        </div>

        <div class="air-cockpit-grid">
          <article class="air-cockpit-verdict">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={cleanUnitImage} alt="ภาพตัวเครื่อง Xiaomi Mijia Air Inverter Eco แบบคลีนสำหรับดูทรงเครื่อง" loading="lazy" />
            </a>
            <div>
              <span>{product.statusLabel}</span>
              <strong>{product.score.toFixed(1)}/10</strong>
              <p>เอาเข้ารอบ shortlist ได้ ถ้าคุณอยากได้แอร์ที่คุมผ่านแอปได้และร้านตอบเรื่องติดตั้งชัด</p>
            </div>
          </article>

          <article class="air-cockpit-panel air-cockpit-steps">
            <span class="air-panel-label">คิดตามนี้ก่อนจ่าย</span>
            {cockpitSteps.map((step) => (
              <div>
                <b>{step.label}</b>
                <strong>{step.title}</strong>
                <p>{step.body}</p>
              </div>
            ))}
          </article>

          <article class="air-cockpit-panel air-cockpit-price">
            <span class="air-panel-label">ราคาที่ต้องคิดจริง</span>
            <strong>{product.priceLabel}</strong>
            <div>
              {costChecks.map((item) => (
                <span>{item.label}: {item.value}</span>
              ))}
            </div>
            <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context="xiaomi-decision-price" />
          </article>
        </div>

        <div class="air-buying-snapshot" aria-label="สรุปก่อนซื้อแบบเร็ว">
          {buyerSnapshotCards.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section air-proof-stage" id="images">
      <div class="wide-container">
        <section class="air-review-proof-section" id="review-proof" aria-label="ภาพและรีวิวผู้ซื้อจริง">
          <div class="air-review-proof-head">
            <div>
              <p class="eyebrow">ภาพและรีวิวที่ควรดู</p>
              <h2>ดูภาพสินค้า แล้วอ่านคำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ</h2>
              <p>
                เวลาเลือกแอร์ ผมจะเริ่มจากภาพสินค้าแบบคลีนก่อน แล้วสรุปรีวิวผู้ซื้อให้กลายเป็นข้อแนะนำที่ใช้ได้จริง
                เพราะคนอ่านควรรู้ทันทีว่าต้องเช็กอะไร ไม่ใช่แค่รู้ว่ารุ่นนี้มีรีวิวเยอะ
              </p>
            </div>
            <div class="air-review-proof-stats" aria-label="ตัวเลขรีวิวจาก Shopee">
              <strong>{product.rating.toFixed(1)}/5</strong>
              <span>{product.ratingsCount.toLocaleString("th-TH")}+ คะแนน</span>
              <span>{product.commentsCount.toLocaleString("th-TH")}+ คอมเมนต์</span>
              <span>{product.mediaCount.toLocaleString("th-TH")}+ รีวิวมีภาพ/วิดีโอ</span>
            </div>
          </div>

          <div class="air-evidence-strip" aria-label="วิธีใช้ภาพและรีวิวในบทความนี้">
            {visualEvidenceCards.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="air-source-photo-grid" aria-label="ภาพสินค้า Xiaomi Mijia Air Inverter Eco">
            {realShopImages.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.title} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                  <em>{item.note}</em>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-photo-wall" aria-label="ภาพประกอบการตัดสินใจก่อนซื้อ">
            {reviewPhotoWall.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.alt} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-real-review-grid" aria-label="คำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ">
            {realReviewSnapshots.map((item) => (
              <article>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={`ภาพประกอบรีวิวจาก ${item.buyer}`} loading="lazy" />
                </a>
                <div>
                  <span>{item.buyer} • {item.date} • {item.variation}</span>
                  <strong>{item.quote}</strong>
                  <p>{item.signal}</p>
                  <em>{item.takeaway}</em>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>

    <section class="section air-btu-stage" id="btu">
      <div class="wide-container">
        <div class="air-btu-selector" aria-label="ตัวช่วยเลือก BTU แบบเร็ว">
          <div>
            <p class="eyebrow">เลือก BTU แบบเร็ว</p>
            <h3>เลือก BTU ให้ตรงห้องก่อนดูราคา</h3>
            <p>รุ่นนี้มี 9,000 / 12,000 / 18,000 BTU จุดดีคือครอบคลุมห้องยอดนิยม แต่ถ้าห้องใหญ่หรือแดดแรงมาก ต้องถามร้านก่อน อย่าเดาจากราคา</p>
          </div>
          <div class="air-btu-selector-grid">
            {btuGuide.map((item) => (
              <article>
                <span>{item.btu}</span>
                <strong>{item.room}</strong>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container article-layout">
        <article class="article-body">
          <div class="air-quick-grid air-fit-grid">
            <div class="soft-card">
              <h2>เหมาะกับใคร</h2>
              <p>{product.bestFor}</p>
            </div>
            <div class="soft-card">
              <h2>ไม่เหมาะกับใคร</h2>
              <p>{product.notFor}</p>
            </div>
          </div>

          <h2 id="score">คะแนนแบบ Friendsay</h2>
          <ScoreBars scores={scoreItems} />
          <p>
            คะแนน {product.score.toFixed(1)}/10 ของ Xiaomi Mijia Air Inverter Eco มาจากภาพรวมของรีวิว ราคาเปิด ฟีเจอร์ Xiaomi Home
            และความเสี่ยงหลังซื้อ จุดที่ทำคะแนนได้ดีคือความคุ้มค่า รีวิวเยอะ และความเป็น smart home ส่วนจุดที่ต้องถามให้ชัดคือราคาติดตั้ง บริการหลังซื้อ และศูนย์บริการในพื้นที่ครับ
          </p>

          <h2 id="good">ข้อดีที่ควรรู้</h2>
          <p>
            ถ้าดูแบบคนกำลังจะซื้อจริง รุ่นนี้มีข้อดีที่จับต้องได้ ไม่ใช่แค่คำโปรโมตบนหน้าร้าน จุดที่ควรเก็บไว้เทียบมีตามนี้ครับ
          </p>
          <div class="verdict-grid" aria-label="ข้อดีของ Xiaomi Mijia Air Inverter Eco">
            {product.pros.map((item, index) => (
              <article>
                <span>{`ข้อ ${index + 1}`}</span>
                <strong>{item}</strong>
              </article>
            ))}
          </div>

          <h2 id="watch">จุดต้องระวังก่อนกดซื้อ</h2>
          <p>
            จุดระวังของรุ่นนี้ไม่ได้แปลว่าไม่ดี แต่เป็นจุดที่ต้องถามให้ชัดก่อนจ่าย เพราะแอร์เป็นสินค้าที่มีงานหน้างานตามมา
            ซื้อผิด BTU หรือเข้าใจผิดเรื่องติดตั้ง จะเสียเวลาแก้มากกว่าของใช้ชิ้นเล็กครับ
          </p>
          <div class="air-watch-list" aria-label="จุดต้องระวังก่อนซื้อ Xiaomi Mijia Air Inverter Eco">
            {product.watch.map((item, index) => (
              <article>
                <span>{`เช็ก ${index + 1}`}</span>
                <strong>{item}</strong>
              </article>
            ))}
          </div>
          <p>
            ถ้าอยู่คอนโด ให้ถามนิติก่อนเรื่องเจาะผนัง จุดวางคอยล์ร้อน และท่อน้ำทิ้ง ส่วนถ้าต้องใช้ด่วน ให้ถามวันติดตั้งก่อนจ่าย
            เพราะแอร์ที่ดูคุ้มมากในหน้าร้าน อาจไม่ตอบโจทย์ถ้าคิวช่างไม่ทันเวลาที่ต้องใช้จริง
          </p>

          <section class="air-cost-section" id="cost">
            <p class="eyebrow">เช็กเงินที่ต้องจ่ายจริง</p>
            <h2>ราคาเครื่องไม่ใช่ราคาสุดท้ายเสมอไป</h2>
            <p>
              จุดนี้สำคัญมากสำหรับแอร์ทุกยี่ห้อครับ ราคาเครื่องเป็นแค่จุดเริ่มต้น ก่อนจ่ายเงินจริงให้ถามให้ครบว่าราคารวมอะไรบ้าง
              โดยเฉพาะคนซื้อออนไลน์ที่ไม่ได้มีช่างประจำ
            </p>
            <figure class="air-wide-figure">
              <a class="air-image-link" {...imageLinkAttrs}>
                <img src={costPlanImage} alt="ภาพประกอบการเช็กต้นทุนรวมและอุปกรณ์ติดตั้ง Xiaomi Mijia Air Inverter Eco" loading="lazy" />
              </a>
              <figcaption>
                ดูราคาเครื่องแล้วอย่าเพิ่งจบ ต้องรวมท่อ ราง ขาแขวน สายไฟ จุดเจาะ วันช่าง และเงื่อนไขประกันด้วย
              </figcaption>
            </figure>
            <div class="air-cost-grid">
              {costChecks.map((item) => (
                <article>
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                  <p>{item.note}</p>
                </article>
              ))}
            </div>
          </section>

          <h2 id="install">เรื่องติดตั้งคือหัวใจของรีวิวแอร์</h2>
          <p>
            แอร์ที่ดีไม่ได้จบตอนกล่องมาถึงบ้าน แต่จบตอนติดตั้งแล้วเย็นจริง น้ำไม่หยด เสียงไม่กวน และใช้งานได้ยาว ๆ
            เพราะฉะนั้นส่วนติดตั้งควรถามละเอียดกว่าปกติ โดยเฉพาะถ้าซื้อผ่าน Shopee แล้วใช้บริการช่างเสริม
          </p>
          <figure class="air-wide-figure">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={installPlanImage} alt="ภาพวางแผนตำแหน่งติดตั้งและอุปกรณ์สำหรับ Xiaomi Mijia Air Inverter Eco" loading="lazy" />
            </a>
            <figcaption>
              ก่อนให้ช่างเจาะผนัง ควรดูทิศทางลม จุดวางเตียง ระยะท่อ และตำแหน่งคอยล์ร้อนให้จบตั้งแต่แรก
            </figcaption>
          </figure>
          <ul class="air-checklist">
            {product.installNotes.map((item) => <li>{item}</li>)}
          </ul>

          <h2 id="warranty">ประกันและความสบายใจหลังซื้อ</h2>
          <p>
            Xiaomi เป็นแบรนด์ที่คนไทยคุ้นกับอุปกรณ์ smart home อยู่แล้ว แต่แอร์เป็นสินค้าที่ต้องมีบริการหลังซื้อจริง
            จุดที่ควรถามจึงไม่ใช่แค่ว่าประกันกี่ปี แต่ต้องถามว่าเคลมผ่านช่องทางไหน ศูนย์บริการในพื้นที่ดูแลอย่างไร และต้องใช้เอกสารอะไรตอนแจ้งเคลม
          </p>
          <ul class="air-checklist">
            {product.warrantyNotes.map((item) => <li>{item}</li>)}
          </ul>

          <h2 id="compare">ควรเทียบกับรุ่นไหน</h2>
          <p>
            ถ้าสนใจ Xiaomi รุ่นนี้ อย่าดูเดี่ยว ๆ ครับ ให้เปิดเทียบกับรุ่นที่มีจุดขายคนละแบบ จะเห็นทันทีว่าคุณให้ความสำคัญกับอะไร:
            แอปและ ecosystem, ราคา, รีวิว, ประกัน หรือความง่ายของงานติดตั้ง
          </p>
          <div class="air-alternative-grid">
            {alternativeCards.map((item) => (
              <article class={item.name.startsWith("Xiaomi") ? "is-current" : ""}>
                <span>{item.role}</span>
                <strong>{item.name}</strong>
                <p>{item.note}</p>
              </article>
            ))}
          </div>

          <div class="air-mid-compare-cta">
            <div>
