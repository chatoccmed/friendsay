---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import { airConditioners } from "../../../../data/airConditioners";
import { queuedAirConditionerReviews } from "../../../../data/airConditionerReviewQueue";
import {
  airConditionerShopeeProofs,
  airConditionerShopeeProofSummary,
  type AirConditionerShopeeProof
} from "../../../../data/airConditionerShopeeProof";

const formatNumber = (value: number | undefined) =>
  value ? value.toLocaleString("th-TH") : "";

const shopeeSearchLink = (query: string) =>
  `https://shopee.co.th/search?keyword=${encodeURIComponent(query)}`;

const queuedByKey = new Map(
  queuedAirConditionerReviews.map((review) => [review.productKey, review])
);

const readyByKey = new Map(
  airConditioners.map((product) => [
    product.slug,
    {
      name: product.name,
      shortName: product.shortName,
      btuOptions: product.btuOptions,
      priceLabel: product.priceLabel,
      sourceName: "Shopee",
      proofCount: product.ratingsCount,
      score: product.score,
      image: product.image.url,
      links: product.links,
      strengths: product.pros,
      watchouts: product.watch
    }
  ])
);

const statusCopy: Record<
  AirConditionerShopeeProof["status"],
  { label: string; shortLabel: string; className: string }
> = {
  detail_verified: {
    label: "ยืนยันรีวิว Shopee แล้ว",
    shortLabel: "Shopee พร้อม",
    className: "is-verified"
  },
  detail_low_signal: {
    label: "พบหน้าสินค้า แต่รีวิวยังน้อย รอลิสติ้งที่ชัดกว่า",
    shortLabel: "รีวิวยังน้อย",
    className: "is-candidate"
  },
  search_candidate_only: {
    label: "พบหน้าสินค้า รอตรวจรีวิวล่าสุด",
    shortLabel: "พบสินค้า",
    className: "is-candidate"
  },
  needs_shopee_capture: {
    label: "พร้อมอ่านรีวิว รอลิงก์ซื้อที่ตรงรุ่น",
    shortLabel: "รอลิงก์ซื้อ",
    className: "is-pending"
  }
};

const modelRows = airConditionerShopeeProofs
  .map((proof) => {
    const queued = queuedByKey.get(proof.productKey);
    const ready = readyByKey.get(proof.productKey);
    const sourceName = proof.status === "detail_verified" ? "Shopee" : queued?.sourceName ?? ready?.sourceName ?? "Friendsay";
    const proofCount = proof.status === "detail_verified" ? proof.ratingsCount ?? 0 : queued?.proofCount ?? ready?.proofCount ?? 0;
    const score = queued?.score ?? ready?.score ?? 8;
    const priceLabel = queued?.priceLabel ?? ready?.priceLabel ?? "เช็กราคาหน้าร้านก่อนซื้อ";
    const image = queued?.heroImage ?? ready?.image ?? "/images/air-conditioners/wall-ac-condo-hero.jpg";
    const btuOptions = queued?.btuOptions ?? ready?.btuOptions ?? ["เช็ก BTU จากหน้าร้าน"];
    const links = queued?.links ?? ready?.links ?? {
      shopee: shopeeSearchLink(proof.searchQuery),
      lazada: `https://www.lazada.co.th/catalog/?q=${encodeURIComponent(proof.searchQuery)}`,
      tiktok: `https://www.tiktok.com/search?q=${encodeURIComponent(`${proof.searchQuery} TikTok Shop`)}`
    };
    const shopeeHref = proof.affiliateUrl ?? proof.productUrl ?? links.shopee;
    const name = queued?.name ?? ready?.name ?? `${proof.brand} ${proof.modelOrSeries}`;
    const shortName = queued?.shortName ?? ready?.shortName ?? proof.modelOrSeries;
    const strengths = queued?.strengths ?? ready?.strengths ?? [
      "มีชื่อรุ่นชัดเจน",
      "เหมาะสำหรับเทียบราคาและ BTU",
      "ใช้เป็นตัวเลือกในคิวรีวิวแอร์ 2026"
    ];
    const watchouts = queued?.watchouts ?? ready?.watchouts ?? [
      "เช็กรุ่นย่อยให้ตรงก่อนซื้อ",
      "ถามค่าติดตั้งและอุปกรณ์เพิ่ม",
      "อ่านเงื่อนไขประกันให้ชัด"
    ];

    const proofLine =
      proof.status === "detail_verified"
        ? `มีข้อมูลรีวิว Shopee ${formatNumber(proof.ratingsCount)}+ รายการ และคอมเมนต์ ${formatNumber(proof.commentsCount)}+ รายการให้ตามอ่าน`
        : proofCount > 0
          ? `มีข้อมูลรีวิวจาก ${sourceName} ${formatNumber(proofCount)} รายการ ช่วยใช้คัดกรองก่อนเทียบราคาจริง`
          : "ใช้เป็นเช็กลิสต์รุ่น/BTU/ราคา แล้วรอจับคู่ลิงก์ซื้อที่ตรงรุ่น";

    return {
      ...proof,
      name,
      shortName,
      sourceName,
      proofCount,
      proofLine,
      score,
      scorePercent: Math.round(score * 10),
      priceLabel,
      image,
      btuText: btuOptions.join(" / "),
      links: { ...links, shopee: shopeeHref },
      statusMeta: statusCopy[proof.status],
      strengths: strengths.slice(0, 3),
      watchouts: watchouts.slice(0, 3),
      reviewHref: `/th/reviews/${proof.reviewSlug}/`
    };
  })
  .sort((a, b) => a.queueRank - b.queueRank);

const verifiedRows = modelRows.filter((row) => row.status === "detail_verified");
const candidateRows = modelRows.filter((row) => row.status === "search_candidate_only");
const pendingRows = modelRows.filter((row) => row.status === "needs_shopee_capture");
const topRows = modelRows.slice(0, 6);

const brandGroups = Array.from(
  modelRows.reduce((map, row) => {
    map.set(row.brand, (map.get(row.brand) ?? 0) + 1);
    return map;
  }, new Map<string, number>())
).sort((a, b) => b[1] - a[1]);

const brandFilterOptions = brandGroups.map(([brand]) => brand);
const btuFilterOptions = Array.from(
  new Set(modelRows.flatMap((row) => row.btuText.match(/\d{1,2},?\d{3}/g) ?? []))
).sort((a, b) => Number(a.replace(",", "")) - Number(b.replace(",", "")));

const pageTitle = "คลังรีวิวแอร์ติดผนัง 28 รุ่นในไทย 2026 | Friendsay";
const pageDescription =
  "หน้ารวมรีวิวแอร์ติดผนัง 28 รุ่น พร้อมข้อมูลรีวิว Shopee ที่ยืนยันแล้ว คิวรุ่นที่รอลิงก์ซื้อ และทางลัดอ่านรีวิวแต่ละรุ่นแบบ Friendsay";
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://friendsay.com/th/reviews/air-conditioners/"
>
  <section class="air-library-hero">
    <div class="air-library-hero__media" aria-hidden="true">
      <img src="/images/air-conditioners/wall-ac-condo-hero.jpg" alt="" />
    </div>
    <div class="air-library-hero__overlay"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Friendsay Air Review Library 2026</span>
        <h1>คลังรีวิวแอร์ติดผนัง 28 รุ่น ที่คนซื้อควรเปิดดูก่อนจ่าย</h1>
        <p>
          รวมรุ่นที่เรากำลังไล่ทำรีวิวแบบละเอียด ทั้งรุ่นที่มีข้อมูลรีวิว Shopee แล้ว
          รุ่นที่มีรีวิวจากร้านใหญ่ และรุ่นที่รอจับคู่ลิงก์ซื้อให้ตรงที่สุด เพื่อให้คุณเทียบได้เร็วขึ้นว่า
          รุ่นไหนน่าอ่านต่อ รุ่นไหนเหมาะกับห้องคุณ และต้องถามร้านเรื่องอะไรบ้างก่อนกดซื้อ
        </p>
        <div class="hero-actions">
          <a href="#all-models" class="button-main">ดูครบ 28 รุ่น</a>
          <a href="#verified" class="button-ghost">ดูรุ่นที่มีข้อมูล Shopee</a>
        </div>
      </div>
      <div class="hero-board" aria-label="สรุปสถานะคิวรีวิวแอร์">
        <div>
          <span>{modelRows.length}</span>
          <strong>รุ่นในคิว</strong>
        </div>
        <div>
          <span>{airConditionerShopeeProofSummary.detailVerified}</span>
          <strong>ยืนยันจาก Shopee</strong>
        </div>
        <div>
          <span>{candidateRows.length + pendingRows.length}</span>
          <strong>รอจับคู่ลิงก์ซื้อ</strong>
        </div>
      </div>
    </div>
  </section>

  <section class="library-strip" aria-label="ภาพรวมคิวรีวิว">
    <div class="container strip-grid">
      <a href="#verified">
        <span>01</span>
        <strong>รุ่นที่มีรีวิว Shopee แล้ว</strong>
        <small>{verifiedRows.length} รุ่น พร้อมตัวเลขรีวิวให้ตรวจ</small>
      </a>
      <a href="#priority">
        <span>02</span>
        <strong>ตัวที่ควรอ่านก่อน</strong>
        <small>เรียงตามคิวและความน่าสนใจของผู้ซื้อ</small>
      </a>
      <a href="#all-models">
        <span>03</span>
        <strong>ตารางครบ 28 รุ่น</strong>
        <small>เปิดรีวิวและเช็กราคาจากแต่ละช่องทาง</small>
      </a>
      <a href="#brand-map">
        <span>04</span>
        <strong>ดูตามแบรนด์</strong>
        <small>รู้ทันทีว่าในคลังมีแบรนด์ไหนกี่รุ่น</small>
      </a>
    </div>
  </section>

  <section class="library-section" id="verified">
    <div class="container section-heading">
      <span class="eyebrow">Shopee Review Ready</span>
      <h2>รุ่นที่มีข้อมูลรีวิว Shopee ให้ใช้ตัดสินใจก่อน</h2>
      <p>
        กลุ่มนี้มีตัวเลขรีวิวและคอมเมนต์จากหน้าสินค้า Shopee แล้ว จึงเหมาะสำหรับเริ่มอ่านก่อน
        เพราะมีเสียงผู้ซื้อจริงให้ตามดูเรื่องความเย็น เสียง การติดตั้ง และความคุ้มค่า
      </p>
    </div>

    <div class="container verified-grid">
      {verifiedRows.map((row) => (
        <article class="verified-card">
          <a href={row.links.shopee} target="_blank" rel="sponsored noopener" class="verified-card__image">
            <img src={row.image} alt={`ภาพประกอบ ${row.name}`} loading="lazy" />
          </a>
          <div class="verified-card__body">
            <div class="card-topline">
              <span>#{row.queueRank.toString().padStart(2, "0")}</span>
              <strong>{row.statusMeta.shortLabel}</strong>
            </div>
            <h3>{row.name}</h3>
            <p>{row.proofLine}</p>
            <div class="mini-stats">
              <span>{row.visibleRating?.toFixed(1) ?? "-"} คะแนน</span>
              <span>{formatNumber(row.ratingsCount)} รีวิว</span>
              <span>{formatNumber(row.commentsCount)} คอมเมนต์</span>
            </div>
            <div class="card-actions">
              <a href={row.reviewHref}>อ่านรีวิวรุ่นนี้</a>
              <a href={row.links.shopee} target="_blank" rel="sponsored noopener">Shopee</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="library-section priority-section" id="priority">
    <div class="container section-heading">
      <span class="eyebrow">Start Here</span>
      <h2>6 รุ่นแรกที่ควรเปิดอ่านก่อน ถ้ากำลังเลือกแอร์ใหม่</h2>
      <p>
        ถ้ายังไม่รู้จะเริ่มจากตัวไหน ให้เริ่มจากกลุ่มนี้ก่อน เพราะมีทั้งรุ่นรีวิวเยอะ รุ่นราคาเริ่มน่าสนใจ
        และรุ่นแบรนด์ใหญ่ที่คนมักเอาไปเทียบกันจริงตอนจะซื้อ
      </p>
    </div>

    <div class="container priority-grid">
      {topRows.map((row) => (
        <article class="priority-card">
          <a href={row.links.shopee} target="_blank" rel="sponsored noopener" class="priority-image">
            <img src={row.image} alt={`ภาพประกอบ ${row.name}`} loading="lazy" />
          </a>
          <div class="priority-copy">
            <div class={`status-pill ${row.statusMeta.className}`}>{row.statusMeta.label}</div>
            <h3>{row.shortName}</h3>
            <p>{row.proofLine}</p>
            <div class="score-line">
              <span>Friendsay {row.score.toFixed(1)}/10</span>
              <i style={`--score:${row.scorePercent}%`}></i>
            </div>
            <ul>
              {row.strengths.map((item) => <li>{item}</li>)}
            </ul>
            <div class="card-actions">
              <a href={row.reviewHref}>อ่านรีวิวรุ่นนี้</a>
              <a href={row.links.shopee} target="_blank" rel="sponsored noopener">เช็กราคา</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="library-section all-models-section" id="all-models">
    <div class="container section-heading">
      <span class="eyebrow">All 28 Models</span>
      <h2>ตารางรีวิวแอร์ครบ 28 รุ่น</h2>
      <p>
        ทุกแถวเปิดอ่านรีวิวได้ทันที และมีทางลัดไป Shopee, Lazada, TikTok เพื่อเช็กราคาล่าสุด
        รุ่นที่ยังไม่ได้จับคู่ลิงก์สินค้าแบบตรงรุ่นจะพาไปหน้าค้นหาด้วยชื่อรุ่นก่อน
      </p>
    </div>

    <div class="container model-tools" data-air-filter>
      <div class="model-tools__copy">
        <span>หาเร็ว</span>
        <strong>เลือกแบรนด์หรือ BTU แล้วกดอ่านรีวิวรายรุ่นได้เลย</strong>
      </div>
      <div class="filter-controls" aria-label="ตัวกรองรีวิวแอร์">
        <label>
          <span>ค้นหารุ่น</span>
          <input type="search" data-filter-search placeholder="เช่น Daikin, 9,000, MSY" autocomplete="off" />
        </label>
        <label>
          <span>แบรนด์</span>
          <select data-filter-brand>
            <option value="">ทุกแบรนด์</option>
            {brandFilterOptions.map((brand) => <option value={brand}>{brand}</option>)}
          </select>
        </label>
        <label>
          <span>BTU</span>
          <select data-filter-btu>
            <option value="">ทุกขนาด</option>
            {btuFilterOptions.map((btu) => <option value={btu}>{btu} BTU</option>)}
          </select>
        </label>
        <label>
          <span>สถานะ</span>
          <select data-filter-status>
            <option value="">ทุกสถานะ</option>
            <option value="detail_verified">มีข้อมูล Shopee แล้ว</option>
            <option value="search_candidate_only">พบสินค้ารอเช็กลิงก์</option>
            <option value="needs_shopee_capture">รอจับคู่ลิงก์ซื้อ</option>
          </select>
        </label>
        <button type="button" data-filter-reset>ล้างตัวกรอง</button>
      </div>
      <p class="model-tools__result">
        ตอนนี้แสดง <strong data-visible-count>{modelRows.length}</strong> จาก {modelRows.length} รุ่น
      </p>
    </div>

    <div class="container model-list">
      {modelRows.map((row) => (
        <article
          class="model-row"
          data-model-row
          data-brand={row.brand}
          data-btu={row.btuText}
          data-status={row.status}
          data-search={`${row.name} ${row.shortName} ${row.brand} ${row.modelOrSeries} ${row.btuText}`}
        >
          <a href={row.links.shopee} target="_blank" rel="sponsored noopener" class="model-thumb">
            <img src={row.image} alt={`ภาพประกอบ ${row.name}`} loading="lazy" />
          </a>
          <div class="model-main">
            <div class="row-kicker">
              <span>#{row.queueRank.toString().padStart(2, "0")}</span>
              <span class={`status-pill ${row.statusMeta.className}`}>{row.statusMeta.shortLabel}</span>
              <a class="review-badge" href={row.reviewHref}>หน้ารีวิวแยกรุ่น</a>
            </div>
            <h3><a class="model-title-link" href={row.reviewHref}>{row.name}</a></h3>
            <p>{row.proofLine}</p>
            <div class="row-meta">
              <span>{row.btuText}</span>
              <span>{row.priceLabel}</span>
              <span>{row.sourceName}{row.proofCount ? ` ${formatNumber(row.proofCount)} รีวิว` : ""}</span>
            </div>
          </div>
          <div class="row-check">
            <strong>ต้องดูเพิ่ม</strong>
            <ul>
              {row.watchouts.map((item) => <li>{item}</li>)}
            </ul>
          </div>
          <div class="row-actions">
            <a class="read-link" href={row.reviewHref}>อ่านรีวิวรุ่นนี้</a>
            <a href={row.links.shopee} target="_blank" rel="sponsored noopener">Shopee</a>
            <a href={row.links.lazada} target="_blank" rel="sponsored noopener">Lazada</a>
            <a href={row.links.tiktok} target="_blank" rel="sponsored noopener">TikTok</a>
          </div>
        </article>
      ))}
    </div>
    <p class="container empty-result" data-empty-result hidden>ยังไม่เจอรุ่นที่ตรงกับตัวกรอง ลองล้างตัวกรองก่อนครับ</p>
  </section>

  <section class="library-section brand-section" id="brand-map">
    <div class="container brand-layout">
      <div class="section-heading brand-heading">
        <span class="eyebrow">Brand Map</span>
        <h2>ดูตามแบรนด์ จะเห็นภาพเร็วขึ้นว่าตลาดแอร์ไทยกว้างแค่ไหน</h2>
        <p>
          กลุ่มนี้ไม่ได้มีแค่แบรนด์ใหญ่ในห้าง แต่รวมรุ่นออนไลน์ที่คนค้นหาเยอะด้วย
          เป้าหมายคือค่อย ๆ ทำให้ครบทุกตัวที่คนไทยมีโอกาสซื้อจริง
        </p>
      </div>
      <div class="brand-chips">
        {brandGroups.map(([brand, count]) => (
          <span>
            <strong>{brand}</strong>
            <small>{count} รุ่น</small>
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    width: min(1220px, calc(100% - 32px));
    margin: 0 auto;
  }

  .air-library-hero {
    position: relative;
    min-height: min(780px, calc(100vh - 84px));
    overflow: hidden;
    background:
      radial-gradient(1100px 480px at 50% -80px, rgba(255, 214, 186, 0.5), transparent 70%),
      linear-gradient(180deg, #fff8ee, #fffdf8);
    color: #17202a;
  }

  .air-library-hero__media,
  .air-library-hero__overlay {
    position: absolute;
    inset: 0;
  }

  .air-library-hero__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 74% center;
    filter: saturate(0.82) contrast(1.02);
    transform: scale(1.04);
  }

  .air-library-hero__overlay {
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.97), rgba(255, 248, 238, 0.9) 42%, rgba(255, 244, 234, 0.5)),
      linear-gradient(180deg, rgba(255, 240, 234, 0.4), rgba(255, 253, 248, 0.92));
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(320px, 440px);
    gap: clamp(28px, 5vw, 84px);
    align-items: end;
    min-height: min(780px, calc(100vh - 84px));
    padding: clamp(72px, 11vw, 132px) 0 clamp(44px, 7vw, 84px);
  }

  .eyebrow {
    color: #d64c41;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .section-heading h2 {
    letter-spacing: 0;
  }

  .hero-copy h1 {
    max-width: 890px;
    margin: 14px 0 18px;
    font-size: clamp(46px, 8.4vw, 112px);
    line-height: 0.95;
  }

  .hero-copy p {
    max-width: 780px;
    margin: 0;
    color: #4a5a68;
    font-size: clamp(17px, 1.8vw, 23px);
    line-height: 1.65;
  }

  .hero-actions,
  .card-actions,
  .row-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .hero-actions {
    margin-top: 28px;
  }

  .button-main,
  .button-ghost,
  .card-actions a,
  .row-actions a {
    min-height: 48px;
