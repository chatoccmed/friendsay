<script is:inline data-astro-rerun>
  (() => {
    const filterRoot = document.querySelector("[data-air-filter]");
    const rows = Array.from(document.querySelectorAll("[data-model-row]"));
    if (!filterRoot || rows.length === 0) return;

    const searchInput = filterRoot.querySelector("[data-filter-search]");
    const brandSelect = filterRoot.querySelector("[data-filter-brand]");
    const btuSelect = filterRoot.querySelector("[data-filter-btu]");
    const statusSelect = filterRoot.querySelector("[data-filter-status]");
    const resetButton = filterRoot.querySelector("[data-filter-reset]");
    const visibleCount = filterRoot.querySelector("[data-visible-count]");
    const emptyResult = document.querySelector("[data-empty-result]");

    const normalize = (value) => String(value || "").toLowerCase().trim();

    const applyFilters = () => {
      const searchValue = normalize(searchInput?.value);
      const brandValue = brandSelect?.value || "";
      const btuValue = btuSelect?.value || "";
      const statusValue = statusSelect?.value || "";
      let shown = 0;

      rows.forEach((row) => {
        const rowSearch = normalize(row.dataset.search);
        const rowBrand = row.dataset.brand || "";
        const rowBtu = row.dataset.btu || "";
        const rowStatus = row.dataset.status || "";
        const isMatch =
          (!searchValue || rowSearch.includes(searchValue)) &&
          (!brandValue || rowBrand === brandValue) &&
          (!btuValue || rowBtu.includes(btuValue)) &&
          (!statusValue || rowStatus === statusValue);

        row.hidden = !isMatch;
        if (isMatch) shown += 1;
      });

      if (visibleCount) visibleCount.textContent = String(shown);
      if (emptyResult) emptyResult.hidden = shown !== 0;
    };

    [searchInput, brandSelect, btuSelect, statusSelect].forEach((control) => {
      control?.addEventListener("input", applyFilters);
      control?.addEventListener("change", applyFilters);
    });

    resetButton?.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      if (brandSelect) brandSelect.value = "";
      if (btuSelect) btuSelect.value = "";
      if (statusSelect) statusSelect.value = "";
      applyFilters();
      searchInput?.focus();
    });
  })();
</script>
