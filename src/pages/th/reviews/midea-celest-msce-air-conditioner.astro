    answer: "ไม่ควรถือว่าเป็นราคาจบ เพราะหน้าสินค้าระบุไม่รวมติดตั้ง ต้องถามค่าช่าง ท่อ ราง ขาแขวน สายไฟ และงานเจาะเพิ่มก่อนตัดสินใจ"
  },
  {
    question: "ควรเลือก BTU ไหน?",
    answer: "เริ่มจากขนาดห้องจริง แดด หน้าต่าง ฝ้า และจำนวนคนในห้อง รุ่นนี้มี 9,360 / 12,000 / 18,000 / 24,000 BTU จึงไม่ควรเลือกจากราคาอย่างเดียว"
  },
  {
    question: "จุดที่ควรถามร้านก่อนซื้อคืออะไร?",
    answer: "ถามเรื่องไม่รวมติดตั้ง, Wi-Fi, ประกัน 10/5/5 ปี, ช่องทางเคลม, ใบเสร็จ, และร้านช่วยประสานงานกับศูนย์บริการหรือไม่"
  }
];

const scoreItems = [
  { label: "ความนิยม", value: 6.6 },
  { label: "ความมั่นใจผู้ซื้อ", value: 7.4 },
  { label: "ความคุ้มค่า", value: 8.7 },
  { label: "เลือก BTU ง่าย", value: 8.8 },
  { label: "ประหยัดไฟ/สบาย", value: 8.7 },
  { label: "ความเสี่ยงติดตั้ง", value: 7.4 },
  { label: "ประกัน/ความปลอดภัย", value: 8.5 },
  { label: "ความเสี่ยงคำบ่น", value: 7.8 }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: "Midea Celest MSCE",
    brand: { "@type": "Brand", name: "Midea" },
    category: "Wall mounted air conditioner"
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: "8.1",
    bestRating: "10",
    worstRating: "1"
  },
  author: { "@type": "Organization", name: "Friendsay" },
  inLanguage: "th",
  dateModified: "2026-06-16",
  headline: "Midea Celest MSCE แอร์ราคาเริ่มดี BTU กว้าง ประกันยาว เหมาะกับคนคุมงบ"
};
---

<BaseLayout
  title="Midea Celest MSCE แอร์ราคาเริ่มดี BTU กว้าง ประกันยาว | Friendsay"
  description="Midea Celest MSCE แอร์ติดผนังราคาเริ่มดี มี BTU กว้างและประกันเด่น สรุปคำแนะนำจากรีวิวผู้ซื้อ ค่าติดตั้งที่ต้องคิดเพิ่ม และปุ่มเช็กราคา Shopee Lazada TikTok"
  canonical="https://friendsay.com/th/reviews/midea-celest-msce-air-conditioner/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

  <article class="pilot-review">
    <section class="air-review-hero">
      <a class="air-image-link air-hero-image-link" {...imageLinkAttrs}>
        <img src={heroImage} alt="ภาพห้องนอนสว่างกับแอร์ Midea Celest MSCE สำหรับเปิดรีวิว" loading="eager" />
      </a>
      <div class="air-review-shade" aria-hidden="true"></div>
      <div class="container air-review-hero-inner">
        <div class="air-review-title">
          <p class="eyebrow">คู่มือเลือกซื้อแบบเพื่อนช่วยดู / Shopee 2026</p>
          <h1>Midea Celest MSCE แอร์ราคาเริ่มดี BTU กว้าง ประกันยาว เหมาะกับคนคุมงบ</h1>
          <p>
            รุ่นนี้น่าเอาเข้ารอบถ้าคุณอยากได้แอร์ Midea ราคาเริ่มดี มี BTU ให้เลือกกว้าง และสนใจประกันยาว
            แต่ต้องจำไว้ก่อนว่าเป็นเครื่องที่ต้องคิดค่าติดตั้งแยก และควรถามร้านเรื่องประกันกับบริการหลังซื้อให้ชัดก่อนจ่าย
          </p>
          <div class="air-review-actions">
            <a class="button button-primary" href="#buying-cockpit">ดูคำตอบ 90 วินาที</a>
            <a class="button button-dark" href="#review-proof">ดูรีวิวผู้ซื้อจริง</a>
            <button class="button compare-hero-button" type="button" data-air-compare-slug={product.slug}>
              + เปรียบเทียบ
            </button>
          </div>
        </div>

        <aside class="air-verdict-card">
          <div class="air-product-card-image">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={productSetImage} alt="ภาพ Midea Celest MSCE พร้อมคอยล์ร้อน รีโมต และอุปกรณ์ติดตั้ง" loading="eager" />
            </a>
          </div>
          <span class="badge badge-coral">{product.statusLabel}</span>
          <div class="air-score-ring" role="img" aria-label={`คะแนนรวม ${product.score.toFixed(1)} จาก 10`} style={`--ring-offset:${(326.73 * (1 - product.score / 10)).toFixed(1)};`}>
            <svg viewBox="0 0 120 120" aria-hidden="true">
              <circle class="air-ring-track" cx="60" cy="60" r="52" />
              <circle class="air-ring-fill" cx="60" cy="60" r="52" />
            </svg>
            <div><strong>{product.score.toFixed(1)}</strong><small>/10</small></div>
          </div>
          <p>น่าเก็บไว้เทียบถ้าคุณอยากได้ Midea ราคาไม่แรง และยอมเช็กค่าติดตั้งกับประกันให้ครบก่อนจ่าย</p>
          <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context="midea-hero-card" />
        </aside>
      </div>
    </section>

    <section class="air-decision-cockpit" id="buying-cockpit" aria-label="สรุปตัดสินใจซื้อแบบเร็ว">
      <div class="wide-container air-cockpit-inner">
        <div class="air-cockpit-head">
          <p class="eyebrow">สรุปให้ก่อนเลือก</p>
          <h2>ตัดสินใจซื้อใน 90 วินาที</h2>
          <p>ถ้าไม่อยากอ่านยาว ให้เริ่มจาก 3 ช่องนี้ก่อนครับ ถ้าตอบได้ครบ ค่อยลงรายละเอียดเรื่องรีวิวจริง ขนาดห้อง และค่าใช้จ่ายต่อ</p>
        </div>

        <div class="air-cockpit-grid">
          <article class="air-cockpit-verdict">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={cleanUnitImage} alt="ภาพตัวเครื่อง Midea Celest MSCE แบบคลีนสำหรับดูทรงเครื่อง" loading="lazy" />
            </a>
            <div>
              <span>{product.statusLabel}</span>
              <strong>{product.score.toFixed(1)}/10</strong>
              <p>เอาเข้ารอบ shortlist ได้ ถ้าคุณอยากได้แอร์ Midea ราคาดี ประกันยาว และคิดค่าติดตั้งแยกไว้แล้ว</p>
            </div>
          </article>

          <article class="air-cockpit-panel air-cockpit-steps">
            <span class="air-panel-label">คิดตามนี้ก่อนจ่าย</span>
            {cockpitSteps.map((step) => (
              <div>
                <b>{step.label}</b>
                <strong>{step.title}</strong>
                <p>{step.body}</p>
              </div>
            ))}
          </article>

          <article class="air-cockpit-panel air-cockpit-price">
            <span class="air-panel-label">ราคาที่ต้องคิดจริง</span>
            <strong>{product.priceLabel}</strong>
            <div>
              {costChecks.map((item) => (
                <span>{item.label}: {item.value}</span>
              ))}
            </div>
            <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} context="midea-decision-price" />
          </article>
        </div>

        <div class="air-buying-snapshot" aria-label="สรุปก่อนซื้อแบบเร็ว">
          {buyerSnapshotCards.map((item) => (
            <article>
              <span>{item.label}</span>
              <strong>{item.title}</strong>
              <p>{item.body}</p>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="section air-proof-stage" id="images">
      <div class="wide-container">
        <section class="air-review-proof-section" id="review-proof" aria-label="ภาพและรีวิวผู้ซื้อจริง">
          <div class="air-review-proof-head">
            <div>
              <p class="eyebrow">ภาพและรีวิวที่ควรดู</p>
              <h2>ดูภาพสินค้า แล้วอ่านคำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ</h2>
              <p>
                เวลาเลือกแอร์ ผมจะเริ่มจากภาพสินค้าแบบคลีนก่อน แล้วสรุปรีวิวผู้ซื้อให้กลายเป็นข้อแนะนำที่ใช้ได้จริง
                เพราะคนอ่านควรรู้ทันทีว่าต้องเช็กอะไร ไม่ใช่แค่รู้ว่ารุ่นนี้มีรีวิวเยอะ
              </p>
            </div>
            <div class="air-review-proof-stats" aria-label="ตัวเลขรีวิวจาก Shopee">
              <strong>{product.rating.toFixed(1)}/5</strong>
              <span>{product.ratingsCount.toLocaleString("th-TH")}+ คะแนน</span>
              <span>{product.commentsCount.toLocaleString("th-TH")}+ คอมเมนต์</span>
              <span>{product.mediaCount.toLocaleString("th-TH")}+ รีวิวมีภาพ/วิดีโอ</span>
            </div>
          </div>

          <div class="air-evidence-strip" aria-label="วิธีใช้ภาพและรีวิวในบทความนี้">
            {visualEvidenceCards.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </article>
            ))}
          </div>

          <div class="air-source-photo-grid" aria-label="ภาพสินค้า Midea Celest MSCE">
            {realShopImages.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.title} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                  <em>{item.note}</em>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-photo-wall" aria-label="ภาพประกอบการตัดสินใจก่อนซื้อ">
            {reviewPhotoWall.map((item) => (
              <figure>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={item.alt} loading="lazy" />
                </a>
                <figcaption>
                  <span>{item.label}</span>
                  <strong>{item.title}</strong>
                </figcaption>
              </figure>
            ))}
          </div>

          <div class="air-real-review-grid" aria-label="คำแนะนำจากรีวิวผู้ซื้อ 6 ข้อ">
            {realReviewSnapshots.map((item) => (
              <article>
                <a class="air-image-link" {...imageLinkAttrs}>
                  <img src={item.image} alt={`ภาพประกอบรีวิวจาก ${item.buyer}`} loading="lazy" />
                </a>
                <div>
                  <span>{item.buyer} • {item.date} • {item.variation}</span>
                  <strong>{item.quote}</strong>
                  <p>{item.signal}</p>
                  <em>{item.takeaway}</em>
                </div>
              </article>
            ))}
          </div>
        </section>
      </div>
    </section>

    <section class="section air-btu-stage" id="btu">
      <div class="wide-container">
        <div class="air-btu-selector" aria-label="ตัวช่วยเลือก BTU แบบเร็ว">
          <div>
            <p class="eyebrow">เลือก BTU แบบเร็ว</p>
            <h3>เลือก BTU ให้ตรงห้องก่อนดูราคา</h3>
            <p>รุ่นนี้มี 9,360 / 12,000 / 18,000 / 24,000 BTU จุดดีคือครอบคลุมตั้งแต่ห้องนอนเล็กไปจนถึงห้องใหญ่ แต่ต้องถามร้านจากขนาดห้องจริงก่อน ไม่ใช่เลือกจากราคา</p>
          </div>
          <div class="air-btu-selector-grid">
            {btuGuide.map((item) => (
              <article>
                <span>{item.btu}</span>
                <strong>{item.room}</strong>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section">
      <div class="container article-layout">
        <article class="article-body">
          <div class="air-quick-grid air-fit-grid">
            <div class="soft-card">
              <h2>เหมาะกับใคร</h2>
              <p>{product.bestFor}</p>
            </div>
            <div class="soft-card">
              <h2>ไม่เหมาะกับใคร</h2>
              <p>{product.notFor}</p>
            </div>
          </div>

          <h2 id="score">คะแนนแบบ Friendsay</h2>
          <ScoreBars scores={scoreItems} />
          <p>
            คะแนน {product.score.toFixed(1)}/10 ของ Midea Celest MSCE มาจากราคาเริ่มต้นที่ดี ตัวเลือก BTU กว้าง และประกันที่ดูน่าสนใจ
            แต่คะแนนถูกกดลงเพราะจำนวนรีวิวยังไม่มากเท่ารุ่นยอดนิยม ร้านไม่ใช่ official โดยตรง และราคาหน้าร้านยังไม่รวมติดตั้งครับ
          </p>

          <h2 id="good">ข้อดีที่ควรรู้</h2>
          <p>
            ถ้าดูแบบคนกำลังจะซื้อจริง รุ่นนี้มีข้อดีที่จับต้องได้ ไม่ใช่แค่คำโปรโมตบนหน้าร้าน จุดที่ควรเก็บไว้เทียบมีตามนี้ครับ
          </p>
          <div class="verdict-grid" aria-label="ข้อดีของ Midea Celest MSCE">
            {product.pros.map((item, index) => (
              <article>
                <span>{`ข้อ ${index + 1}`}</span>
                <strong>{item}</strong>
              </article>
            ))}
          </div>

          <h2 id="watch">จุดต้องระวังก่อนกดซื้อ</h2>
          <p>
            จุดระวังของรุ่นนี้ไม่ได้แปลว่าไม่ดี แต่เป็นจุดที่ต้องถามให้ชัดก่อนจ่าย เพราะแอร์เป็นสินค้าที่มีงานหน้างานตามมา
            ซื้อผิด BTU หรือเข้าใจผิดเรื่องติดตั้ง จะเสียเวลาแก้มากกว่าของใช้ชิ้นเล็กครับ
          </p>
          <div class="air-watch-list" aria-label="จุดต้องระวังก่อนซื้อ Midea Celest MSCE">
            {product.watch.map((item, index) => (
              <article>
                <span>{`เช็ก ${index + 1}`}</span>
                <strong>{item}</strong>
              </article>
            ))}
          </div>
          <p>
            ถ้าอยู่คอนโด ให้ถามนิติก่อนเรื่องเจาะผนัง จุดวางคอยล์ร้อน และท่อน้ำทิ้ง ส่วนถ้าไม่มีช่างประจำ
            ให้คุยค่าติดตั้งกับช่างก่อนกดซื้อ เพราะรุ่นนี้ราคาเครื่องดูดี แต่ราคาจบขึ้นกับหน้างานจริงครับ
          </p>

          <section class="air-cost-section" id="cost">
            <p class="eyebrow">เช็กเงินที่ต้องจ่ายจริง</p>
            <h2>ราคาเครื่องไม่ใช่ราคาสุดท้ายเสมอไป</h2>
            <p>
              จุดนี้สำคัญมากสำหรับแอร์ทุกยี่ห้อครับ ราคาเครื่องเป็นแค่จุดเริ่มต้น ก่อนจ่ายเงินจริงให้ถามให้ครบว่าราคารวมอะไรบ้าง
              โดยเฉพาะคนซื้อออนไลน์ที่ไม่ได้มีช่างประจำ
            </p>
            <figure class="air-wide-figure">
              <a class="air-image-link" {...imageLinkAttrs}>
                <img src={costPlanImage} alt="ภาพประกอบการเช็กต้นทุนรวมและประกัน Midea Celest MSCE" loading="lazy" />
              </a>
              <figcaption>
                ราคาเครื่องเปล่าเป็นแค่จุดเริ่มต้น ต้องรวมค่าช่าง อุปกรณ์หน้างาน และเงื่อนไขประกันก่อนเทียบกับรุ่นอื่น
              </figcaption>
            </figure>
            <div class="air-cost-grid">
              {costChecks.map((item) => (
                <article>
                  <span>{item.label}</span>
                  <strong>{item.value}</strong>
                  <p>{item.note}</p>
                </article>
              ))}
            </div>
          </section>

          <h2 id="install">เรื่องติดตั้งคือหัวใจของรีวิวแอร์</h2>
          <p>
            แอร์ที่ดีไม่ได้จบตอนกล่องมาถึงบ้าน แต่จบตอนติดตั้งแล้วเย็นจริง น้ำไม่หยด เสียงไม่กวน และใช้งานได้ยาว ๆ
            เพราะฉะนั้นส่วนติดตั้งควรถามละเอียดกว่าปกติ โดยเฉพาะรุ่นนี้ที่หน้าสินค้าระบุไม่รวมติดตั้ง
          </p>
          <figure class="air-wide-figure">
            <a class="air-image-link" {...imageLinkAttrs}>
              <img src={installPlanImage} alt="ภาพวางแผนตำแหน่งติดตั้งและอุปกรณ์สำหรับ Midea Celest MSCE" loading="lazy" />
            </a>
            <figcaption>
              ก่อนให้ช่างเจาะผนัง ควรดูทิศทางลม จุดวางเตียง ระยะท่อ และตำแหน่งคอยล์ร้อนให้จบตั้งแต่แรก
            </figcaption>
          </figure>
          <ul class="air-checklist">
            {product.installNotes.map((item) => <li>{item}</li>)}
          </ul>

          <h2 id="warranty">ประกันและความสบายใจหลังซื้อ</h2>
          <p>
            Midea เป็นแบรนด์เครื่องใช้ไฟฟ้าที่คนไทยรู้จัก และจุดขายของรุ่นนี้คือประกันที่ดูยาวกว่าหลายรุ่นในงบใกล้กัน
            แต่ก่อนซื้อควรถามให้ชัดว่าคอมเพรสเซอร์ อะไหล่ และค่าแรงครอบคลุมกี่ปีจริง เคลมผ่านร้านหรือศูนย์ และต้องใช้เอกสารอะไร
          </p>
          <ul class="air-checklist">
            {product.warrantyNotes.map((item) => <li>{item}</li>)}
          </ul>

          <h2 id="compare">ควรเทียบกับรุ่นไหน</h2>
          <p>
