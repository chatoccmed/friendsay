<script is:inline data-astro-rerun>
  (() => {
    const root = document.querySelector("[data-fridge-filter]");
    const rows = Array.from(document.querySelectorAll("[data-model-row]"));
    if (!root || rows.length === 0) return;

    const searchInput = root.querySelector("[data-filter-search]");
    const brandSelect = root.querySelector("[data-filter-brand]");
    const typeSelect = root.querySelector("[data-filter-type]");
    const resetButton = root.querySelector("[data-filter-reset]");
    const visibleCount = root.querySelector("[data-visible-count]");
    const emptyResult = document.querySelector("[data-empty-result]");
    const normalize = (value) => String(value || "").toLowerCase().trim();

    const applyFilters = () => {
      const searchValue = normalize(searchInput?.value);
      const brandValue = brandSelect?.value || "";
      const typeValue = typeSelect?.value || "";
      let shown = 0;

      rows.forEach((row) => {
        const isMatch =
          (!searchValue || normalize(row.dataset.search).includes(searchValue)) &&
          (!brandValue || row.dataset.brand === brandValue) &&
          (!typeValue || row.dataset.type === typeValue);
        row.hidden = !isMatch;
        if (isMatch) shown += 1;
      });

      if (visibleCount) visibleCount.textContent = String(shown);
      if (emptyResult) emptyResult.hidden = shown !== 0;
    };

    [searchInput, brandSelect, typeSelect].forEach((control) => {
      control?.addEventListener("input", applyFilters);
      control?.addEventListener("change", applyFilters);
    });

    resetButton?.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      if (brandSelect) brandSelect.value = "";
      if (typeSelect) typeSelect.value = "";
      applyFilters();
      searchInput?.focus();
    });
  })();
</script>
