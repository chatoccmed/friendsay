---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import {
  queuedRefrigeratorReviews,
  refrigeratorReviewSummary
} from "../../../../data/refrigeratorReviewQueue";

const reviews = queuedRefrigeratorReviews.slice().sort((a, b) => a.queueRank - b.queueRank);
const topReviews = reviews.slice(0, 6);
const brandGroups = Array.from(
  reviews.reduce((map, item) => {
    map.set(item.brand, (map.get(item.brand) ?? 0) + 1);
    return map;
  }, new Map<string, number>())
).sort((a, b) => b[1] - a[1]);
const brands = brandGroups.map(([brand]) => brand);
const types = Array.from(new Set(reviews.map((item) => item.typeLabel)));
const readyCount = refrigeratorReviewSummary.reviewSignalReady;
const formatNumber = (value: number | undefined) => value ? value.toLocaleString("th-TH") : "";
const reviewHref = (slug: string) => `/th/reviews/refrigerators/${slug}/`;
const pageUrl = "https://friendsay.com/th/reviews/refrigerators/";
const firstReview = (predicate: (item: typeof reviews[number]) => boolean) =>
  reviews.find(predicate) ?? reviews[0];
const bestByNeed = [
  {
    label: "คุมงบ",
    title: "อยากได้ตู้เย็นใช้ง่าย ราคาไม่แรง",
    note: "เริ่มจากรุ่นขนาดพอดีบ้านเล็กก่อน แล้วค่อยเทียบโปร",
    item: firstReview((item) => item.priceLabel.includes("6,990") || item.priceLabel.includes("7,390") || item.priceLabel.includes("7,790"))
  },
  {
    label: "บ้านเล็ก",
    title: "คอนโดหรือบ้าน 1-2 คน",
    note: "ดูรุ่น 6-8 คิวก่อน ถ้าแช่ของสดเยอะค่อยขยับขึ้น",
    item: firstReview((item) => item.capacityCuFt <= 8)
  },
  {
    label: "บ้านกลาง",
    title: "บ้าน 2-4 คนที่ซื้อของทุกสัปดาห์",
    note: "ช่วง 9-14 คิวมักบาลานซ์พื้นที่ ราคา และค่าไฟได้ดี",
    item: firstReview((item) => item.capacityCuFt >= 9 && item.capacityCuFt <= 14)
  },
  {
    label: "บ้านใหญ่",
    title: "ทำอาหารบ่อยหรือซื้อของเข้าบ้านทีละเยอะ",
    note: "เริ่มดู 16 คิวขึ้นไป แต่ต้องวัดทางขนย้ายจริงจัง",
    item: firstReview((item) => item.capacityCuFt >= 16)
  },
  {
    label: "ไซด์บายไซด์",
    title: "อยากได้ช่องแช่กว้างและหยิบของง่าย",
    note: "เหมาะกับครัวที่มีพื้นที่หน้าเครื่องพอเปิดประตูสองฝั่ง",
    item: firstReview((item) => item.type === "side-by-side")
  },
  {
    label: "พรีเมียม",
    title: "อยากให้ครัวดูเรียบร้อยและจัดของเป็นโซน",
    note: "มัลติดอร์เหมาะกับบ้านที่ยอมจ่ายเพิ่มเพื่อความเป็นระเบียบ",
    item: firstReview((item) => item.type === "multi-door")
  }
];
const itemListJsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: "คลังรีวิวตู้เย็น Friendsay 2026",
  description: "รายชื่อรีวิวตู้เย็น 28 รุ่น พร้อมตัวกรอง ความจุ ราคา และจุดที่ควรถามร้านก่อนซื้อ",
  url: pageUrl,
  numberOfItems: reviews.length,
  itemListElement: reviews.map((item, index) => ({
    "@type": "ListItem",
    position: index + 1,
    url: `https://friendsay.com${reviewHref(item.reviewSlug)}`,
    name: item.name,
    image: `https://friendsay.com${item.heroImage}`
  }))
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "หน้าแรก",
      item: "https://friendsay.com/th/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "รีวิวตู้เย็น",
      item: pageUrl
    }
  ]
};
---

<BaseLayout
  title="คลังรีวิวตู้เย็น 28 รุ่นน่าเลือกในไทย 2026 | Friendsay"
  description="รวมรีวิวตู้เย็น 28 รุ่นจากแหล่งขายในไทย พร้อมตัวกรอง ประเภทตู้เย็น ความจุ ราคา จุดควรถามร้าน และลิงก์อ่านรีวิวแยกรุ่นแบบ Friendsay"
  canonical="https://friendsay.com/th/reviews/refrigerators/"
>
  <script type="application/ld+json" set:html={JSON.stringify(itemListJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <section class="fridge-hero">
    <a href={reviews[0].links.shopee} class="fridge-hero__image" target="_blank" rel="sponsored noopener">
      <img src="/images/refrigerators/refrigerator-library-hero.png" alt="ภาพรวมหมวดรีวิวตู้เย็น Friendsay" />
    </a>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Friendsay Refrigerator Library 2026</span>
        <h1>คลังรีวิวตู้เย็น 28 รุ่น เลือกง่ายขึ้นก่อนจ่ายเงินจริง</h1>
        <p>
          หน้านี้รวมตู้เย็นรุ่นที่คนไทยน่าจะเจอบ่อยเวลาเทียบซื้อออนไลน์ แล้วแยกรีวิวให้เปิดดูทีละรุ่นได้ทันที
          จุดสำคัญคือช่วยให้คุณเทียบขนาด ราคา ประเภทตู้ พื้นที่วาง ความเสี่ยงขนส่ง และคำถามที่ควรถามร้านก่อนกดซื้อใน Shopee, Lazada หรือ TikTok
        </p>
        <div class="hero-actions">
          <a href="#all-models" class="primary-link">ดูครบ 28 รุ่น</a>
          <a href="#start-here" class="secondary-link">เริ่มจากรุ่นเด่น</a>
        </div>
      </div>
      <div class="hero-stats" aria-label="สรุปรีวิวตู้เย็น">
        <div>
          <strong>{reviews.length}</strong>
          <span>รุ่นที่เปิดอ่านได้แล้ว</span>
        </div>
        <div>
          <strong>{readyCount}</strong>
          <span>รุ่นที่มีรีวิวให้ไล่อ่านเกิน 5 รายการ</span>
        </div>
        <div>
          <strong>{refrigeratorReviewSummary.categoryCount}</strong>
          <span>รายการสินค้าในหมวดที่ใช้ตั้งต้นสำรวจ</span>
        </div>
      </div>
    </div>
  </section>

  <section class="visual-strip">
    <div class="container strip-grid">
      <a href="#type-guide">
        <img src="/images/refrigerators/refrigerator-product-set.png" alt="ภาพเปรียบเทียบประเภทตู้เย็น" loading="lazy" />
        <strong>เลือกประเภทตู้ให้ตรงบ้าน</strong>
        <span>1 ประตู, 2 ประตู, มัลติดอร์, ไซด์บายไซด์</span>
      </a>
      <a href="#capacity-guide">
        <img src="/images/refrigerators/refrigerator-capacity-organization.png" alt="ภาพจัดของในตู้เย็นตามความจุ" loading="lazy" />
        <strong>ดูความจุจากการใช้จริง</strong>
        <span>อย่าดูคิวอย่างเดียว ให้ดูนิสัยซื้อของด้วย</span>
      </a>
      <a href="#buy-check">
        <img src="/images/refrigerators/refrigerator-delivery-check.png" alt="ภาพตรวจรับตู้เย็นหลังขนส่ง" loading="lazy" />
        <strong>เช็กก่อนรับของ</strong>
        <span>ประตู รอยบุบ ขอบยาง และเงื่อนไขเปลี่ยนคืน</span>
      </a>
    </div>
  </section>

  <section class="library-section" id="start-here">
    <div class="container section-heading">
      <span class="eyebrow">Start Here</span>
      <h2>6 รุ่นแรกที่ควรเปิดอ่านก่อน</h2>
      <p>เรียงจากความน่าสนใจของราคา ความจุ คะแนน และจำนวนรีวิวที่เห็นในรอบสำรวจ เพื่อให้เริ่มเทียบได้เร็วขึ้น</p>
    </div>
    <div class="container priority-grid">
      {topReviews.map((item) => (
        <article class="priority-card">
          <a href={item.links.shopee} class="priority-image" target="_blank" rel="sponsored noopener">
            <img src={item.heroImage} alt={`ภาพประกอบ ${item.name}`} loading="lazy" />
          </a>
          <div class="priority-copy">
            <div class="card-kicker">
              <span>#{item.queueRank.toString().padStart(2, "0")}</span>
              <strong>{item.capacityLabel}</strong>
              <strong>{item.typeLabel}</strong>
            </div>
            <h3><a href={reviewHref(item.reviewSlug)}>{item.name}</a></h3>
            <p>{item.quickVerdict}</p>
            <div class="score-line" style={`--score:${Math.round(item.score * 10)}%;`}>
              <span>{item.score.toFixed(1)}/10</span>
              <i aria-hidden="true"></i>
            </div>
            <div class="card-actions">
              <a href={reviewHref(item.reviewSlug)}>อ่านรีวิวรุ่นนี้</a>
              <a href={item.links.shopee} target="_blank" rel="sponsored noopener">Shopee</a>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="need-section" id="best-by-need">
    <div class="container section-heading">
      <span class="eyebrow">Best By Need</span>
      <h2>ไม่อยากอ่านครบ 28 รุ่น ให้เริ่มจากโจทย์นี้ก่อน</h2>
      <p>เลือกจากสถานการณ์ใกล้ตัว แล้วค่อยเปิดรีวิวรุ่นที่เหมาะที่สุดเพื่อเช็กจุดละเอียดก่อนซื้อจริง</p>
    </div>
    <div class="container need-grid">
      {bestByNeed.map(({ label, title, note, item }) => (
        <article class="need-card">
          <a href={item.links.shopee} target="_blank" rel="sponsored noopener">
            <img src={item.secondaryImage} alt={`ภาพประกอบ ${item.name}`} loading="lazy" />
          </a>
          <div>
            <span>{label}</span>
            <h3>{title}</h3>
            <p>{note}</p>
            <strong>{item.name}</strong>
            <small>{item.capacityLabel} / {item.priceLabel}</small>
            <a class="need-link" href={reviewHref(item.reviewSlug)}>อ่านรีวิวรุ่นนี้</a>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section class="guide-section" id="type-guide">
    <div class="container guide-grid">
      <div>
        <span class="eyebrow">Buying Map</span>
        <h2>ตู้เย็นต่างประเภท เหมาะกับบ้านไม่เหมือนกัน</h2>
        <p>
          ตู้สองประตูยังเป็นตัวเริ่มที่ปลอดภัยที่สุดสำหรับบ้านไทยส่วนใหญ่ ส่วนไซด์บายไซด์และมัลติดอร์เหมาะกับบ้านที่มีพื้นที่ครัวพอ
          และต้องการจัดของหลายโซนมากขึ้น ก่อนเลือกให้ดู “พื้นที่เปิดประตู” กับ “ทางขนย้าย” ควบคู่กับความจุเสมอ
        </p>
      </div>
      <div class="type-cards">
        {types.map((type) => (
          <span>
            <strong>{type}</strong>
            <small>{reviews.filter((item) => item.typeLabel === type).length} รุ่นในคลัง</small>
          </span>
        ))}
      </div>
    </div>
  </section>

  <section class="guide-section guide-section--soft" id="capacity-guide">
    <div class="container capacity-grid">
      <a href={reviews[0].links.shopee} target="_blank" rel="sponsored noopener">
        <img src="/images/refrigerators/refrigerator-capacity-organization.png" alt="ภาพจัดช่องแช่ในตู้เย็น" loading="lazy" />
      </a>
      <div>
        <span class="eyebrow">Capacity Guide</span>
        <h2>เลือกความจุจากนิสัยซื้อของ ไม่ใช่ดูตัวเลขคิวอย่างเดียว</h2>
        <div class="capacity-list">
          <span><strong>6-8 คิว</strong>คอนโดหรือบ้าน 1-2 คน</span>
          <span><strong>9-13 คิว</strong>บ้านเล็กถึงกลาง ใช้ง่าย ราคายังไม่แรง</span>
          <span><strong>14-18 คิว</strong>บ้านทำอาหารบ่อย ซื้อของเข้าบ้านทีละเยอะ</span>
          <span><strong>20 คิวขึ้นไป</strong>บ้านใหญ่ ต้องเช็กพื้นที่เปิดประตูจริงจัง</span>
        </div>
      </div>
    </div>
  </section>

  <section class="library-section all-models-section" id="all-models">
    <div class="container section-heading">
      <span class="eyebrow">All Models</span>
      <h2>รายชื่อรุ่นทั้งหมดในคลังตู้เย็น</h2>
      <p>ค้นจากแบรนด์ รุ่น ประเภท หรือความจุได้เลย ทุกแถวมีลิงก์ไปหน้ารีวิวแยกรุ่น พร้อมทางลัดไปเช็กราคาและรีวิวล่าสุดก่อนตัดสินใจ</p>
    </div>

    <div class="container model-tools" data-fridge-filter>
      <label>
        <span>ค้นหารุ่น</span>
        <input data-filter-search type="search" placeholder="เช่น Toshiba, 12.8, Side by side" />
      </label>
      <label>
        <span>แบรนด์</span>
        <select data-filter-brand>
          <option value="">ทุกแบรนด์</option>
          {brands.map((brand) => <option value={brand}>{brand}</option>)}
        </select>
      </label>
      <label>
        <span>ประเภท</span>
        <select data-filter-type>
          <option value="">ทุกประเภท</option>
          {types.map((type) => <option value={type}>{type}</option>)}
        </select>
      </label>
      <button data-filter-reset type="button">ล้างตัวกรอง</button>
      <p><strong data-visible-count>{reviews.length}</strong> รุ่นที่แสดงอยู่</p>
    </div>

    <div class="container model-list">
      {reviews.map((item) => (
        <article
          class="model-row"
          data-model-row
          data-brand={item.brand}
          data-type={item.typeLabel}
          data-search={`${item.brand} ${item.model} ${item.typeLabel} ${item.capacityLabel}`.toLowerCase()}
        >
          <a href={item.links.shopee} class="model-thumb" target="_blank" rel="sponsored noopener">
            <img src={item.secondaryImage} alt={`ภาพประกอบ ${item.name}`} loading="lazy" />
          </a>
          <div class="model-main">
            <span class="rank">#{item.queueRank.toString().padStart(2, "0")}</span>
            <h3><a href={reviewHref(item.reviewSlug)}>{item.name}</a></h3>
            <p>{item.quickVerdict}</p>
            <div class="row-meta">
              <span>{item.capacityLabel}</span>
              <span>{item.priceLabel}</span>
              <span>{item.reviewCount ? `${formatNumber(item.reviewCount)} รีวิวให้ไล่อ่าน` : "เช็กราคาและรีวิวล่าสุดก่อนซื้อ"}</span>
            </div>
          </div>
          <div class="row-check">
            <strong>ต้องเช็กก่อนซื้อ</strong>
            <ul>
              {item.watchouts.slice(0, 3).map((watch) => <li>{watch}</li>)}
            </ul>
          </div>
          <div class="row-actions">
            <a class="read-link" href={reviewHref(item.reviewSlug)}>อ่านรีวิว</a>
            <a href={item.links.shopee} target="_blank" rel="sponsored noopener">Shopee</a>
            <a href={item.links.lazada} target="_blank" rel="sponsored noopener">Lazada</a>
            <a href={item.links.tiktok} target="_blank" rel="sponsored noopener">TikTok</a>
          </div>
        </article>
      ))}
    </div>
    <p class="container empty-result" data-empty-result hidden>ยังไม่เจอรุ่นตามตัวกรอง ลองล้างตัวกรองแล้วค้นด้วยชื่อแบรนด์หรือเลขรุ่นอีกครั้งครับ</p>
  </section>

  <section class="guide-section" id="buy-check">
    <div class="container guide-grid">
      <div>
        <span class="eyebrow">Before You Pay</span>
        <h2>ตู้เย็นซื้อออนไลน์ได้ แต่ต้องถามร้านให้ชัดก่อน</h2>
        <p>
          ของใหญ่แบบตู้เย็นไม่ได้จบที่ราคาเครื่อง ให้ถามค่าส่ง ยกขึ้นชั้น ระยะเวลาเปลี่ยนคืน รอยบุบจากขนส่ง และเงื่อนไขประกันก่อนจ่ายเงิน
          ถ้าร้านตอบเรื่องพวกนี้ชัด โอกาสปวดหัวหลังรับของจะน้อยลงมาก
        </p>
      </div>
      <a href={reviews[0].links.shopee} target="_blank" rel="sponsored noopener">
        <img src="/images/refrigerators/refrigerator-delivery-check.png" alt="ภาพตรวจรับตู้เย็นก่อนใช้งาน" loading="lazy" />
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .container {
    width: min(1220px, calc(100% - 32px));
    margin: 0 auto;
  }

  .fridge-hero {
    position: relative;
    overflow: hidden;
    min-height: min(760px, calc(100vh - 82px));
    background:
      radial-gradient(1100px 480px at 50% -80px, rgba(255, 214, 186, 0.5), transparent 70%),
      linear-gradient(180deg, #fff8ee, #fffdf8);
    color: #17202a;
  }

  .fridge-hero__image,
  .fridge-hero__image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .fridge-hero__image img {
    object-fit: cover;
    object-position: 66% center;
    opacity: 0.9;
    filter: saturate(0.92) contrast(1.04);
  }

  .fridge-hero::after {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(90deg, rgba(255, 253, 248, 0.97), rgba(255, 248, 238, 0.9) 45%, rgba(255, 244, 234, 0.5)),
      linear-gradient(180deg, rgba(255, 240, 234, 0.4), rgba(255, 253, 248, 0.92));
    content: "";
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 410px);
    gap: clamp(26px, 5vw, 76px);
    align-items: end;
    min-height: min(760px, calc(100vh - 82px));
    padding: clamp(72px, 11vw, 128px) 0 clamp(42px, 6vw, 78px);
  }

  .eyebrow {
    color: #d64c41;
    font-size: 0.78rem;
    font-weight: 950;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .hero-copy h1,
  .section-heading h2,
  .guide-grid h2,
  .capacity-grid h2 {
    letter-spacing: 0;
  }

  .hero-copy h1 {
    max-width: 850px;
    margin: 12px 0 18px;
    font-size: clamp(44px, 8vw, 106px);
    line-height: 0.95;
  }

  .hero-copy p {
    max-width: 760px;
    margin: 0;
    color: #4a5a68;
    font-size: clamp(17px, 1.8vw, 23px);
    line-height: 1.65;
  }

  .hero-actions,
  .card-actions,
  .row-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
