---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import PriceButtons from "../../../../components/PriceButtons.astro";
import ScoreBars from "../../../../components/ScoreBars.astro";
import AffiliateClickTracker from "../../../../components/AffiliateClickTracker.astro";
import {
  queuedRefrigeratorReviews,
  type QueuedRefrigeratorReview
} from "../../../../data/refrigeratorReviewQueue";

export function getStaticPaths() {
  return queuedRefrigeratorReviews.map((review) => ({
    params: { slug: review.reviewSlug },
    props: { review }
  }));
}

type Props = {
  review: QueuedRefrigeratorReview;
};

const { review } = Astro.props;
const title = `${review.articleTitle} | Friendsay`;
const description = `${review.name} ${review.capacityLabel} ${review.typeLabel} สรุปแบบเพื่อนช่วยเลือก พร้อมคะแนน จุดเด่น จุดระวัง คำถามก่อนซื้อ และลิงก์เช็กราคา Shopee Lazada TikTok`;
const pageUrl = `https://friendsay.com/th/reviews/refrigerators/${review.reviewSlug}/`;
const scoreBars = [
  { label: "ความนิยม", value: review.scores.popularity },
  { label: "ความมั่นใจผู้ซื้อ", value: review.scores.buyerConfidence },
  { label: "ความคุ้มค่า", value: review.scores.value },
  { label: "ความจุเหมาะบ้าน", value: review.scores.capacityFit },
  { label: "ค่าไฟ/เสียงรบกวน", value: review.scores.energyComfort },
  { label: "ดูแลรักษาง่าย", value: review.scores.maintenanceEase },
  { label: "ความเสี่ยงขนส่ง", value: review.scores.deliveryRisk }
];
const tocItems = [
  ["quick", "คำตอบเร็ว"],
  ["buyer-advice", "6 ข้อที่ควรรู้"],
  ["fit", "เหมาะกับใคร"],
  ["capacity", "เลือกความจุ"],
  ["score", "คะแนน"],
  ["good", "ข้อดี"],
  ["watch", "จุดระวัง"],
  ["cost", "ต้นทุนจริง"],
  ["space", "พื้นที่วาง"],
  ["warranty", "ประกัน"],
  ["compare", "เทียบรุ่นอื่น"],
  ["shop-questions", "ถามร้านก่อนซื้อ"],
  ["price", "เช็กราคา"],
  ["faq", "FAQ"],
  ["final", "สรุป"]
];
const imageLinkAttrs = {
  href: review.links.shopee,
  target: "_blank",
  rel: "sponsored noopener"
};
const reviewJsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  name: review.articleTitle,
  headline: review.articleTitle,
  url: pageUrl,
  image: `https://friendsay.com${review.heroImage}`,
  datePublished: "2026-06-19",
  dateModified: "2026-06-19",
  inLanguage: "th-TH",
  reviewBody: review.summary,
  author: {
    "@type": "Organization",
    name: "Friendsay",
    url: "https://friendsay.com"
  },
  publisher: {
    "@type": "Organization",
    name: "Friendsay",
    url: "https://friendsay.com"
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: review.score.toFixed(1),
    bestRating: "10",
    worstRating: "1"
  },
  itemReviewed: {
    "@type": "Product",
    name: review.name,
    brand: {
      "@type": "Brand",
      name: review.brand
    },
    model: review.model,
    category: "ตู้เย็น",
    image: `https://friendsay.com${review.secondaryImage}`,
    description
  }
};
const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: [
    {
      "@type": "Question",
      name: `${review.capacityLabel} พอกับบ้านกี่คน?`,
      acceptedAnswer: {
        "@type": "Answer",
        text: "ขึ้นกับนิสัยซื้อของ ถ้าซื้อของสดบ่อยและแช่เยอะ ให้ขยับขนาดขึ้นจากที่คิดไว้เล็กน้อย แต่ถ้ากินข้างนอกบ่อย ขนาดกลางมักพอแล้ว"
      }
    },
    {
      "@type": "Question",
      name: "ซื้อผ่าน Shopee ต้องระวังอะไร?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "ระวังชื่อรุ่น สี ประกันศูนย์ไทย ค่าขนส่ง ยกขึ้นชั้น และเงื่อนไขเปลี่ยนคืนเมื่อเจอรอยบุบหรือเครื่องมีปัญหา"
      }
    },
    {
      "@type": "Question",
      name: "ควรเสียบปลั๊กทันทีหลังรับของไหม?",
      acceptedAnswer: {
        "@type": "Answer",
        text: "ควรดูคู่มือของรุ่นนั้น ๆ ก่อน โดยทั่วไปตู้เย็นที่ผ่านการขนส่งควรตั้งให้นิ่งก่อนเสียบปลั๊ก เพื่อให้น้ำยาทำความเย็นและระบบภายในเข้าที่"
      }
    }
  ]
};
const breadcrumbJsonLd = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "หน้าแรก",
      item: "https://friendsay.com/th/"
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "รีวิวตู้เย็น",
      item: "https://friendsay.com/th/reviews/refrigerators/"
    },
    {
      "@type": "ListItem",
      position: 3,
      name: review.name,
      item: pageUrl
    }
  ]
};
---

<BaseLayout title={title} description={description} canonical={pageUrl}>
  <script type="application/ld+json" set:html={JSON.stringify(reviewJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbJsonLd)} />

  <AffiliateClickTracker pageContext={`refrigerator-review-${review.productKey}`} />

  <section class="review-hero">
    <a class="review-hero__media" {...imageLinkAttrs}>
      <img src={review.heroImage} alt={`ภาพประกอบรีวิว ${review.name}`} />
    </a>
    <div class="review-hero__overlay"></div>
    <div class="container hero-grid">
      <div class="hero-copy">
        <span class="eyebrow">Friendsay Refrigerator Review 2026</span>
        <h1>{review.articleTitle}</h1>
        <p>{review.quickVerdict}</p>
        <div class="hero-actions">
          <a href="#quick" class="primary-link">ดูคำตอบ 90 วินาที</a>
          <a href="#buyer-advice" class="secondary-link">ดู 6 ข้อที่ควรรู้</a>
        </div>
      </div>
      <aside class="hero-card">
        <a {...imageLinkAttrs} class="hero-card__image">
          <img src={review.secondaryImage} alt={`ภาพช่วยตัดสินใจ ${review.name}`} />
        </a>
        <span>คะแนน Friendsay</span>
        <strong>{review.score.toFixed(1)}/10</strong>
        <p>{review.proofLabel}</p>
        <PriceButtons links={review.links} label={`เช็กราคา ${review.name}`} context={`refrigerator-hero-${review.productKey}`} />
      </aside>
    </div>
  </section>

  <nav class="sticky-buy" aria-label="ลิงก์ซื้อสินค้าแบบลอย">
    <a class="sticky-buy__shopee" href={review.links.shopee} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`refrigerator-sticky-${review.productKey}`}>Shopee</a>
    <a class="sticky-buy__lazada" href={review.links.lazada} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="lazada" data-affiliate-context={`refrigerator-sticky-${review.productKey}`}>Lazada</a>
    <a class="sticky-buy__tiktok" href={review.links.tiktok} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="tiktok" data-affiliate-context={`refrigerator-sticky-${review.productKey}`}>TikTok</a>
  </nav>

  <section class="decision-section" id="quick">
    <div class="container decision-grid">
      <a class="decision-image" {...imageLinkAttrs}>
        <img src={review.imageSet.capacityScene} alt="ภาพตัวอย่างการจัดของในตู้เย็น" loading="lazy" />
      </a>
      <div class="decision-card">
        <span class="pill">คำตอบเร็ว</span>
        <h2>ถ้ากำลังเทียบรุ่นนี้ ให้ดู 3 เรื่องก่อน</h2>
        <ol>
          <li><strong>พื้นที่วางจริง:</strong> วัดช่องตู้และทางขนย้ายก่อนดูโปร</li>
          <li><strong>นิสัยซื้อของ:</strong> {review.capacityLabel} เหมาะไหมกับจำนวนคนและของที่แช่ประจำ</li>
          <li><strong>ประกัน/ขนส่ง:</strong> ถามร้านเรื่องรอยบุบ เปลี่ยนคืน และประกันคอมเพรสเซอร์ให้ชัด</li>
        </ol>
      </div>
      <div class="decision-card price-card">
        <span class="pill">ราคาอ้างอิง</span>
        <h2>{review.priceLabel}</h2>
        <p>ใช้เป็นจุดตั้งต้นเทียบโปรได้ แต่ราคาจริงอาจเปลี่ยนตามคูปอง สี ค่าขนส่ง และร้านที่ขาย</p>
        <PriceButtons links={review.links} label={`เช็กราคา ${review.name}`} context={`refrigerator-quick-${review.productKey}`} />
      </div>
    </div>
  </section>

  <section class="proof-section" id="buyer-advice">
    <div class="container section-heading">
      <span class="eyebrow">Buyer Notes</span>
      <h2>6 ข้อที่ควรรู้ก่อนกดซื้อ {review.shortName}</h2>
      <p>สรุปเป็นภาษาคนซื้อจริง: ไม่ต้องอ่านยาว แต่รู้ว่าต้องเช็กอะไรและถามร้านตรงไหนก่อนจ่ายเงิน</p>
    </div>
    <div class="container advice-grid">
      {review.reviewAdvice.map((item, index) => (
        <article class="advice-card">
          <span>{(index + 1).toString().padStart(2, "0")}</span>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </article>
      ))}
    </div>
  </section>

  <section class="photo-wall">
    <div class="container photo-grid">
      <a {...imageLinkAttrs} class="photo-large">
        <img src={review.imageSet.productDetail} alt={`ภาพรวม ${review.name}`} loading="lazy" />
        <span><strong>ตัวเลือกในตลาด</strong> ดูชื่อรุ่น ความจุ และประเภทตู้ให้ตรงก่อน</span>
      </a>
      <a {...imageLinkAttrs}>
        <img src={review.imageSet.spaceScene} alt="ภาพวัดพื้นที่วางตู้เย็น" loading="lazy" />
        <span><strong>พื้นที่วาง</strong> วัดช่องตู้และระยะเปิดประตู</span>
      </a>
      <a {...imageLinkAttrs}>
        <img src={review.imageSet.warrantyScene} alt="ภาพเช็กค่าไฟและประกันตู้เย็น" loading="lazy" />
        <span><strong>ค่าไฟ/ประกัน</strong> ถามให้ชัดก่อนจ่ายเงิน</span>
      </a>
      <a {...imageLinkAttrs}>
        <img src={review.imageSet.deliveryScene} alt="ภาพตรวจรับตู้เย็นหลังขนส่ง" loading="lazy" />
        <span><strong>ขนส่ง</strong> ถ่ายคลิปตอนรับของไว้เสมอ</span>
      </a>
    </div>
  </section>

  <section class="article-zone">
    <div class="container article-layout">
      <article class="article-body">
        <section id="fit" class="content-block">
          <div class="fit-grid">
            <div>
              <h2>เหมาะกับใคร</h2>
              <ul>
                {review.bestFor.map((item) => <li>{item}</li>)}
              </ul>
            </div>
            <div>
              <h2>ไม่เหมาะกับใคร</h2>
              <ul>
                {review.notFor.map((item) => <li>{item}</li>)}
              </ul>
            </div>
          </div>
        </section>

        <section id="capacity" class="content-block visual-block">
          <div>
            <span class="eyebrow">Capacity</span>
            <h2>{review.capacityLabel} ใช้กับบ้านแบบไหนถึงจะพอดี</h2>
            <p>
              {review.name} อยู่ในกลุ่ม {review.typeLabel} ขนาด {review.capacityLabel}
              ถ้าเป็นบ้านที่ทำอาหารบ่อย ให้คิดจากพื้นที่ช่องผัก ช่องขวดน้ำ และช่องฟรีซมากกว่าดูตัวเลขคิวอย่างเดียว
              ส่วนบ้านที่ซื้อของสดไม่เยอะ รุ่นใหญ่เกินไปอาจเปลืองพื้นที่และค่าไฟมากกว่าความจำเป็น
            </p>
          </div>
          <a {...imageLinkAttrs}>
            <img src={review.imageSet.capacityScene} alt="ภาพช่วยเลือกความจุตู้เย็น" loading="lazy" />
          </a>
        </section>

        <section id="score" class="content-block">
          <span class="eyebrow">Friendsay Score</span>
          <h2>คะแนนแบบ Friendsay</h2>
          <ScoreBars scores={scoreBars} />
          <p>
            คะแนนนี้ใช้ดูภาพรวม ไม่ใช่คำตัดสินสุดท้าย รุ่นที่คะแนนสูงมักมีจุดแข็งเรื่องความชัดของชื่อรุ่น ราคา และความเหมาะกับบ้านไทย
            แต่ถ้าพื้นที่วางไม่พอดีหรือร้านตอบเรื่องประกันไม่ชัด ก็ควรชะลอไว้ก่อน
          </p>
        </section>

        <section id="good" class="content-block">
          <span class="eyebrow">Good Points</span>
          <h2>ข้อดีที่ทำให้รุ่นนี้ควรอยู่ใน shortlist</h2>
          <div class="point-grid">
            {review.strengths.map((item) => (
              <div class="point-card">
                <strong>{item}</strong>
              </div>
            ))}
          </div>
        </section>

        <section id="watch" class="content-block">
          <span class="eyebrow">Watchouts</span>
          <h2>จุดระวังก่อนกดซื้อ</h2>
          <div class="point-grid point-grid--warn">
            {review.watchouts.map((item) => (
              <div class="point-card">
                <strong>{item}</strong>
              </div>
            ))}
          </div>
        </section>

        <section id="cost" class="content-block">
          <span class="eyebrow">Real Cost</span>
          <h2>ต้นทุนจริงไม่ได้มีแค่ราคาเครื่อง</h2>
          <p>
            ราคาอ้างอิงของรุ่นนี้คือ {review.priceLabel} แต่เวลาซื้อออนไลน์ให้รวมค่าส่ง ค่ายกขึ้นชั้น ค่ากำจัดตู้เก่า
            และความเสี่ยงเรื่องการเปลี่ยนคืน ถ้าโปรถูกมากแต่ร้านไม่ตอบเรื่องขนส่งและประกันให้ชัด รุ่นที่แพงกว่านิดหน่อยอาจสบายใจกว่า
          </p>
        </section>

        <section id="space" class="content-block visual-block">
          <div>
            <span class="eyebrow">Space Check</span>
            <h2>วัดพื้นที่วางให้จบก่อนดูสีและโปร</h2>
            <p>
              ตู้เย็นต้องมีพื้นที่ระบายความร้อน และต้องเปิดประตูได้สุดพอให้ดึงลิ้นชักหรือชั้นวางออกมาได้ ถ้าทางเข้าบ้านแคบ
              ให้ถามร้านเรื่องขนาดกล่องและบริการยกขึ้นชั้นก่อน โดยเฉพาะรุ่นขนาด {review.capacityLabel}
            </p>
          </div>
          <a {...imageLinkAttrs}>
            <img src={review.imageSet.spaceScene} alt="ภาพวัดช่องวางตู้เย็น" loading="lazy" />
          </a>
        </section>

        <section id="warranty" class="content-block visual-block">
          <div>
            <span class="eyebrow">Warranty</span>
            <h2>ประกันคือเรื่องที่ต้องถามก่อน ไม่ใช่หลังเสีย</h2>
            <p>
              ให้ถามร้านว่าเป็นสินค้าใหม่ศูนย์ไทยหรือไม่ รับประกันตัวเครื่องและคอมเพรสเซอร์กี่ปี ต้องลงทะเบียนเองไหม
              และกรณีซื้อผ่านร้านออนไลน์ ใครเป็นผู้ประสานงานเคลม ถ้าคำตอบคลุมเครือให้เก็บแชตไว้ก่อนตัดสินใจ
            </p>
          </div>
          <a {...imageLinkAttrs}>
            <img src={review.imageSet.warrantyScene} alt="ภาพเอกสารประกันและค่าไฟตู้เย็น" loading="lazy" />
          </a>
        </section>

        <section id="compare" class="content-block">
          <span class="eyebrow">Compare</span>
          <h2>ถ้ายังลังเล ให้เทียบกับรุ่นใกล้กันก่อน</h2>
          <p>
            วิธีเทียบง่ายที่สุดคือเอา {review.brand} {review.model} ไปเทียบกับตู้เย็นขนาดใกล้กันในงบเดียวกัน
            ดู 4 อย่างพร้อมกัน: ความจุจริง ประเภทตู้ ค่าไฟ และเงื่อนไขหลังการขาย อย่าเทียบจากราคาหน้าโปรอย่างเดียว
          </p>
          <a class="compare-link" href="/th/reviews/refrigerators/">กลับไปดูคลังตู้เย็น 28 รุ่น</a>
        </section>

        <section id="shop-questions" class="content-block">
          <span class="eyebrow">Ask Before Pay</span>
          <h2>6 คำถามที่ควรถามร้านก่อนซื้อ</h2>
          <div class="question-list">
            {review.questions.map((item, index) => (
              <div>
                <span>{index + 1}</span>
                <p>{item}</p>
              </div>
            ))}
          </div>
        </section>

        <section id="price" class="content-block price-check">
          <span class="eyebrow">Price Check</span>
          <h2>เช็กราคาล่าสุด</h2>
          <p>
            ราคาหน้าโปรเปลี่ยนได้ตลอด ก่อนกดซื้อให้ดูชื่อรุ่น สี ความจุ รหัสท้ายรุ่น ค่าขนส่ง ยกขึ้นชั้น ประกัน และเงื่อนไขเปลี่ยนคืนให้ตรงกัน
            ร้านที่ตอบคำถามครบและมีรีวิวล่าสุดให้อ่านชัด มักน่าไว้ใจกว่าร้านที่ถูกกว่าเล็กน้อยแต่ข้อมูลคลุมเครือ
          </p>
          <PriceButtons links={review.links} label={`เช็กราคา ${review.name}`} context={`refrigerator-price-${review.productKey}`} />
        </section>

        <section id="faq" class="content-block faq-block">
          <span class="eyebrow">FAQ</span>
          <h2>คำถามที่เจอบ่อย</h2>
          <details open>
            <summary>{review.capacityLabel} พอกับบ้านกี่คน?</summary>
            <p>ขึ้นกับนิสัยซื้อของ ถ้าซื้อของสดบ่อยและแช่เยอะ ให้ขยับขนาดขึ้นจากที่คิดไว้เล็กน้อย แต่ถ้ากินข้างนอกบ่อย ขนาดกลางมักพอแล้ว</p>
          </details>
          <details>
            <summary>ซื้อผ่าน Shopee ต้องระวังอะไร?</summary>
            <p>ระวังชื่อรุ่น สี ประกันศูนย์ไทย ค่าขนส่ง ยกขึ้นชั้น และเงื่อนไขเปลี่ยนคืนเมื่อเจอรอยบุบหรือเครื่องมีปัญหา</p>
          </details>
          <details>
            <summary>ควรเสียบปลั๊กทันทีหลังรับของไหม?</summary>
            <p>ควรดูคู่มือของรุ่นนั้น ๆ ก่อน โดยทั่วไปตู้เย็นที่ผ่านการขนส่งควรตั้งให้นิ่งก่อนเสียบปลั๊ก เพื่อให้น้ำยาทำความเย็นและระบบภายในเข้าที่</p>
          </details>
        </section>

