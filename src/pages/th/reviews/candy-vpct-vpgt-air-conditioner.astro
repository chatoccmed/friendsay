---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PriceButtons from "../../../components/PriceButtons.astro";
import ScoreBars from "../../../components/ScoreBars.astro";
import { candyAirConditioner as product } from "../../../data/airConditioners";

const premiumHeroImage = "/images/air-conditioners/candy-vpct-premium-hero.png";
const productShowcaseImage = "/images/air-conditioners/candy-vpct-product-showcase.png";

const decisionCards = [
  {
    label: "ซื้อได้ ถ้า",
    title: "คุณอยากได้แอร์อินเวอร์เตอร์ราคาเริ่มดีและรีวิวเยอะ",
    body: "จุดที่ทำให้รุ่นนี้น่าสนใจคือฐานรีวิวใหญ่พอให้ดูภาพจริงได้หลายมุม เหมาะกับคนที่อยากเริ่มจากตัวเลือกที่มี social proof แข็งแรง"
  },
  {
    label: "รอก่อน ถ้า",
    title: "คุณยังไม่รู้ว่าห้องควรใช้กี่ BTU หรือคิวช่างว่างเมื่อไหร่",
    body: "แอร์ไม่เหมือนของชิ้นเล็ก ซื้อผิดแล้วแก้ยากกว่า ควรถามเรื่อง BTU จุดวางคอยล์ร้อน และวันติดตั้งก่อนจ่ายเงิน"
  },
  {
    label: "ข้ามได้ ถ้า",
    title: "คุณอยากได้เงื่อนไขติดตั้ง/ประกันแบบชัดที่สุดตั้งแต่หน้าแรก",
    body: "รุ่นนี้ยังต้องอ่านรายละเอียดและถามร้านเพิ่ม โดยเฉพาะค่าอุปกรณ์ติดตั้งและความต่างของรุ่นย่อย VPCT/VPGT"
  }
];

const buyerScenes = [
  {
    label: "คอนโด 1 ห้องนอน",
    fit: "เริ่มดู 9,000-12,000 BTU",
    note: "ถ้าแดดไม่แรงและปิดประตูห้องเป็นหลัก รุ่นเล็ก-กลางมักพอ แต่ต้องเช็กจุดวางคอยล์ร้อนกับนิติบุคคลก่อน"
  },
  {
    label: "ห้องรับแดดบ่าย",
    fit: "ขยับ BTU เผื่อความร้อน",
    note: "ห้องที่กระจกใหญ่หรือโดนแดดตรงไม่ควรเลือกจากตารางพื้นที่อย่างเดียว เพราะเครื่องอาจทำงานหนักกว่าห้องปกติ"
  },
  {
    label: "บ้านที่รีบใช้",
    fit: "ถามคิวช่างก่อนกดซื้อ",
    note: "ถ้าต้องใช้ทันที อย่าดูแค่ราคาหน้าสินค้า ให้ถามวันติดตั้งจริงและค่าอุปกรณ์เพิ่มก่อน"
  },
  {
    label: "คนเน้นสบายใจ",
    fit: "เทียบประกันกับ TCL/Xiaomi/Midea",
    note: "ถ้าให้ความสำคัญกับศูนย์บริการมากกว่าราคา ให้ดูร้าน official เงื่อนไขประกัน และขั้นตอนเคลมควบคู่กัน"
  }
];

const visualGuides = [
  {
    href: "#btu",
    image: "/images/air-conditioners/wall-ac-btu-bedroom.png",
    alt: "ห้องนอนคอนโดพร้อมแอร์ติดผนังและสายวัดสำหรับประเมิน BTU",
    label: "BTU fit",
    title: "เริ่มจากขนาดห้อง ไม่ใช่เริ่มจากราคา",
    body: "ภาพนี้ใช้แทนโจทย์ที่คนซื้อเจอจริง: ห้องโดนแดดแค่ไหน กว้างเท่าไหร่ และควรขยับ BTU ไหม"
  },
  {
    href: "#install",
    image: "/images/air-conditioners/wall-ac-installation-check.png",
    alt: "ช่างกำลังติดตั้งแอร์ติดผนังพร้อมอุปกรณ์ท่อทองแดงและรางครอบท่อ",
    label: "Install risk",
    title: "งานติดตั้งคือต้นทุนที่มองไม่เห็น",
    body: "ท่อทองแดง รางครอบท่อ ขาแขวน และคิวช่างคือสิ่งที่ควรถามก่อนจ่าย ไม่ใช่ค่อยรู้ตอนหน้างาน"
  },
  {
    href: "#cost",
    image: "/images/air-conditioners/wall-ac-cost-warranty.png",
    alt: "โต๊ะวางรีโมตแอร์ เครื่องคิดเลข เอกสารรับประกัน และท่อแอร์สำหรับเช็กต้นทุนจริง",
    label: "True cost",
    title: "ราคาสุดท้ายคือเครื่อง + ติดตั้ง + ประกัน",
    body: "คนซื้อควรเก็บหน้าสินค้า ใบเสร็จ serial และเงื่อนไขประกันไว้ครบตั้งแต่วันแรก"
  }
];

const costChecks = [
  { label: "ราคาเครื่อง", value: "ประมาณ 7,995 บาท", note: "ตัวเลขที่พบหลังคูปอง ณ วันเก็บข้อมูล ราคาเปลี่ยนได้" },
  { label: "ติดตั้ง", value: "ต้องเช็กว่ารวมไหม", note: "ถ้าซื้อบริการติดตั้งเสริม ต้องดูวันนัดและขอบเขตงานมาตรฐาน" },
  { label: "อุปกรณ์เพิ่ม", value: "ถามก่อนจ่าย", note: "รางครอบท่อ ขาแขวน สายไฟ ท่อยาวเกิน และงานเจาะพิเศษอาจมีค่าเพิ่ม" },
  { label: "ประกัน", value: "1 ปี / 5 ปี", note: "ข้อมูลหน้าสินค้าพูดถึงตัวเครื่อง 1 ปีและคอมเพรสเซอร์ 5 ปี ควรยืนยันกับร้าน" }
];

const askBeforeBuy = [
  "รุ่นที่เลือกคือ VPCT หรือ VPGT และ BTU เท่าไหร่",
  "ราคานี้รวมติดตั้งหรือเป็นราคาเครื่องอย่างเดียว",
  "ติดตั้งได้เร็วสุดวันไหน และถ้าเลื่อนนัดต้องติดต่อใคร",
  "ท่อทองแดง สายไฟ รางครอบท่อ และขาแขวนรวมกี่เมตร",
  "คอนโดต้องมีเอกสารหรือข้อกำหนดอะไรให้ช่างก่อนเข้าหน้างาน",
  "ประกันต้องลงทะเบียนไหม และเคลมผ่านร้านหรือศูนย์บริการ"
];

const alternativeCards = [
  { name: "CANDY VPCT/VPGT", role: "ตัวคุ้มที่รีวิวเยอะ", note: "เหมาะเริ่ม shortlist เพราะฐานรีวิวใหญ่และราคาเปิดดูเป็นมิตร" },
  { name: "TCL SaveIN AI", role: "ตัวฟีเจอร์เยอะ", note: "น่าดูถ้าสนใจ AI/Full DC Inverter และ BTU กว้างถึง 24,200" },
  { name: "Xiaomi Mijia Eco", role: "ตัวสายแอป", note: "เหมาะกับคนใช้ Xiaomi Home และอยากดูข้อมูลผ่านระบบ smart home" },
  { name: "Midea Celest", role: "ตัวประกันน่าสนใจ", note: "รีวิวไม่เยอะเท่า CANDY/TCL แต่มีจุดขายเรื่องประกันและ SEER ในรายละเอียด" }
];

const faqs = [
  {
    question: "CANDY VPCT/VPGT Series น่าซื้อไหม",
    answer:
      "น่าซื้อสำหรับคนที่ต้องการแอร์อินเวอร์เตอร์ราคายังจับต้องได้และอยากเริ่มจากรุ่นที่มีรีวิว Shopee จำนวนมาก แต่ควรเช็ก BTU รุ่นย่อย ค่าอุปกรณ์ติดตั้ง และวันนัดช่างก่อนกดซื้อ"
  },
  {
    question: "รุ่นนี้เหมาะกับห้องขนาดไหน",
    answer:
      "หน้าสินค้ามีตัวเลือกประมาณ 9,000, 12,000, 18,000 และ 23,200 BTU โดยควรเลือกจากขนาดห้อง ทิศแดด ความสูงฝ้า จำนวนคน และการใช้งานกลางวัน ไม่ควรเลือกจากพื้นที่ห้องอย่างเดียว"
  },
  {
    question: "ราคาที่เห็นรวมติดตั้งไหม",
    answer:
      "ต้องเช็กหน้าร้านและตัวเลือกบริการติดตั้งทุกครั้ง เพราะราคาหน้าโปรอาจเป็นราคาเครื่อง ส่วนบริการติดตั้งและค่าอุปกรณ์เพิ่มอาจมีเงื่อนไขแยก"
  },
  {
    question: "ทำไม Friendsay ไม่เขียนว่ายอดขายกี่เครื่อง",
    answer:
      "เพราะหน้าที่เก็บข้อมูลยังไม่แสดงยอดขายจริงชัดเจน เราจึงใช้สถานะ review_signal_pass จากคะแนนและรีวิวแทน เพื่อไม่เติมตัวเลขเอง"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: product.name,
    brand: {
      "@type": "Brand",
      name: product.brand
    }
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: product.score,
    bestRating: 10
  },
  author: {
    "@type": "Organization",
    name: "Friendsay"
  },
  inLanguage: "th",
  dateModified: product.updated,
  isBasedOn: product.sourceUrl
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title={`รีวิว ${product.name} | แอร์อินเวอร์เตอร์ Shopee 2026 | Friendsay`}
  description={`รีวิวละเอียด ${product.name} จากข้อมูล Shopee และสัญญาณรีวิวผู้ซื้อจริง สรุปว่าเหมาะกับใคร เลือก BTU ยังไง ต้องระวังเรื่องติดตั้งและประกันตรงไหน`}
  canonical="https://friendsay.com/th/reviews/candy-vpct-vpgt-air-conditioner/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="air-review-hero">
    <img src={premiumHeroImage} alt={`ภาพ ${product.name} ในห้องคอนโดสว่างสบาย`} loading="eager" />
    <div class="air-review-shade" aria-hidden="true"></div>
    <div class="container air-review-hero-inner">
      <div class="air-review-title">
        <p class="eyebrow">Research review / Shopee Thailand 2026</p>
        <h1>รีวิว {product.name}: ตัวคุ้มที่น่าซื้อ ถ้าคุณเช็กติดตั้งให้จบก่อน</h1>
        <p>
          ไม่ใช่รีวิวแบบชมอย่างเดียว รุ่นนี้น่าสนใจจริงจากฐานรีวิวและราคา แต่คำถามที่ทำให้ซื้อแล้วไม่พลาดคือ:
          ห้องคุณควรใช้กี่ BTU, ราคานี้รวมอะไรบ้าง, และช่างจะติดตั้งได้เมื่อไหร่
        </p>
        <div class="air-review-actions">
          <a class="button button-primary" href="#verdict">ดูคำตอบ 30 วินาที</a>
          <a class="button button-dark" href="#questions">เช็กลิสต์ก่อนซื้อ</a>
        </div>
      </div>

      <aside class="air-verdict-card">
        <div class="air-product-card-image">
          <img src={productShowcaseImage} alt={`ภาพสินค้า ${product.name} พร้อมชุดติดตั้ง`} loading="eager" />
        </div>
        <span class="badge badge-coral">{product.statusLabel}</span>
        <strong>{product.score.toFixed(1)}/10</strong>
        <p>
          คำตอบสั้นๆ: น่าดูมาก แต่ต้องซื้อแบบมีเช็กลิสต์ ไม่ใช่กดเพราะเห็นราคาโปรอย่างเดียว
        </p>
        <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />
      </aside>
    </div>
  </section>

  <section class="roundup-signal-band">
    <div class="wide-container roundup-signals">
      <div>
        <span>คะแนน Shopee</span>
        <strong>{product.rating.toFixed(1)}/5</strong>
      </div>
      <div>
        <span>จำนวนคะแนน</span>
        <strong>{product.ratingsCount.toLocaleString("th-TH")}+</strong>
      </div>
      <div>
        <span>คอมเมนต์</span>
        <strong>{product.commentsCount.toLocaleString("th-TH")}+</strong>
      </div>
      <div>
        <span>สถานะยอดขาย</span>
        <strong>ยังไม่เห็นตัวเลขขาย</strong>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container article-layout">
      <article class="article-body">
        <div class="air-note">
          <strong>ความโปร่งใสก่อนอ่าน</strong>
          <p>
            บทความนี้เป็น Research Review จากข้อมูลหน้าสินค้า Shopee และรีวิวผู้ซื้อที่มองเห็นในวันที่ 15 มิถุนายน 2026
            เรายังไม่ได้ทดสอบระยะยาวด้วยตัวเอง และยอดขายจริงไม่ได้แสดงชัดบนหน้าที่เก็บข้อมูล จึงจัดสถานะเป็น
            <strong>review_signal_pass</strong> ไม่ใช่ <strong>verified_sold</strong>. ถ้าหน้า Shopee แสดงยอดขายภายหลัง
            บทความนี้ควรอัปเดตตัวเลขใหม่ก่อนใช้เป็นรีวิวฉบับสมบูรณ์
          </p>
        </div>

        <section class="air-product-snapshot" aria-label="ภาพสินค้าและสิ่งที่ควรเช็กก่อนซื้อ">
          <figure>
            <img src={productShowcaseImage} alt={`ภาพสินค้า ${product.name} พร้อมคอยล์ร้อน รีโมต และชุดท่อแอร์`} loading="lazy" />
          </figure>
          <div>
            <p class="eyebrow">Product look</p>
            <h2>เห็นหน้าตาตัวเครื่องก่อน แล้วค่อยตัดสินใจเรื่องราคา</h2>
            <p>
              ภาพนี้ทำใหม่จากภาพอ้างอิงสินค้าจริง เพื่อให้เห็นทรงตัวเครื่อง ชุดคอยล์ร้อน รีโมต และอุปกรณ์ที่ควรถามร้านก่อนซื้อในมุมเดียว
            </p>
            <div class="air-snapshot-pills" aria-label="จุดที่ควรดูจากภาพสินค้า">
              <span>ตัวเครื่องในบ้าน</span>
              <span>คอยล์ร้อน</span>
              <span>รีโมต</span>
              <span>ท่อและอุปกรณ์ติดตั้ง</span>
            </div>
          </div>
        </section>

        <section class="air-decision-section" id="verdict">
          <p class="eyebrow">30-second verdict</p>
          <h2>คำตอบแบบไม่อ้อม: รุ่นนี้น่าดูมาก แต่ต้องซื้อให้ถูกเงื่อนไข</h2>
          <div class="air-decision-grid">
            {decisionCards.map((item) => (
              <article>
                <span>{item.label}</span>
                <h3>{item.title}</h3>
                <p>{item.body}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="air-visual-strip" aria-label="ภาพช่วยตัดสินใจก่อนซื้อ">
          {visualGuides.map((item) => (
            <a class="air-media-card" href={item.href}>
              <img src={item.image} alt={item.alt} loading="lazy" />
              <div>
                <span>{item.label}</span>
                <strong>{item.title}</strong>
                <p>{item.body}</p>
              </div>
            </a>
          ))}
        </section>

        <div class="air-quick-grid air-fit-grid">
          <div class="soft-card">
            <h2>เหมาะกับใคร</h2>
            <p>{product.bestFor}</p>
          </div>
          <div class="soft-card">
            <h2>ไม่เหมาะกับใคร</h2>
            <p>{product.notFor}</p>
          </div>
        </div>

        <section class="air-real-life-section" id="scenes">
          <p class="eyebrow">Real-life fit</p>
          <h2>ถ้าเป็นห้องของคุณ ควรคิดแบบไหน</h2>
          <div class="air-scene-grid">
            {buyerScenes.map((scene) => (
              <article>
                <span>{scene.label}</span>
                <strong>{scene.fit}</strong>
                <p>{scene.note}</p>
              </article>
            ))}
          </div>
        </section>

        <h2 id="summary">สรุปก่อนอ่านยาว</h2>
        <p>
          ถ้าดูจากสัญญาณบน Shopee, {product.name} เป็นหนึ่งในรุ่นที่ควรถูกหยิบขึ้นมารีวิวก่อนในหมวดแอร์ติดผนัง
          เพราะมีฐานรีวิวเยอะมากเมื่อเทียบกับสินค้าหลายรุ่นในหมวดเดียวกัน คะแนนเฉลี่ยอยู่ที่ {product.rating.toFixed(1)}/5,
          มีจำนวนคะแนนระดับหมื่น มีคอมเมนต์หลักพัน และมีรีวิวพร้อมรูปหรือวิดีโอจำนวนมากพอให้ดูงานติดตั้งจริงได้หลายมุม
          สำหรับสินค้าอย่างแอร์ สัญญาณเหล่านี้สำคัญมาก เพราะหน้าสเปกบอกได้แค่ว่าเครื่องทำอะไรได้บ้าง แต่รีวิวผู้ซื้อจะบอกว่า
          ของมาถึงจริงไหม นัดติดตั้งราบรื่นหรือเปล่า เย็นไวอย่างที่โฆษณาไหม และร้านดูแลหลังขายดีแค่ไหน
