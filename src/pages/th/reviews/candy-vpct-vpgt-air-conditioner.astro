const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: product.name,
    brand: {
      "@type": "Brand",
      name: product.brand
    }
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: product.score,
    bestRating: 10
  },
  author: {
    "@type": "Organization",
    name: "Friendsay"
  },
  inLanguage: "th",
  dateModified: product.updated,
  isBasedOn: product.sourceUrl
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
      "@type": "Answer",
      text: faq.answer
    }
  }))
};
---

<BaseLayout
  title={`รีวิว ${product.shortName}: แอร์รีวิวเยอะ คุ้มจริงไหมเมื่อรวมค่าติดตั้ง? | Friendsay`}
  description={`รีวิว ${product.name} แอร์อินเวอร์เตอร์ Shopee 2026 สรุปคุ้มจริงไหม เหมาะกับห้องแบบไหน เลือก BTU ยังไง ต้องเช็กค่าติดตั้ง ประกัน และรีวิวผู้ซื้อจุดไหนก่อนกดซื้อ`}
  canonical="https://friendsay.com/th/reviews/candy-vpct-vpgt-air-conditioner/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="air-review-hero">
    <img src={premiumHeroImage} alt={`ภาพ ${product.name} ในห้องคอนโดสว่างสบาย`} loading="eager" />
    <div class="air-review-shade" aria-hidden="true"></div>
    <div class="container air-review-hero-inner">
      <div class="air-review-title">
        <p class="eyebrow">คู่มือเลือกซื้อแบบเพื่อนช่วยดู / Shopee 2026</p>
        <h1>รีวิว {product.shortName}: แอร์รีวิวเยอะ คุ้มจริงไหมเมื่อรวมค่าติดตั้ง?</h1>
        <p>
          ถ้าเพื่อนส่งลิงก์รุ่นนี้มาให้ดู ผมจะยังไม่บอกว่า “กดเลย” แต่จะบอกว่า “เออ รุ่นนี้ควรเอาไว้เทียบ”
          เพราะรีวิวเยอะ ราคาเริ่มต้นดี และมีหลาย BTU ให้เลือก สิ่งที่ต้องถามให้จบคือ ห้องเราใช้กี่ BTU, ราคานี้รวมติดตั้งไหม, แล้วช่างมาได้วันไหน
        </p>
        <div class="air-review-actions">
          <a class="button button-primary" href="#buying-cockpit">ดูคำตอบ 90 วินาที</a>
          <a class="button button-dark" href="#review-proof">ดูรีวิวผู้ซื้อจริง</a>
        </div>
      </div>

      <aside class="air-verdict-card">
        <div class="air-product-card-image">
          <img src={productShowcaseImage} alt={`ภาพสินค้า ${product.name} พร้อมชุดติดตั้ง`} loading="eager" />
        </div>
        <span class="badge badge-coral">{product.statusLabel}</span>
        <strong>{product.score.toFixed(1)}/10</strong>
        <p>
          สั้น ๆ คือควรเก็บไว้เทียบครับ แต่ห้ามรีบเพราะราคาโปรอย่างเดียว ต้องถาม BTU ค่าติดตั้ง และประกันให้จบก่อน
        </p>
        <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />
      </aside>
    </div>
  </section>

  <section class="air-decision-cockpit" id="buying-cockpit" aria-label="สรุปตัดสินใจซื้อแบบเร็ว">
    <div class="wide-container air-cockpit-inner">
      <div class="air-cockpit-head">
        <p class="eyebrow">สรุปให้ก่อนเลือก</p>
        <h2>ตัดสินใจซื้อใน 90 วินาที</h2>
        <p>
