---

<BaseLayout
  title={`รีวิว ${product.name} | แอร์อินเวอร์เตอร์ Shopee 2026 | Friendsay`}
  description={`รีวิวละเอียด ${product.name} แบบเพื่อนช่วยดู จากข้อมูล Shopee และรีวิวผู้ซื้อจริง สรุปว่าเหมาะกับใคร เลือก BTU ยังไง ต้องถามเรื่องติดตั้งและประกันตรงไหนก่อนซื้อ`}
  canonical="https://friendsay.com/th/reviews/candy-vpct-vpgt-air-conditioner/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="air-review-hero">
    <img src={premiumHeroImage} alt={`ภาพ ${product.name} ในห้องคอนโดสว่างสบาย`} loading="eager" />
    <div class="air-review-shade" aria-hidden="true"></div>
    <div class="container air-review-hero-inner">
      <div class="air-review-title">
        <p class="eyebrow">คู่มือเลือกซื้อแบบเพื่อนช่วยดู / Shopee 2026</p>
        <h1>รีวิว {product.shortName}: แอร์ตัวคุ้มที่ต้องถามติดตั้งให้ชัด</h1>
        <p>
          ถ้าเพื่อนถามผมว่ารุ่นนี้น่าสนใจไหม คำตอบคือ “น่าดูมาก” เพราะรีวิวเยอะ ราคาเริ่มต้นดี และมีหลาย BTU ให้เลือก
          แต่แอร์ไม่ใช่ของที่กดซื้อแล้วจบง่ายๆ จุดที่ต้องถามก่อนคือห้องเราควรใช้กี่ BTU, ราคานี้รวมอะไรบ้าง, และช่างจะมาติดตั้งได้เมื่อไหร่
        </p>
        <div class="air-review-actions">
          <a class="button button-primary" href="#buying-cockpit">ดูคำตอบ 90 วินาที</a>
          <a class="button button-dark" href="#review-proof">ดูรีวิวผู้ซื้อจริง</a>
        </div>
      </div>

      <aside class="air-verdict-card">
        <div class="air-product-card-image">
          <img src={productShowcaseImage} alt={`ภาพสินค้า ${product.name} พร้อมชุดติดตั้ง`} loading="eager" />
        </div>
        <span class="badge badge-coral">{product.statusLabel}</span>
        <strong>{product.score.toFixed(1)}/10</strong>
        <p>
          คำตอบสั้นๆ: น่าดูมากครับ แต่ก่อนกดซื้อให้ถามเรื่อง BTU ค่าติดตั้ง และประกันให้จบก่อน อย่าให้ราคาโปรพาเรารีบเกินไป
        </p>
        <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />
      </aside>
    </div>
  </section>

  <section class="air-decision-cockpit" id="buying-cockpit" aria-label="สรุปตัดสินใจซื้อแบบเร็ว">
