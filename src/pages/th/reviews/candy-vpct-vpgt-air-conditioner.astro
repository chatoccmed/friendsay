        <a href="#compare">เทียบรุ่นอื่น</a>
        <a href="#questions">ถามร้านก่อนซื้อ</a>
        <a href="#buy">เช็กราคา</a>
        <a href="#faq">FAQ</a>
        <a href="#final">สรุป</a>
      </aside>
    </div>
  </section>
</BaseLayout>
