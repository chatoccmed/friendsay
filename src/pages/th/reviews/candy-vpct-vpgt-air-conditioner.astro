            <div>
              <span>{option}</span>
              <strong>{option.includes("23") ? "ห้องใหญ่หรือแดดแรง" : option.includes("18") ? "ห้องนั่งเล่น/ห้องนอนใหญ่" : option.includes("12") ? "ห้องนอนกลาง" : "ห้องเล็ก/คอนโด"}</strong>
            </div>
          ))}
        </div>

        <h2 id="good">ข้อดีที่เห็นจากข้อมูลและรีวิวผู้ซื้อ</h2>
        <p>
          อย่างแรกที่ทำให้รุ่นนี้น่าดูคือรีวิวเยอะพอให้เห็นภาพ ไม่ใช่สินค้าใหม่ที่ดาวสูงเพราะมีรีวิวแค่ไม่กี่รายการ
          ในหมวดแอร์ จำนวนรีวิวสำคัญกว่าหลายหมวด เพราะสินค้ามีหลายขั้นตอนหลังซื้อ ตั้งแต่ขนส่ง การนัดช่าง การติดตั้ง การใช้งานจริง
          ไปจนถึงการเคลม เมื่อมีรีวิวรูป/วิดีโอจำนวนมาก คนซื้อจะดูได้ว่ากล่องมาถึงสภาพไหน คอยล์ร้อนหน้าตาอย่างไร
          งานติดตั้งที่ผู้ซื้อได้จริงเรียบร้อยแค่ไหน และมีปัญหาซ้ำจุดใดหรือไม่
        </p>
        <p>
          อีกอย่างที่ดึงสายตาคือราคาเริ่มต้นของรุ่นนี้ดูเป็นมิตรกับคนที่อยากเปลี่ยนจากแอร์เก่าหรือเริ่มติดแอร์ห้องใหม่
          โดยเฉพาะถ้าดูรุ่น 9,000 หรือ 12,000 BTU สำหรับห้องนอน ราคาที่พบหลังคูปองทำให้รุ่นนี้ควรอยู่ในลิสต์เปรียบเทียบ
          แต่ราคาควรถูกอ่านพร้อมคำว่า “รวมอะไรบ้าง” เสมอ ถ้าราคาเครื่องถูกแต่ไม่รวมติดตั้ง หรือมีค่าอุปกรณ์เพิ่มหลายรายการ
          ราคาสุดท้ายอาจไม่ต่างจากรุ่นที่ราคาเริ่มต้นสูงกว่าแต่เงื่อนไขชัดกว่า
        </p>
        <p>
          จุดที่ผมชอบอีกข้อคือมีรุ่นย่อยหลาย BTU ทำให้แนะนำให้คนอ่านหลายแบบได้ง่าย เช่น คนอยู่คอนโด คนอยู่บ้านเดี่ยว
          คนต้องการห้องนั่งเล่น หรือคนอยากประหยัดงบสำหรับห้องนอนลูก ถ้าเราจะทำคลังรีวิวหมวดแอร์ให้ใหญ่จริง รุ่นแบบนี้เหมาะมากสำหรับทำเป็นบทความแม่
          เพราะคนอ่านจะเข้ามาด้วยคำถามต่างกัน แต่ยังอยู่ในตระกูลสินค้าเดียวกัน
        </p>

        <div class="verdict-grid">
          {product.pros.map((item) => (
            <div>
              <span>เด่น</span>
              <strong>{item}</strong>
            </div>
          ))}
        </div>

        <h2 id="watch">จุดต้องระวังก่อนกดซื้อ</h2>
        <p>
          จุดแรก ผมยังไม่อยากใส่ตัวเลขยอดขายเอง ถ้าหน้าร้านไม่ได้โชว์ให้เห็นชัดๆ แม้รุ่นนี้จะมีรีวิวเยอะมากก็ตาม
          เพราะเว็บรีวิวที่อยากให้คนไว้ใจต้องพูดเท่าที่ตรวจได้จริง อะไรที่ยังไม่เห็นชัดก็ควรบอกว่าไม่เห็นชัด
          แต่รีวิวจำนวนมากก็ยังมีประโยชน์มากพอสำหรับการประเมินว่า รุ่นนี้มีคนซื้อจริงและมีข้อมูลให้เราดูต่อได้เยอะ
        </p>
        <p>
          จุดที่สองคือชื่อรุ่น VPCT/VPGT Series และตัวเลือก BTU หลายแบบ ทำให้ต้องดูก่อนสั่งว่าเรากำลังเลือกตัวไหนอยู่
          บางหน้าสินค้าใน marketplace รวมหลายรุ่นย่อยไว้ในหน้าเดียว ทำให้คนซื้อกดเร็วแล้วได้สเปกไม่ตรงกับที่คิดได้ง่าย
          ก่อนจ่ายเงินควรถ่ายหน้าจอตัวเลือกที่เลือกไว้ เช็กชื่อรุ่น BTU ระบบอินเวอร์เตอร์ เงื่อนไขติดตั้ง และข้อมูลประกันให้ครบ
        </p>
        <p>
          จุดที่สามคือเรื่องติดตั้ง แม้การมี Q-CHANG หรือบริการนัดช่างจะช่วยให้สะดวกขึ้น
          แต่ก็ต้องดูรายละเอียดให้ชัด เช่น วันนัดจริงนานแค่ไหน ค่าอุปกรณ์มาตรฐานรวมอะไรบ้าง ต้องจ่ายเพิ่มกรณีท่อยาวเกินกี่เมตร
          มีค่าขาแขวนคอยล์ร้อนหรือไม่ และพื้นที่ติดตั้งของเราอนุญาตให้เจาะผนัง/วางคอยล์ร้อนตรงไหน ถ้าเป็นคอนโดควรคุยกับนิติบุคคลก่อน
          เพราะการติดตั้งแอร์มีผลกับอาคารและเพื่อนบ้านมากกว่าการซื้อเครื่องใช้ไฟฟ้าทั่วไป
        </p>

        <div class="air-watch-list">
          {product.watch.map((item) => <span>{item}</span>)}
        </div>

        <section class="air-cost-section" id="cost">
          <p class="eyebrow">เช็กเงินที่ต้องจ่ายจริง</p>
          <h2>ราคาเครื่องไม่ใช่ราคาสุดท้ายเสมอไป</h2>
          <p>
            คนซื้อแอร์พลาดตรงนี้กันบ่อยครับ เห็นราคาเครื่องแล้วคิดว่านี่คืองบทั้งหมด แต่จริงๆ ยังมีค่าติดตั้ง
            อุปกรณ์หน้างาน และความพร้อมของห้อง รุ่นนี้เลยควรถูกมองเป็น “ดีลที่น่าสนใจหลังคิดราคาจบแล้ว”
            ไม่ใช่ดีลที่ตัดสินได้ตั้งแต่เห็นตัวเลขแรก
          </p>
          <figure class="air-wide-figure">
            <img src="/images/air-conditioners/wall-ac-cost-warranty.png" alt="ภาพรีโมตแอร์ เครื่องคิดเลข เอกสารรับประกัน และท่อแอร์สำหรับประเมินต้นทุนจริง" loading="lazy" />
            <figcaption>
              สิ่งที่ควรรู้ก่อนจ่าย: ราคาเครื่องเป็นแค่จุดเริ่มต้น ต้องรวมค่าอุปกรณ์เพิ่ม เงื่อนไขติดตั้ง และหลักฐานประกันด้วย
            </figcaption>
          </figure>
          <div class="air-cost-grid">
            {costChecks.map((item) => (
              <article>
                <span>{item.label}</span>
                <strong>{item.value}</strong>
                <p>{item.note}</p>
              </article>
            ))}
          </div>
        </section>

        <h2 id="install">เรื่องติดตั้งคือหัวใจของรีวิวแอร์</h2>
        <p>
          ถ้าจะรีวิวแอร์ให้มีประโยชน์จริง ผมว่าเราต้องพูดเรื่องติดตั้งให้ละเอียดพอๆ กับตัวเครื่อง
          เพราะแอร์รุ่นเดียวกันอาจให้ประสบการณ์ต่างกันมากตามคุณภาพช่าง สภาพห้อง และอุปกรณ์ที่ใช้ การเดินท่อทองแดงไม่เรียบร้อย
          การเอียงท่อน้ำทิ้งไม่ดี หรือการวางคอยล์ร้อนในจุดอับ อาจทำให้เกิดน้ำหยด เสียงดัง กินไฟ หรือซ่อมยากในอนาคต
        </p>
        <figure class="air-wide-figure">
          <img src="/images/air-conditioners/wall-ac-installation-check.png" alt="ภาพช่างติดตั้งแอร์ติดผนังพร้อมระดับน้ำ ท่อทองแดง ท่อน้ำทิ้ง และรางครอบท่อ" loading="lazy" />
          <figcaption>
            งานติดตั้งที่ดีต้องคิดก่อนเจาะ: ระดับเครื่อง ท่อน้ำทิ้ง ท่อทองแดง รางครอบท่อ และจุดวางคอยล์ร้อนมีผลกับการใช้งานระยะยาว
          </figcaption>
        </figure>
        <p>
          สำหรับรุ่นนี้ หน้าสินค้าระบุบริการติดตั้งเสริมและมีรายละเอียดว่าหลังสั่งซื้อจะมีการติดต่อเพื่อนัดหมาย
          สิ่งที่อยากเตือนแบบตรงๆ คืออย่าคิดว่ากดซื้อวันนี้แล้วช่างจะมาติดตั้งพรุ่งนี้เสมอไป โดยเฉพาะช่วงหน้าร้อนหรือช่วงแคมเปญใหญ่
          ถ้าห้องจำเป็นต้องใช้ทันที เช่น ห้องเด็ก ห้องผู้สูงอายุ หรือห้องทำงานที่ร้อนมาก ควรทักร้านหรือเช็กคิวช่างก่อนจ่ายเงิน
        </p>
        <ul class="air-checklist">
          {product.installNotes.map((item) => <li>{item}</li>)}
        </ul>

        <h2 id="warranty">ประกันและความสบายใจหลังซื้อ</h2>
        <p>
          แอร์เป็นของที่ไม่ได้วัดความคุ้มแค่วันแรก แต่ต้องดูหลังใช้ไปหลายเดือนและหลายปีด้วย
          ข้อมูลที่พบใน Shopee มีทั้งส่วนสเปกที่ระบุประกัน 12 เดือน และรายละเอียดคำอธิบายที่พูดถึงตัวเครื่อง 1 ปี คอมเพรสเซอร์ 5 ปี
          จุดนี้ไม่ได้แปลว่ามีปัญหา แต่แปลว่าเราควรถามให้ชัดก่อนซื้อว่าเงื่อนไขจริงคืออะไร ใครเป็นผู้รับประกัน ใช้ใบเสร็จแบบไหน
          ต้องลงทะเบียนหรือไม่ และถ้าเครื่องมีปัญหาหลังติดตั้งต้องติดต่อร้าน ช่าง หรือศูนย์บริการช่องทางใด
        </p>
        <p>
          คำแนะนำแบบเพื่อนคือ เก็บทุกอย่างไว้ครับ ตั้งแต่หน้าสินค้า ราคา ตัวเลือก BTU ใบเสร็จ เลข serial
          รูปกล่อง รูปจุดติดตั้ง และข้อความคุยกับร้าน ถ้ามีปัญหาในอนาคต สิ่งเหล่านี้ช่วยลดเวลาคุยและเพิ่มโอกาสได้บริการที่ถูกต้อง
          โดยเฉพาะแอร์ที่ติดตั้งกับผนังและมีคอยล์ร้อนภายนอก การเคลมอาจเกี่ยวข้องกับทั้งตัวเครื่องและงานติดตั้ง
        </p>
        <ul class="air-checklist">
          {product.warrantyNotes.map((item) => <li>{item}</li>)}
        </ul>

        <h2 id="review-signals">เสียงผู้ซื้อจริงบอกอะไรบ้าง</h2>
        <p>
          อ่านรีวิวหลายอันแล้วภาพรวมที่เห็นคือ คนซื้อจำนวนมากพูดถึงความเย็นเร็ว ความคุ้มค่า และใช้งานสบาย
          บางรีวิวชมเรื่องเสียงเงียบและดีไซน์ ซึ่งเป็นสองเรื่องที่คนอยู่คอนโดหรือใช้ในห้องนอนสนใจมาก
          แต่ผมอยากให้อ่านรีวิวบวกคู่กับรีวิวที่พูดเรื่องติดตั้งเสมอ เพราะความเย็นของเครื่องคือครึ่งหนึ่งของประสบการณ์
          อีกครึ่งคือการนัดช่าง ความเรียบร้อยของงาน และราคาจริงหลังติดตั้งเสร็จ
        </p>
        <p>
          เวลาสรุปรีวิว ผมจะไม่หยิบรีวิวเดียวมาตัดสินทั้งรุ่น แต่จะดูว่าเรื่องไหนมีคนพูดซ้ำๆ
          ถ้าหลายคนพูดว่าเย็นไวในห้องขนาดใกล้เคียงกัน เราก็พอเขียนเป็นจุดเด่นได้มั่นใจกว่า
          ถ้ามีคนพูดเรื่องคิวนัดติดตั้งช้าในบางช่วง เราก็เขียนเป็นจุดที่ควรถามร้าน ไม่ใช่ตัดสินว่าบริการแย่ทั้งหมด
          วิธีนี้แฟร์กับทั้งคนอ่านและตัวสินค้า
        </p>
        <div class="source-grid air-source-grid">
          {product.reviewSignals.map((item, index) => (
            <article>
              <span>{String(index + 1).padStart(2, "0")}</span>
              <h3>{item}</h3>
              <p>เป็นเรื่องที่ควรอ่านต่อในรีวิวจริง แล้วดูว่ามีคนพูดซ้ำมากแค่ไหน</p>
            </article>
          ))}
        </div>

        <h2 id="compare">เมื่อเทียบกับ TCL, Xiaomi และ Midea ในรอบแรก</h2>
        <p>
          ถ้าเทียบเฉพาะ 4 รุ่นที่เราเก็บข้อมูลรอบแรก CANDY และ TCL เป็นสองรุ่นที่รีวิวแน่นที่สุด
          เลยเหมาะจะเป็นตัวหลักในบทความ “แอร์อินเวอร์เตอร์รุ่นไหนดีใน Shopee 2026” มากกว่า Midea ที่รีวิวยังน้อยกว่า
          ส่วน Xiaomi เหมาะกับคนที่ชอบระบบแอปและ smart home แต่ต้องชั่งกับความคุ้นเคยของศูนย์บริการในพื้นที่
          ถ้าพูดง่ายๆ CANDY อยู่ฝั่ง “คุ้มค่า รีวิวเยอะ” ส่วน TCL อยู่ฝั่ง “แบรนด์เด่น ฟีเจอร์เยอะ BTU กว้าง”
          สองรุ่นนี้ควรถูกจับเทียบกันแบบละเอียดมากเป็นพิเศษ
        </p>
        <p>
          สำหรับคนซื้อทั่วไป ถ้าต้องการตัดสินเร็ว ผมจะเริ่มจากคำถามสามข้อ:
          หนึ่ง ห้องคุณควรใช้กี่ BTU จริงๆ สอง คุณอยากซื้อแบบรวมติดตั้งเลยหรือซื้อเครื่องแล้วหาช่างเอง
          สาม คุณให้ความสำคัญกับแบรนด์ ศูนย์บริการ และประกันมากแค่ไหน ถ้าตอบสามข้อนี้ได้ การเลือกจะง่ายกว่าการไล่ดูดาวทีละรุ่นมาก
        </p>
        <div class="air-alternative-grid">
          {alternativeCards.map((item) => (
            <article class={item.name.startsWith("CANDY") ? "is-current" : ""}>
              <span>{item.role}</span>
              <strong>{item.name}</strong>
              <p>{item.note}</p>
            </article>
          ))}
        </div>

        <section class="air-questions-section" id="questions">
          <p class="eyebrow">ก่อนกดซื้อ</p>
          <h2>ก่อนกดซื้อ ให้ถามร้าน 6 ข้อนี้</h2>
          <p>
            ถ้าร้านตอบได้ชัด คุณจะซื้อสบายใจกว่าเดิมเยอะ แต่ถ้าตอบคลุมเครือหรือเลี่ยงคำถาม
            ต่อให้ราคาดีแค่ไหนก็ควรชะลอก่อน เพราะปัญหาแอร์ส่วนใหญ่ไม่ได้เกิดตอนกดสั่งซื้อ แต่มักเกิดตอนติดตั้งและตอนเคลม
          </p>
          <ol class="air-question-list">
            {askBeforeBuy.map((item) => <li>{item}</li>)}
          </ol>
        </section>

        <h2 id="buy">ควรซื้อช่องทางไหนดี</h2>
        <p>
          ใช้ปุ่มด้านล่างเปิดเทียบราคาหลายช่องทางก่อนครับ อย่ารีบกดร้านแรกที่เห็นราคาถูกที่สุด
          ให้ดูว่าร้านระบุรุ่นย่อยและ BTU ชัดไหม รีวิวจริงเยอะไหม เงื่อนไขติดตั้งอ่านแล้วเข้าใจไหม และประกันไม่คลุมเครือหรือเปล่า
          ถ้าราคาใกล้กัน ผมจะเลือกร้านที่ตอบคำถามชัดกว่า เพราะแอร์เป็นของที่บริการหลังซื้อสำคัญพอๆ กับราคา
        </p>
        <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />

        <h2 id="final">สรุปแบบ Friendsay</h2>
        <p>
          {product.name} เป็นรุ่นที่ควรเข้าลิสต์แรกของหมวดแอร์ Shopee 2026 เพราะรีวิวเยอะพอให้ดูได้หลายมุม
          ราคาเปิดดูน่าสนใจ และมีตัวเลือก BTU ครอบคลุมห้องหลายขนาด แต่รุ่นนี้ไม่ควรถูกเล่าแบบขายฝันว่า “ถูกและดี จบ”
          จุดที่ต้องทำให้ชัดคือเลือก BTU ให้ตรงห้อง เช็กว่าราคารวมติดตั้งหรือไม่ อ่านเงื่อนไข Q-CHANG/ช่างให้ละเอียด
          และเก็บหลักฐานประกันให้ครบตั้งแต่แรก
        </p>
        <p>
          ถ้าเพื่อนถามว่าควรซื้อไหม ผมจะตอบว่า “น่าดูมาก แต่ต้องถามร้านให้จบก่อน”
          ถ้าคุณเลือก BTU ถูก ร้านชัด คิวติดตั้งรับได้ และค่าอุปกรณ์เพิ่มไม่บาน รุ่นนี้มีเหตุผลมาก
          แต่ถ้าคุณรีบใช้ในไม่กี่วัน ไม่สะดวกคุยเรื่องติดตั้ง หรืออยากได้เงื่อนไขประกันแบบชัดที่สุดตั้งแต่หน้าแรก
          ควรเทียบ TCL, Xiaomi, Midea หรือร้าน official อื่นก่อนตัดสินใจอีกที
        </p>

        <section class="air-faq-section" id="faq">
          <p class="eyebrow">FAQ</p>
          <h2>คำถามที่คนกำลังจะซื้อแอร์รุ่นนี้น่าจะอยากรู้</h2>
          <div class="air-faq-list">
            {faqs.map((faq) => (
              <details>
                <summary>{faq.question}</summary>
                <p>{faq.answer}</p>
              </details>
            ))}
          </div>
        </section>

        <div class="air-note">
          <strong>แหล่งข้อมูลที่ใช้ในรอบนี้</strong>
          <p>
            ข้อมูลหลักมาจากหน้า Shopee ของรุ่นนี้:
            <a href={product.sourceUrl} target="_blank" rel="noopener">{product.sourceUrl}</a>
            และข้อมูลที่บันทึกไว้วันที่ 15 มิถุนายน 2026 ราคา คูปอง คะแนน และเงื่อนไขร้านค้าเปลี่ยนได้ตลอด
            ก่อนจ่ายเงินจริงเปิดหน้าร้านเช็กอีกครั้งดีที่สุดครับ
          </p>
        </div>
      </article>

