const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Review",
  itemReviewed: {
    "@type": "Product",
    name: product.name,
    brand: {
      "@type": "Brand",
      name: product.brand
    }
  },
  reviewRating: {
    "@type": "Rating",
    ratingValue: product.score,
    bestRating: 10
  },
  author: {
    "@type": "Organization",
    name: "Friendsay"
  },
  inLanguage: "th",
  dateModified: product.updated,
  isBasedOn: product.sourceUrl
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((faq) => ({
    "@type": "Question",
    name: faq.question,
    acceptedAnswer: {
