  {
    image: cleanUnitImage,
    label: "ภาพสินค้า",
    title: "ตัวเครื่องแบบคลีน",
    note: "ใช้ดูหน้าตาเครื่อง สี และทรงโดยรวมก่อนกดดูรายละเอียดร้าน"
  },
  {
    image: heroImage,
    label: "ชุดสินค้า",
