  <script is:inline>
    (() => {
      const scrollOffset = 108;

      const withInstantScroll = (callback) => {
        const root = document.documentElement;
        const previous = root.style.scrollBehavior;
        root.style.scrollBehavior = "auto";
        callback();
        window.requestAnimationFrame(() => {
          root.style.scrollBehavior = previous;
        });
      };

      const offsetHashTarget = () => {
        if (!window.location.hash) return;
        const id = decodeURIComponent(window.location.hash.slice(1));
        const target = document.getElementById(id);
        if (!target) return;

        window.requestAnimationFrame(() => {
          const top = Math.max(0, target.getBoundingClientRect().top + window.scrollY - scrollOffset);
          withInstantScroll(() => {
            window.scrollTo({ top, behavior: "auto" });
          });
        });
      };

      document.querySelectorAll('a[href^="#"]').forEach((link) => {
        link.addEventListener("click", (event) => {
          const href = link.getAttribute("href");
          if (!href || href.length <= 1) return;
          const target = document.getElementById(decodeURIComponent(href.slice(1)));
          if (!target) return;

          event.preventDefault();
          window.history.pushState(null, "", href);
          offsetHashTarget();
        });
      });

      window.addEventListener("hashchange", () => window.setTimeout(offsetHashTarget, 0));
      window.addEventListener("popstate", () => window.setTimeout(offsetHashTarget, 0));
      window.addEventListener("load", () => {
        window.setTimeout(offsetHashTarget, 120);
        window.setTimeout(offsetHashTarget, 700);
      });
      window.setTimeout(offsetHashTarget, 0);
      window.setTimeout(offsetHashTarget, 300);
      window.setTimeout(offsetHashTarget, 1100);
    })();
  </script>
