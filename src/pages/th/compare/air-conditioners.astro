---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";
import { airConditioners } from "../../../data/airConditioners";
import { queuedAirConditionerReviews } from "../../../data/airConditionerReviewQueue";
import { searchIndex } from "../../../data/searchIndex";
import acPriceCsvRaw from "../../../data/price-history/air-conditioners.csv?raw";

// ยอดขายที่เห็นจริงรายรุ่น (กติกา B+D: Shopee ไม่โชว์ = null ห้ามเดา) — searchIndex เก็บไว้ครบแล้ว
const soldById = new Map(searchIndex.map((item) => [item.id, { soldNum: item.soldNum, soldLabel: item.soldLabel }]));

// ราคาที่เคยเห็นจริงล่าสุดรายรุ่น จาก ledger (append-only) — ใช้เทียบตัวเลขในผลตัดสินรายคู่
// เลือกแถวล่าสุดของแต่ละรุ่น (ถ้าวันเดียวกันมีทั้ง list/promo ใช้ promo เพราะคือราคาที่จ่ายจริง)
const latestSeenPrice: Record<string, { price: number; date: string; priceType: string }> = {};
for (const line of acPriceCsvRaw.trim().split(/\r?\n/).slice(1)) {
  const [productKey, date, price, priceType] = line.split(",");
  if (!productKey) continue;
  const current = latestSeenPrice[productKey];
  if (!current || date > current.date || (date === current.date && priceType === "promo")) {
    latestSeenPrice[productKey] = { price: Number(price), date, priceType };
  }
}

const THAI_MONTHS = ["ม.ค.", "ก.พ.", "มี.ค.", "เม.ย.", "พ.ค.", "มิ.ย.", "ก.ค.", "ส.ค.", "ก.ย.", "ต.ค.", "พ.ย.", "ธ.ค."];
const thaiDate = (iso: string) => {
  const [y, m, d] = iso.split("-").map(Number);
  return `${d} ${THAI_MONTHS[m - 1]} ${y}`;
};

const mainCompareProducts = airConditioners.map((product, productIndex) => ({
  tier: "main",
  orderIdx: productIndex,
  soldNum: soldById.get(product.slug)?.soldNum ?? null,
  soldShort: (() => {
    const s = soldById.get(product.slug);
    if (!s) return "ไม่แสดง";
    return s.soldNum ? `${s.soldNum >= 10000 ? "10พัน+" : s.soldNum >= 1000 ? Math.floor(s.soldNum / 1000) + "พัน+" : s.soldNum.toLocaleString("th-TH")} เครื่อง` : "ไม่แสดง";
  })(),
  priceNum: latestSeenPrice[product.slug]?.price ?? null,
  priceSeenLabel: latestSeenPrice[product.slug]
    ? `฿${latestSeenPrice[product.slug].price.toLocaleString("th-TH")} (${latestSeenPrice[product.slug].priceType === "promo" ? "ราคาโปร" : "ราคาตั้ง"} · ${thaiDate(latestSeenPrice[product.slug].date)})`
    : null,
  slug: product.slug,
  name: product.name,
  shortName: product.shortName,
  brand: product.brand,
  store: product.store,
  statusLabel: product.statusLabel,
  sourceUrl: product.sourceUrl,
  image: product.image,
  priceLabel: product.priceLabel,
  btuOptions: product.btuOptions,
  rating: product.rating,
  ratingsCount: product.ratingsCount,
  commentsCount: product.commentsCount,
  mediaCount: product.mediaCount,
  favoritesLabel: product.favoritesLabel,
  score: product.score,
  popularity: product.popularity,
  buyerConfidence: product.buyerConfidence,
  value: product.value,
  roomFit: product.roomFit,
  energyComfort: product.energyComfort,
  installRisk: product.installRisk,
  warrantySafety: product.warrantySafety,
  complaintRisk: product.complaintRisk,
  bestFor: product.bestFor,
  notFor: product.notFor,
  pros: product.pros,
  watch: product.watch,
  reviewSignals: product.reviewSignals,
  installNotes: product.installNotes,
  warrantyNotes: product.warrantyNotes,
  links: product.links,
  updated: product.updated
}));

const queueCompareProducts = queuedAirConditionerReviews.map((review) => ({
  tier: "queue",
  soldNum: null,
  soldShort: "ยังไม่บันทึก",
  priceNum: null,
  priceSeenLabel: null,
  slug: review.productKey,
  name: review.name,
  shortName: review.shortName,
  brand: review.brand,
  store: review.sourceName,
  statusLabel: "มีข้อมูลให้เทียบ",
  sourceUrl: review.links.shopee,
  image: {
    url: review.heroImage,
    alt: `ภาพประกอบรีวิว ${review.name}`,
    source: review.heroImage,
    note: "ภาพประกอบสำหรับช่วยตัดสินใจก่อนซื้อ"
  },
  priceLabel: review.priceLabel,
  btuOptions: review.btuOptions,
  rating: Math.min(5, Math.max(0, review.score / 2)),
  ratingsCount: review.proofCount,
  commentsCount: review.proofCount,
  mediaCount: 0,
  favoritesLabel: "",
  score: review.score,
  popularity: review.popularity,
  buyerConfidence: review.buyerConfidence,
  value: review.value,
  roomFit: review.roomFit,
  energyComfort: review.value,
  installRisk: review.installClarity,
  warrantySafety: review.warrantySafety,
  complaintRisk: Math.max(1, 10 - review.installClarity),
  bestFor: review.bestFor,
  notFor: review.notFor,
  pros: review.strengths,
  watch: review.watchouts,
  reviewSignals: review.strengths,
  installNotes: [
    "ถามราคาติดตั้งและอุปกรณ์เพิ่มให้ชัดก่อนจ่าย",
    "ส่งรูปหน้างานให้ร้านช่วยประเมินก่อนนัดช่าง"
  ],
  warrantyNotes: [
    "ถามประกันเครื่อง คอมเพรสเซอร์ อะไหล่ และค่าแรงให้ครบ",
    "เก็บใบเสร็จและข้อความยืนยันรุ่นจากร้านไว้หลังซื้อ"
  ],
  links: review.links,
  updated: "2026-06-17"
}));

const compareProducts = [...mainCompareProducts, ...queueCompareProducts];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "เปรียบเทียบแอร์ติดผนังใน Shopee 2026",
  description: "ระบบเปรียบเทียบแอร์ติดผนังแบบเพื่อนช่วยเลือก เทียบราคา BTU รีวิวจริง จุดระวัง งานติดตั้ง ประกัน และลิงก์ Shopee Lazada TikTok",
  inLanguage: "th",
  dateModified: "2026-06-15",
  author: { "@type": "Organization", name: "Friendsay" }
};
---

<BaseLayout
  title="เปรียบเทียบแอร์ติดผนัง Shopee 2026 | Friendsay"
  description="เปรียบเทียบแอร์ติดผนัง CANDY TCL Xiaomi Midea แบบอ่านง่าย ดูรุ่นที่เหมาะกับงบ ห้อง รีวิว งานติดตั้ง ประกัน และปุ่มเช็กราคา Shopee Lazada TikTok"
  canonical="https://friendsay.com/th/compare/air-conditioners/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <AffiliateClickTracker />

  <section class="compare-page-hero compare-hero-v3">
    <div class="wide-container compare-page-hero-inner">
      <div>
        <p class="eyebrow">Friendsay Compare</p>
        <h1>เทียบแอร์แบบ<em class="accent-underline">เพื่อนช่วยเลือก</em></h1>
        <p>
          เลือก 2-4 รุ่นที่ลังเล เราตัดสินให้ทีละคู่จากหลักฐานจริง —
          ราคาที่เคยเห็น รีวิวผู้ซื้อ และคะแนน 8 ด้าน
        </p>
      </div>
      <aside>
        <span>ใช้ยังไงให้เร็วสุด</span>
        <strong>อ่านคำตัดสินก่อน แล้วค่อยไล่รายละเอียด</strong>
        <p>รุ่นที่เลือกจะลอยติดจอพร้อมปุ่มเช็กราคา เปลี่ยนรุ่นได้ตลอดโดยไม่ต้องเลื่อนกลับ</p>
      </aside>
    </div>
  </section>

  <div class="compare-cockpit" data-compare-cockpit-bar>
    <div class="wide-container compare-cockpit-inner">
      <div class="compare-cockpit-slots" data-compare-cockpit></div>
      <div class="compare-cockpit-actions">
        <button class="button compare-cockpit-btn" type="button" data-compare-drawer-open>⇄ เปลี่ยนรุ่น</button>
        <button class="button compare-cockpit-btn" type="button" data-compare-share>🔗 แชร์</button>
      </div>
    </div>
  </div>

  <main class="section compare-page-section">
    <div class="wide-container">
      <section class="compare-duel-panel" aria-label="จับคู่ชนกันตัวต่อตัว">
        <div class="compare-duel" data-compare-duel></div>
        <p class="compare-note compare-duel-note">
          สลับรุ่นในช่องไหนก็ได้ ผลเทียบทั้งหน้าอัปเดตตามทันที — ถ้าเลือกไว้มากกว่า 2 รุ่น ตัวที่เหลือยังถูกเทียบอยู่ในผลด้านล่างครบ
        </p>
      </section>

      <details class="compare-picker-drawer" data-compare-drawer>
        <summary>
          <span class="compare-drawer-title">เลือก/เปลี่ยนรุ่นที่เทียบ</span>
          <span class="compare-drawer-count" data-compare-drawer-count>เลือกแล้ว 0/4 รุ่น</span>
          <span class="compare-drawer-caret" aria-hidden="true">▾</span>
        </summary>
        <div class="compare-picker-panel" aria-label="เลือกรุ่นแอร์เพื่อเปรียบเทียบ">
          <label class="compare-picker-filter">
            <input type="search" data-compare-filter placeholder="พิมพ์ชื่อรุ่น/แบรนด์ เช่น daikin, haier" aria-label="กรองรายชื่อรุ่นที่เลือกได้" autocomplete="off" />
          </label>
          <div class="compare-picker-chips" data-compare-picker></div>
        </div>
      </details>

      <section class="compare-flags-panel" aria-label="คำตอบเร็วรายโจทย์">
        <p class="compare-flags-label">คำตอบใน 10 วินาที —</p>
        <div class="compare-flags" data-compare-answers></div>
      </section>

      <section class="compare-verdict-panel" aria-label="ผลตัดสินรายคู่">
        <div class="section-heading home-section-split">
          <div>
            <p class="eyebrow">Head-to-head</p>
            <h2 class="headline">ระหว่างคู่นี้ เอาตัวไหน</h2>
          </div>
          <p>
            เทียบจากหลักฐานที่เก็บจริงทีละคู่ — ราคาที่เคยเห็น จำนวนรีวิว และคะแนนรายด้านของเรา
            แล้วสรุปให้แบบเพื่อน: เอาตัวไหนถ้าโจทย์คุณเป็นแบบไหน
          </p>
        </div>
        <div class="compare-verdict-grid" data-compare-verdicts></div>
        <p class="compare-note" style="margin-top: 12px;">
          ราคาคือ "ราคาที่เคยเห็นจริง" จาก<a href="/th/guides/price-history/">บันทึกราคาย้อนหลังของเรา</a> ณ รอบเก็บข้อมูล ไม่ใช่ราคาปัจจุบัน — กดปุ่มเช็กราคาเพื่อดูราคาสดก่อนตัดสินใจ
        </p>
      </section>


      <section class="compare-overview-panel" aria-label="จุดแข็งแต่ละรุ่นเทียบ 8 ด้าน">
        <div class="section-heading home-section-split">
          <div>
            <p class="eyebrow">ภาพรวม 8 ด้าน</p>
            <h2 class="headline">จุดแข็งของแต่ละรุ่นในภาพเดียว</h2>
          </div>
          <p>เรดาร์กางเต็มด้านไหน แปลว่ารุ่นนั้นแข็งด้านนั้น — แถบขวาคือคะแนนละเอียดพร้อม ✓ ผู้ชนะรายด้าน</p>
        </div>
        <div class="compare-overview-layout">
          <div class="compare-overview-radar">
            <div class="compare-radar-chart" data-compare-radar></div>
            <div class="compare-radar-legend" data-compare-radar-legend></div>
          </div>
          <div class="compare-score-matrix" data-compare-score-matrix></div>
        </div>
      </section>

      <section class="compare-selected-products" aria-label="การ์ดรุ่นที่เลือก">
        <div class="section-heading home-section-split">
          <div>
            <p class="eyebrow">Selected models</p>
            <h2 class="headline">รุ่นที่กำลังเทียบ</h2>
          </div>
          <p data-compare-summary>กำลังโหลดข้อมูลเปรียบเทียบ</p>
        </div>
        <div class="compare-product-cards" data-compare-product-cards></div>
      </section>

      <details class="compare-deep-drawer">
        <summary>
          <span class="compare-drawer-title">ตารางเทียบเต็มสำหรับสายละเอียด</span>
          <span class="compare-drawer-note">BTU · ราคา · รีวิวจริง · ติดตั้ง · ประกัน · จุดที่ควรถามร้าน</span>
          <span class="compare-drawer-caret" aria-hidden="true">▾</span>
        </summary>
        <div class="compare-responsive-table" data-compare-table></div>
      </details>
    </div>
  </main>

  {/* SECURITY: set:html ไม่ escape — compareProducts ต้องเป็น build-time data เท่านั้น ห้ามรับจากผู้ใช้ */}
  <script id="air-compare-page-data" type="application/json" set:html={JSON.stringify(compareProducts)}></script>
  <script is:inline data-astro-rerun>
    (() => {
      const key = "friendsay:compare:air-conditioners";
      const dataEl = document.getElementById("air-compare-page-data");
      const products = dataEl ? JSON.parse(dataEl.textContent || "[]") : [];
      const productMap = new Map(products.map((product) => [product.slug, product]));
      const picker = document.querySelector("[data-compare-picker]");
      const answers = document.querySelector("[data-compare-answers]");
      const cards = document.querySelector("[data-compare-product-cards]");
      const matrix = document.querySelector("[data-compare-score-matrix]");
      const table = document.querySelector("[data-compare-table]");
      const summary = document.querySelector("[data-compare-summary]");

      const escapeHtml = (value) => String(value ?? "")
        .replaceAll("&", "&amp;")
        .replaceAll("<", "&lt;")
        .replaceAll(">", "&gt;")
        .replaceAll('"', "&quot;")
        .replaceAll("'", "&#039;");

      const readLocal = () => {
        try {
          const value = JSON.parse(localStorage.getItem(key) || "[]");
          return Array.isArray(value) ? value : [];
        } catch {
          return [];
        }
      };

      const readInitial = () => {
        const params = new URLSearchParams(location.search);
        const fromUrl = (params.get("items") || "").split(",").map((item) => item.trim()).filter(Boolean);
        const source = fromUrl.length ? fromUrl : readLocal();
        const valid = source.filter((slug) => productMap.has(slug));
        return valid.length ? valid.slice(0, 4) : products.slice(0, 4).map((product) => product.slug);
      };

      let selected = readInitial();

      const selectedProducts = () => selected.map((slug) => productMap.get(slug)).filter(Boolean);
      const scoreRows = [
        ["popularity", "ความนิยม"],
        ["buyerConfidence", "ความมั่นใจผู้ซื้อ"],
        ["value", "ความคุ้มค่า"],
        ["roomFit", "เลือก BTU ง่าย"],
        ["energyComfort", "ประหยัดไฟ/สบาย"],
        ["installRisk", "ความเสี่ยงติดตั้ง"],
        ["warrantySafety", "ประกัน/ความปลอดภัย"],
        ["complaintRisk", "ความเสี่ยงคำบ่น"]
      ];

      const bestBy = (items, fn) => items.slice().sort((a, b) => fn(b) - fn(a))[0];
      const moneyText = (product) => product.priceLabel.replace("พบ", "").replace(" ณ วันที่เก็บข้อมูล", "");
      const listText = (items) => items.filter(Boolean).slice(0, 2).join(" / ");

      const persist = () => {
        try {
          localStorage.setItem(key, JSON.stringify(selected));
        } catch {
          // URL state is enough for sharing and for browsers that block storage.
        }
        const url = selected.length
          ? `${location.pathname}?items=${encodeURIComponent(selected.join(","))}`
          : location.pathname;
        history.replaceState(null, "", url);
      };

      const chipHtml = (product) => {
        const isSelected = selected.includes(product.slug);
        return `
          <button class="compare-picker-chip ${isSelected ? "is-selected" : ""}" type="button" data-compare-page-slug="${escapeHtml(product.slug)}" data-chip-text="${escapeHtml((product.shortName + " " + product.name + " " + product.brand).toLowerCase())}" aria-pressed="${isSelected}">
            <img class="compare-chip-thumb" src="${escapeHtml(product.image.url)}" alt="" loading="lazy" />
            <span>${escapeHtml(product.score.toFixed(1))}</span>
            <strong>${escapeHtml(product.shortName)}</strong>
            <small>${escapeHtml(product.statusLabel)}</small>
          </button>
        `;
      };

      const applyChipFilter = () => {
        const filterInput = document.querySelector("[data-compare-filter]");
        const query = (filterInput?.value || "").trim().toLowerCase();
        picker?.querySelectorAll("[data-compare-page-slug]").forEach((chip) => {
          chip.hidden = Boolean(query) && !(chip.dataset.chipText || "").includes(query);
        });
        picker?.querySelectorAll("[data-picker-group]").forEach((group) => {
          const anyVisible = [...group.querySelectorAll("[data-compare-page-slug]")].some((chip) => !chip.hidden);
          group.hidden = !anyVisible;
        });
      };

      const renderPicker = () => {
        if (!picker) return;
        const mains = products.filter((product) => product.tier === "main");
        const queue = products.filter((product) => product.tier !== "main");
        picker.innerHTML = `
          <div class="compare-picker-group" data-picker-group>
            <p class="compare-picker-group-label">คลังหลัก — ตรวจหลักฐานเต็มรูปแบบแล้ว (${mains.length} รุ่น)</p>
            <div class="compare-picker-group-chips">${mains.map(chipHtml).join("")}</div>
          </div>
          <div class="compare-picker-group" data-picker-group>
            <p class="compare-picker-group-label">คิวรีวิว — มีข้อมูลให้เทียบ กำลังทยอยตรวจเต็มรูปแบบ (${queue.length} รุ่น)</p>
            <div class="compare-picker-group-chips">${queue.map(chipHtml).join("")}</div>
          </div>
        `;
        applyChipFilter();

        picker.querySelectorAll("[data-compare-page-slug]").forEach((button) => {
          button.addEventListener("click", () => {
            const slug = button.dataset.comparePageSlug;
            if (!slug) return;
            if (selected.includes(slug)) {
              selected = selected.filter((item) => item !== slug);
            } else if (selected.length < 4) {
              selected = [...selected, slug];
            } else {
              selected = [...selected.slice(1), slug];
            }
            if (selected.length === 0) selected = [products[0].slug];
            persist();
            renderAll();
          });
        });
      };

      const renderAnswers = (items) => {
        if (!answers) return;
        const value = bestBy(items, (product) => product.value);
        const trust = bestBy(items, (product) => product.popularity + product.buyerConfidence);
        const room = bestBy(items, (product) => product.roomFit);
        const warranty = bestBy(items, (product) => product.warrantySafety);
        const answerCards = [
          ["งบคุ้ม", value, "เหมาะถ้าต้องการราคาเปิดดีและคะแนนความคุ้มค่าสูง"],
          ["รีวิวแน่น", trust, "เหมาะถ้าอยากเริ่มจากรุ่นที่มีรีวิวผู้ซื้อเยอะกว่า"],
          ["เลือก BTU ง่าย", room, "เหมาะถ้ายังไม่มั่นใจเรื่องขนาดห้องและต้องการตัวเลือกกว้าง"],
          ["ประกันน่าสบายใจ", warranty, "เหมาะถ้ากังวลเรื่องบริการหลังซื้อและอยากถามประกันให้ชัด"]
        ];

        answers.innerHTML = answerCards.map(([label, product]) => `
          <span class="compare-flag">
            <em>${escapeHtml(label)}</em>
            <strong>${escapeHtml(product.shortName)}</strong>
          </span>
        `).join("");
      };

      // ---- เวทีชน 2 รุ่น (ช่องบนสุด): ภาพใหญ่ + dropdown สลับรุ่นได้อิสระ ----
      const duelHost = document.querySelector("[data-compare-duel]");
      const renderDuel = (items) => {
        if (!duelHost) return;
        const slots = [items[0] || null, items[1] || null];
        duelHost.innerHTML = slots.map((p, i) => `
          ${i === 1 ? '<div class="compare-duel-medal" aria-hidden="true">VS</div>' : ""}
          <div class="compare-duel-card">
            ${p ? `
              <a class="compare-duel-img" href="${escapeHtml(p.links.shopee)}" target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-duel-${escapeHtml(p.slug)}">
                <img src="${escapeHtml(p.image.url)}" alt="ภาพสินค้าจริง ${escapeHtml(p.name)}" loading="eager" />
              </a>
              <div class="compare-duel-meta">
                <strong>${escapeHtml(p.score.toFixed(1))}<small>/10</small></strong>
                <span>${escapeHtml(p.shortName)}</span>
              </div>`
            : '<div class="compare-duel-empty">ยังไม่ได้เลือกรุ่นช่องนี้<br/>เลือกจากเมนูด้านล่างได้เลย</div>'}
            <select class="compare-duel-switch" data-duel-slot="${i}" aria-label="เลือกรุ่นช่องที่ ${i + 1}">
              ${!p ? '<option value="" selected disabled>เลือกรุ่น…</option>' : ""}
              ${products.map((m) => {
                const takenElsewhere = selected.includes(m.slug) && (!p || m.slug !== p.slug);
                return `<option value="${escapeHtml(m.slug)}" ${p && m.slug === p.slug ? "selected" : ""} ${takenElsewhere ? "disabled" : ""}>${escapeHtml(m.shortName)}${takenElsewhere ? " (เลือกอยู่แล้ว)" : ""}</option>`;
              }).join("")}
            </select>
            ${p ? `<a class="compare-duel-buy" href="${escapeHtml(p.links.shopee)}" target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-duel-buy-${escapeHtml(p.slug)}">เช็กราคา Shopee</a>` : ""}
          </div>
        `).join("");

        duelHost.querySelectorAll("[data-duel-slot]").forEach((sel) => {
          sel.addEventListener("change", () => {
            const slot = Number(sel.dataset.duelSlot);
            const chosen = sel.value;
            if (!chosen || selected[slot] === chosen || selected.includes(chosen)) {
              renderAll();
              return;
            }
            if (selected[slot]) {
              selected = selected.map((s, idx2) => (idx2 === slot ? chosen : s));
            } else {
              selected = [...selected, chosen];
            }
            persist();
            renderAll();
          });
        });
      };

      // ---- cockpit: รุ่นที่เลือกลอยติดจอ พร้อมปุ่มซื้อ/เอาออก/เพิ่มรุ่น ----
      const drawer = document.querySelector("[data-compare-drawer]");
      const drawerCount = document.querySelector("[data-compare-drawer-count]");
      const cockpit = document.querySelector("[data-compare-cockpit]");

      const openDrawer = () => {
        if (!drawer) return;
        drawer.open = true;
        drawer.scrollIntoView({ behavior: "smooth", block: "start" });
        document.querySelector("[data-compare-filter]")?.focus({ preventScroll: true });
      };

      const renderCockpit = (items) => {
        if (!cockpit) return;
        const slots = items.map((product) => `
          <div class="compare-slot">
            <img src="${escapeHtml(product.image.url)}" alt="" loading="lazy" />
            <div class="compare-slot-info">
              <strong>${escapeHtml(product.shortName)}</strong>
              <span>${product.priceNum ? `เคยเห็น ฿${product.priceNum.toLocaleString("th-TH")}` : escapeHtml(product.statusLabel)}</span>
            </div>
            <a class="compare-slot-buy" href="${escapeHtml(product.links.shopee)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-cockpit-${escapeHtml(product.slug)}">เช็กราคา</a>
            <button class="compare-slot-remove" type="button" data-slot-remove="${escapeHtml(product.slug)}" aria-label="เอา ${escapeHtml(product.shortName)} ออกจากการเทียบ">✕</button>
          </div>
        `).join("");
        const addSlot = items.length < 4
          ? '<button class="compare-slot-add" type="button" data-cockpit-add>＋ เพิ่มรุ่น</button>'
          : "";
        cockpit.innerHTML = slots + addSlot;

        cockpit.querySelectorAll("[data-slot-remove]").forEach((btn) => {
          btn.addEventListener("click", () => {
            if (selected.length <= 1) return;
            selected = selected.filter((slug) => slug !== btn.dataset.slotRemove);
            persist();
            renderAll();
          });
        });
        cockpit.querySelector("[data-cockpit-add]")?.addEventListener("click", openDrawer);

        if (drawerCount) drawerCount.textContent = `เลือกแล้ว ${items.length}/4 รุ่น`;
      };

      // ---- ผลตัดสินรายคู่: เทียบจากหลักฐานจริง (ราคาที่เคยเห็น/รีวิว/คะแนนรายด้าน) ไม่แต่งตัวเลข ----
      const axisPhrases = {
        value: "เน้นความคุ้มราคา",
        popularity: "อยากได้ตัวที่คนซื้อเยอะ",
        buyerConfidence: "อยากได้รีวิวแน่น ๆ ไว้ตามอ่านก่อนจ่าย",
        roomFit: "อยากได้ตัวเลือก BTU กว้าง เลือกตรงห้องง่าย",
        energyComfort: "เปิดยาวทุกคืน เน้นเรื่องค่าไฟ",
        installRisk: "อยากให้เรื่องติดตั้งวุ่นน้อยที่สุด",
        warrantySafety: "เน้นประกันและความสบายใจหลังซื้อ",
        complaintRisk: "อยากได้ตัวที่เสียงบ่นจากผู้ซื้อน้อย"
      };

      const biggestEdge = (a, b) => {
        let bestKey = null;
        let bestDiff = 0.25; // ต่างน้อยกว่านี้ถือว่าสูสี ไม่เคลมเป็นจุดต่าง
        for (const keyName of Object.keys(axisPhrases)) {
          const diff = Number(a[keyName] || 0) - Number(b[keyName] || 0);
          if (diff > bestDiff) {
            bestDiff = diff;
            bestKey = keyName;
          }
        }
        return bestKey;
      };

      const verdictReason = (product, rival) => {
        if (product.priceNum && rival.priceNum && rival.priceNum - product.priceNum >= 500) {
          return `คุมงบเป็นหลัก — ราคาที่เคยเห็นถูกกว่าราว ${(rival.priceNum - product.priceNum).toLocaleString("th-TH")} บาท`;
        }
        const edge = biggestEdge(product, rival);
        if (edge) return axisPhrases[edge] + ` (คะแนนด้านนี้ ${Number(product[edge]).toFixed(1)} ต่อ ${Number(rival[edge]).toFixed(1)})`;
        if (product.ratingsCount > rival.ratingsCount * 1.5) {
          return `อยากได้ฐานรีวิวใหญ่กว่า (${product.ratingsCount.toLocaleString("th-TH")} เทียบ ${rival.ratingsCount.toLocaleString("th-TH")} รายการ)`;
        }
        return "สองตัวนี้สูสีมากในข้อมูลที่เรามี — ตัดสินจาก BTU ที่ตรงห้องและดีลติดตั้งวันที่คุณกดซื้อ";
      };

      const verdictFacts = (a, b) => {
        const facts = [];
        if (a.priceNum && b.priceNum && a.priceNum !== b.priceNum) {
          const cheap = a.priceNum < b.priceNum ? a : b;
          const diff = Math.abs(a.priceNum - b.priceNum);
          facts.push(`${cheap.shortName} ราคาที่เคยเห็นถูกกว่าราว ${diff.toLocaleString("th-TH")} บาท`);
        }
        if (a.ratingsCount !== b.ratingsCount) {
          const more = a.ratingsCount > b.ratingsCount ? a : b;
          const less = more === a ? b : a;
          facts.push(`${more.shortName} รีวิวเยอะกว่า (${more.ratingsCount.toLocaleString("th-TH")} ต่อ ${less.ratingsCount.toLocaleString("th-TH")})`);
        }
        if (a.soldNum || b.soldNum) {
          facts.push(`ยอดขายที่เห็นบนหน้าร้าน: ${a.shortName} ${a.soldShort} · ${b.shortName} ${b.soldShort}`);
        }
        facts.push(`คะแนนรวมของเรา: ${a.shortName} ${a.score.toFixed(1)} · ${b.shortName} ${b.score.toFixed(1)}`);
        return facts;
      };

      const renderVerdicts = (items) => {
        const host = document.querySelector("[data-compare-verdicts]");
        if (!host) return;
        if (items.length < 2) {
          host.innerHTML = '<p class="muted">เลือกอย่างน้อย 2 รุ่นจากด้านบน แล้วเราจะตัดสินให้ทีละคู่</p>';
          return;
        }
        const pairs = [];
        for (let i = 0; i < items.length; i += 1) {
          for (let j = i + 1; j < items.length; j += 1) pairs.push([items[i], items[j]]);
        }
        host.innerHTML = pairs.map(([a, b]) => `
          <article class="compare-verdict-card">
            <p class="compare-verdict-title">${escapeHtml(a.shortName)} <em>vs</em> ${escapeHtml(b.shortName)}</p>
            <ul class="compare-verdict-facts">
              ${verdictFacts(a, b).map((fact) => `<li>${escapeHtml(fact)}</li>`).join("")}
            </ul>
            <div class="compare-verdict-take">
              <p><strong>เอา ${escapeHtml(a.shortName)}</strong> ถ้า${escapeHtml(verdictReason(a, b))}</p>
              <p><strong>เอา ${escapeHtml(b.shortName)}</strong> ถ้า${escapeHtml(verdictReason(b, a))}</p>
            </div>
            <div class="compare-verdict-buy">
              <a class="button button-primary" href="${escapeHtml(a.links.shopee)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-verdict-${escapeHtml(a.slug)}">เช็กราคา ${escapeHtml(a.shortName)}</a>
              <a class="button button-primary" href="${escapeHtml(b.links.shopee)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-verdict-${escapeHtml(b.slug)}">เช็กราคา ${escapeHtml(b.shortName)}</a>
            </div>
            ${Number.isInteger(a.orderIdx) && Number.isInteger(b.orderIdx)
              ? `<a class="compare-detail-link" href="/th/vs/${a.orderIdx < b.orderIdx ? escapeHtml(a.slug) + "-vs-" + escapeHtml(b.slug) : escapeHtml(b.slug) + "-vs-" + escapeHtml(a.slug)}/">เปิดหน้าเทียบเต็มของคู่นี้ (แชร์ได้) →</a>`
              : ""}
          </article>
        `).join("");
      };

      const renderCards = (items) => {
        if (!cards) return;
        if (summary) {
          summary.textContent = `กำลังเทียบ ${items.length} รุ่น: ${items.map((product) => product.shortName).join(" / ")}`;
        }
        cards.innerHTML = items.map((product) => `
          <article class="compare-product-summary-card">
            <a class="compare-card-media" href="${escapeHtml(product.links.shopee)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-page-card">
              <img src="${escapeHtml(product.image.url)}" alt="ภาพสินค้าจริง ${escapeHtml(product.name)}" loading="lazy" />
            </a>
            <div class="compare-card-top">
              <span>${escapeHtml(product.statusLabel)}</span>
              <strong>${escapeHtml(product.score.toFixed(1))}<small>/10</small></strong>
            </div>
            <h3>${escapeHtml(product.name)}</h3>
            <p>${escapeHtml(product.bestFor)}</p>
            <div class="compare-card-facts">
              <span>ราคา: ${escapeHtml(moneyText(product))}</span>
              ${product.priceSeenLabel ? `<span>เคยเห็นจริง: ${escapeHtml(product.priceSeenLabel)} · <a href="/th/guides/price-history/">ดูประวัติราคา</a></span>` : ""}
              <span>ยอดขายที่เห็น: ${escapeHtml(product.soldShort)}</span>
              <span>BTU: ${escapeHtml(product.btuOptions.join(" / "))}</span>
              <span>รีวิว: ${escapeHtml(product.ratingsCount.toLocaleString("th-TH"))}+ คะแนน</span>
            </div>
            <div class="compare-card-reviews">
              <div class="compare-reviews-good">
                <strong>รีวิวดีที่พูดซ้ำ</strong>
                <ul>${(product.reviewSignals || []).slice(0, 2).map((s) => `<li>${escapeHtml(s)}</li>`).join("")}</ul>
              </div>
              <div class="compare-reviews-bad">
                <strong>เสียงบ่น/จุดระวัง</strong>
                <ul>${(product.watch || []).slice(0, 2).map((s) => `<li>${escapeHtml(s)}</li>`).join("")}</ul>
              </div>
            </div>
            <div class="compare-buy-grid">
              <a class="price-button shopee" href="${escapeHtml(product.links.shopee)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="compare-page">Shopee</a>
              <a class="price-button lazada" href="${escapeHtml(product.links.lazada)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="lazada" data-affiliate-context="compare-page">Lazada</a>
              <a class="price-button tiktok" href="${escapeHtml(product.links.tiktok)}" rel="sponsored noopener" target="_blank" data-affiliate-link data-affiliate-store="tiktok" data-affiliate-context="compare-page">TikTok</a>
            </div>
          </article>
        `).join("");
      };

      const renderMatrix = (items) => {
        if (!matrix) return;
        matrix.innerHTML = scoreRows.map(([keyName, label]) => {
          const rowMax = Math.max(...items.map((product) => Number(product[keyName] || 0)));
          return `
          <article>
            <strong>${escapeHtml(label)}</strong>
            <div>
              ${items.map((product) => {
                const value = Number(product[keyName] || 0);
                const isBest = items.length > 1 && value === rowMax;
                return `
                  <span class="${isBest ? "is-row-best" : ""}">
                    <b>${escapeHtml(product.shortName)}${isBest ? " ✓" : ""}</b>
                    <i style="--score:${Math.max(0, Math.min(10, value)) * 10}%"></i>
                    <em>${escapeHtml(value.toFixed(1))}</em>
                  </span>
                `;
              }).join("")}
            </div>
          </article>
        `;
        }).join("");
      };

      const renderTable = (items) => {
        if (!table) return;
        const rows = [
          ["ราคา", (product) => moneyText(product)],
          ["ยอดขายที่เห็น", (product) => product.soldShort],
          ["BTU ที่มี", (product) => product.btuOptions.join(" / ")],
          ["เหมาะกับใคร", (product) => product.bestFor],
          ["ไม่เหมาะถ้า", (product) => product.notFor],
          ["รีวิวดีที่พูดซ้ำ", (product) => listText(product.reviewSignals)],
          ["รีวิวเสีย/จุดระวัง", (product) => listText(product.watch)],
          ["เรื่องติดตั้ง", (product) => listText(product.installNotes)],
          ["ประกัน", (product) => listText(product.warrantyNotes)],
          ["อัปเดตข้อมูล", (product) => product.updated]
        ];

        table.innerHTML = `
          <table class="compare-deep-table">
            <thead>
              <tr>
                <th>หัวข้อ</th>
                ${items.map((product) => `
                  <th>
                    <img class="compare-th-thumb" src="${escapeHtml(product.image.url)}" alt="" loading="lazy" />
                    <span>${escapeHtml(product.shortName)}</span>
                  </th>
                `).join("")}
              </tr>
            </thead>
            <tbody>
              ${rows.map(([label, getter]) => `
                <tr>
                  <th>${escapeHtml(label)}</th>
                  ${items.map((product) => `<td>${escapeHtml(getter(product))}</td>`).join("")}
                </tr>
              `).join("")}
            </tbody>
          </table>
        `;
      };

      const renderRadar = (items) => {
        const host = document.querySelector("[data-compare-radar]");
        if (!host) return;
        const axes = [
          ["popularity", "ความนิยม"],
          ["buyerConfidence", "มั่นใจผู้ซื้อ"],
          ["value", "คุ้มค่า"],
          ["roomFit", "เลือกขนาดง่าย"],
          ["energyComfort", "ประหยัด/สบาย"],
          ["installRisk", "ติดตั้งสบายใจ"],
          ["warrantySafety", "ประกัน"],
          ["complaintRisk", "เสียงบ่นน้อย"]
        ];
        const colors = ["#ff6b5a", "#0ea5a0", "#3a86ff", "#f1a208"];
        const size = 460;
        const cx = size / 2;
        const cy = size / 2;
        const radius = 150;
        const angle = (i) => (Math.PI * 2 * i) / axes.length - Math.PI / 2;
        const px = (i, r) => cx + Math.cos(angle(i)) * r;
        const py = (i, r) => cy + Math.sin(angle(i)) * r;
        const pt = (i, r) => `${px(i, r).toFixed(1)},${py(i, r).toFixed(1)}`;

        const rings = [0.25, 0.5, 0.75, 1]
          .map((f) => `<polygon points="${axes.map((_, i) => pt(i, radius * f)).join(" ")}" fill="none" stroke="rgba(31,41,55,0.1)" />`)
          .join("");
        const spokes = axes
          .map((_, i) => `<line x1="${cx}" y1="${cy}" x2="${px(i, radius).toFixed(1)}" y2="${py(i, radius).toFixed(1)}" stroke="rgba(31,41,55,0.1)" />`)
          .join("");
        const labels = axes
          .map(([, label], i) => {
            const lx = px(i, radius + 24);
            const ly = py(i, radius + 24);
            const anchor = Math.abs(lx - cx) < 14 ? "middle" : lx > cx ? "start" : "end";
            return `<text x="${lx.toFixed(1)}" y="${ly.toFixed(1)}" text-anchor="${anchor}" dominant-baseline="middle">${escapeHtml(label)}</text>`;
          })
          .join("");
        const shapes = items
          .map((product, idx) => {
            const points = axes
              .map(([keyName], i) => pt(i, (radius * Math.max(0, Math.min(10, Number(product[keyName] || 0)))) / 10))
              .join(" ");
            const color = colors[idx % colors.length];
            return `<polygon class="radar-shape" style="animation-delay:${idx * 120}ms" points="${points}" fill="${color}24" stroke="${color}" stroke-width="2.5" stroke-linejoin="round" />`;
          })
          .join("");

        host.innerHTML = `<svg viewBox="0 0 ${size} ${size}" role="img" aria-label="เรดาร์เทียบคะแนน 8 ด้านของรุ่นที่เลือก">${rings}${spokes}${labels}${shapes}</svg>`;

        const legend = document.querySelector("[data-compare-radar-legend]");
        if (legend) {
          legend.innerHTML = items
            .map((product, idx) => `
              <span>
                <i style="background:${colors[idx % colors.length]}"></i>
                <b>${escapeHtml(product.shortName)}</b>
                <em>${escapeHtml(product.score.toFixed(1))}/10</em>
              </span>
            `)
            .join("");
        }
      };

      const flyIn = (container) => {
        if (!container) return;
        container.querySelectorAll(":scope > *").forEach((el, index) => {
          el.classList.add("compare-fly");
          el.style.animationDelay = `${Math.min(index, 5) * 70}ms`;
        });
      };

      function renderAll() {
        const items = selectedProducts();
        renderDuel(items);
        renderCockpit(items);
        renderPicker();
        renderAnswers(items);
        renderVerdicts(items);
        renderRadar(items);
        renderCards(items);
        renderMatrix(items);
        renderTable(items);
        flyIn(answers);
        flyIn(document.querySelector("[data-compare-verdicts]"));
        flyIn(cards);
        flyIn(matrix);
      }

      // ปุ่ม "เปลี่ยนรุ่น" บน cockpit + เปิดลิ้นชักอัตโนมัติถ้ายังเลือกไม่ถึง 2 รุ่น
      document.querySelectorAll("[data-compare-drawer-open]").forEach((btn) => {
        btn.addEventListener("click", openDrawer);
      });
      if (drawer && selected.length < 2) drawer.open = true;

      // ช่องกรองรายชื่อรุ่นใน picker (34 รุ่นไล่หายาก)
      const filterInput = document.querySelector("[data-compare-filter]");
      filterInput?.addEventListener("input", applyChipFilter);

      // ปุ่มคัดลอกลิงก์ผลเทียบ — URL มี ?items= ของรุ่นที่เลือกอยู่แล้ว
      const shareButton = document.querySelector("[data-compare-share]");
      shareButton?.addEventListener("click", async () => {
        const original = shareButton.textContent;
        try {
          await navigator.clipboard.writeText(location.href);
          shareButton.textContent = "คัดลอกแล้ว ✓ ส่งให้เพื่อนช่วยเลือกได้เลย";
        } catch {
          window.prompt("คัดลอกลิงก์นี้ส่งให้เพื่อน", location.href);
          shareButton.textContent = original;
          return;
        }
        if (typeof window.gtag === "function") {
          window.gtag("event", "friendsay_compare_share", { items: selected.join(",") });
        }
        setTimeout(() => { shareButton.textContent = original; }, 2600);
      });

      persist();
      renderAll();
    })();
  </script>
</BaseLayout>
