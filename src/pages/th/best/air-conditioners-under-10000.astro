  <script is:inline data-astro-rerun>
    (() => {
      const grid = document.getElementById("budget-grid");
      const note = document.getElementById("budget-sort-note");
      const officialOnly = document.getElementById("budget-official-only");
      if (!grid) return;

      const cards = Array.from(grid.children);
      const sortButtons = Array.from(document.querySelectorAll("[data-sort]"));
      const num = (card, key) => Number(card.getAttribute("data-" + key) || 0);
      const sortLabels = { price: "ราคาถูกสุดก่อน", reviews: "รีวิวเยอะสุด", sold: "ยอดขายสูงสุด", score: "คะแนนรวม" };
      let currentSort = "price";

      const apply = () => {
        const onlyOfficial = officialOnly && officialOnly.checked;

        const sorted = cards.slice().sort((a, b) => {
          if (currentSort === "price") return num(a, "price") - num(b, "price");
          if (currentSort === "reviews") return num(b, "reviews") - num(a, "reviews");
          if (currentSort === "score") return num(b, "score") - num(a, "score");
          // sold: ยอดขายสูงสุด (null=0 ไปท้าย) tiebreak ด้วยรีวิว
          const d = num(b, "sold") - num(a, "sold");
          return d !== 0 ? d : num(b, "reviews") - num(a, "reviews");
        });

        let visible = 0;
        sorted.forEach((card) => {
          const show = !onlyOfficial || card.getAttribute("data-official") === "true";
          card.hidden = !show;
          if (show) {
            visible += 1;
            card.classList.remove("budget-pop");
            // reflow เพื่อรีสตาร์ท animation
            void card.offsetWidth;
            card.classList.add("budget-pop");
          }
          grid.appendChild(card);
        });

        if (note) {
          note.textContent = `เรียงตาม: ${sortLabels[currentSort]}` + (onlyOfficial ? " · เฉพาะร้านทางการ (ไม่รวม reseller)" : "") + ` · แสดง ${visible} รุ่น`;
        }
      };

      sortButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          currentSort = btn.getAttribute("data-sort") || "price";
          sortButtons.forEach((b) => b.classList.toggle("is-active", b === btn));
          apply();
        });
      });
      if (officialOnly) officialOnly.addEventListener("change", apply);
    })();
  </script>
