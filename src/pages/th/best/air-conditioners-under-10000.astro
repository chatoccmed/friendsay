  { q: "ค่าติดตั้งจริงเท่าไหร่ ราคาที่เห็นคือราคาจบเลยไหม?", a: "เกือบทุกกรณีราคาที่เห็นยังไม่ใช่ราคาจบ Midea Celest หน้าสินค้าระบุ \"ไม่รวมติดตั้ง\" ตรง ๆ ต้องบวกค่าช่างเอง ส่วนรุ่นที่มีตัวเลือกติดตั้งตอนสั่ง (เช่น Candy ติดผ่าน Q-CHANG) ก็มักไม่จบที่ตัวเลขนั้น เพราะราว 90% ของงานมีค่าอุปกรณ์หน้างานเพิ่ม ทั้งรางครอบท่อ ขาแขวน ท่อส่วนที่เกินระยะแถม ทางที่ปลอดภัยคือถามร้านให้ชัดก่อนจ่ายว่าราคานี้รวมท่อ/ราง/ขาแขวน/สายไฟกี่เมตร โดยเฉพาะ TCL กับ Xiaomi ที่ต้องเช็กว่าเป็นราคาเครื่องเปล่าหรือรวมติดตั้งแล้ว" },
  { q: "ยี่ห้อจีนเคลมยากไหม ถ้าเครื่องมีปัญหาจะติดต่อใคร?", a: "ขึ้นกับว่าซื้อจากร้านแบบไหน มากกว่าดูแค่สัญชาติแบรนด์ รุ่นที่มีช่องทางศูนย์ชัดในกลุ่มนี้คือ Hisense CE มี onsite service ศูนย์ไทย โทร 02-017-0077 และ Haier VQEC ระบุศูนย์ทั่วประเทศ โทร 1789 จุดที่ต้องระวังคือเงื่อนไขเคลมขนส่ง อย่าง Haier VQEC ระบุว่ากรณีเคลมจากการขนส่งต้องมีวิดีโอตอนแกะกล่องแบบถ่ายต่อเนื่องเท่านั้น ฉะนั้นถ่ายคลิปตอนแกะกล่องไว้ทุกครั้งจะปลอดภัยกว่า และควรเก็บใบเสร็จกับช่องทางเคลมเป็นข้อความไว้ตั้งแต่วันซื้อ" },
  { q: "ควรซื้อจากร้าน official หรือ reseller ที่ราคาถูกกว่า?", a: "ในกลุ่มนี้สถานะร้านมี 3 แบบ ไม่เท่ากันหมด official แท้คือ Xiaomi Official Store, Hisense Official Store (Shopee Mall) และ haier.officialshop (ที่ขาย Haier VQEC) ส่วน TCL SaveIN ขายจาก TCL Authorized Store ซึ่งเป็นร้านตัวแทนที่ได้รับอนุญาต ไม่ใช่ official store เต็มตัว และ CANDY VPCT/VPGT เป็นแบรนด์ในเครือ Haier จำหน่ายผ่าน haier.officialshop ซึ่งเป็นร้าน official ของ Haier ไม่ใช่ร้านทางการเฉพาะแบรนด์ CANDY โดยตรง ทั้งสามแบบยังถือว่าซื้อจากร้านที่มีที่มา ต่างจาก Midea Celest ที่ขายโดย Lucky Plaza Online ซึ่งเป็น reseller แม้ราคาจะเริ่มถูกสุดราว 7,490.- ซื้อกับ reseller ได้ แต่ควรถามให้ชัดเรื่องใบเสร็จและช่องทางเคลมก่อนจ่าย และเช็กว่า Wi-Fi เป็นฟีเจอร์มาตรฐานของรุ่นที่สั่งจริงไหม เพราะประกันหน้าสินค้าพูดถึงหลายช่วง ต้องขอให้ร้านยืนยันเป็นข้อความ" },
  { q: "ราคาที่ Friendsay บอกเชื่อได้แค่ไหน แล้วเว็บได้อะไรจากการแนะนำ?", a: "ราคาทั้งหมดคือราคาที่เห็นจริงบนหน้า Shopee ณ 2 ก.ค. 2026 ส่วนใหญ่เป็นราคาช่วงโปร/Flash Sale จึงเปลี่ยนได้ทุกวัน ตัวเลขที่เห็นตอนคุณกดอาจไม่ตรงกับที่เขียนไว้ ให้ยึดราคาหน้าจริงเป็นหลัก Friendsay ทำคนเดียวร่วมกับ AI ไม่มีสินค้าจริงในมือ ไม่เคยใช้เครื่องเอง ข้อมูลทั้งหมดมาจากการส่องหน้าสินค้าจริง ส่วน \"ยอดขายไม่แสดง\" หมายถึง Shopee ไม่โชว์ตัวเลขบนหน้านั้น เราจึงไม่อ้างยอดขายเอง ใช้จำนวนรีวิวแทน (มีเพียง Hisense ที่เห็นยอดจริง 10,000+ และ Haier VQEC 8,000+) และลิงก์ในเว็บเป็นลิงก์ affiliate ถ้าคุณกดซื้อผ่าน Friendsay เราอาจได้ค่าคอมมิชชั่นเล็กน้อยโดยคุณไม่จ่ายเพิ่ม" }
];

// ประกอบข้อมูลรายรุ่น (ล็อกตัวเลข/ภาพ/ลิงก์จาก airConditioners.ts + budgetExtras) เรียงราคาถูก→แพง
const bySlug = (slug: string) => airConditioners.find((p) => p.slug === slug);
const budgetProducts = Object.keys(budgetExtras)
  .map((slug) => {
    const p = bySlug(slug)!;
    const ex = budgetExtras[slug];
    const btuFirst = p.btuOptions[0].replace(" BTU", "");
    const btuLast = p.btuOptions[p.btuOptions.length - 1].replace(" BTU", "");
    return {
      slug,
      name: p.name,
      shortName: p.shortName,
      image: p.image,
      rating: p.rating,
      ratingsCount: p.ratingsCount,
      score: p.score,
      energyComfort: p.energyComfort,
      value: p.value,
      btuRange: btuFirst === btuLast ? btuFirst : `${btuFirst}–${btuLast}`,
      btuOptions: p.btuOptions,
      links: p.links,
      whoFor: prose[slug].whoFor,
      topWatch: prose[slug].topWatch,
      ...ex
    };
  })
  .sort((a, b) => a.priceNum - b.priceNum);

// best-in-column (คิดจากข้อมูลจริง)
const minPrice = Math.min(...budgetProducts.map((p) => p.priceNum));
const maxReviews = Math.max(...budgetProducts.map((p) => p.ratingsCount));
const maxSold = Math.max(...budgetProducts.map((p) => p.soldNum ?? 0));
const bestWarrantySlug = "hisense-ce-series";

// quick-pick 3 ใบ
const quickPicks = [
  { label: "ถูกสุดในลิสต์", slug: "midea-celest-msce", reason: "ราคาเริ่มต้นต่ำสุด ~7,490.- คะแนน 5.0 — แต่เป็น reseller ต้องถามร้านให้จบ" },
  { label: "รีวิวเยอะสุด", slug: "candy-vpct-vpgt-series", reason: "รีวิวผู้ซื้อกว่า 10,400 รายการ มากสุดในกลุ่ม มีรูปให้ตามอ่านเยอะ" },
  { label: "official + ประกันยาว", slug: "hisense-ce-series", reason: "inverter จากร้าน official ประกันคอม 12 ปี เห็นยอดขายจริง 10พัน+" }
].map((pick) => {
  const p = budgetProducts.find((x) => x.slug === pick.slug)!;
  return { ...pick, name: p.shortName, image: p.image, priceShort: p.priceShort, rating: p.rating };
});

// กราฟ: แท่งราคา (สั้น = ถูกกว่า) + ป้ายรีวิว
const chartMax = Math.max(...budgetProducts.map((p) => p.priceNum));

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "แอร์ต่ำกว่า 10,000 บาท 2026: 6 รุ่นอินเวอร์เตอร์ที่ตรวจหลักฐานจริง",
  description: "รวมแอร์อินเวอร์เตอร์ราคาต่ำกว่าหมื่นบน Shopee 6 รุ่นที่ตรวจหลักฐานจริง เรียงจากถูกไปแพง พร้อมราคา BTU ประกัน จุดระวัง และตารางเทียบ",
  inLanguage: "th",
  dateModified: "2026-07-02",
  author: { "@type": "Organization", name: "Friendsay" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: budgetProducts.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: product.name,
      url: `https://friendsay.com/th/best/air-conditioners-under-10000/#${product.slug}`
    }))
  }
};

const faqJsonLd = faqSchema(faqs);

const scenarioCards = scenarios.map((s) => ({
  ...s,
  picks: s.recommendedSlugs.map((slug) => {
    const p = budgetProducts.find((x) => x.slug === slug)!;
    return { slug, shortName: p.shortName, priceShort: p.priceShort };
  })
}));
---

<BaseLayout
  title="แอร์ต่ำกว่า 10,000 บาท 2026: 6 รุ่นอินเวอร์เตอร์ที่ตรวจหลักฐานจริง | Friendsay"
  description="อยากได้แอร์อินเวอร์เตอร์งบไม่ถึงหมื่น? รวม 6 รุ่นที่เจอราคาต่ำกว่า 10,000 บาทบน Shopee ตรวจหลักฐานจริงรายรุ่น เรียงถูกไปแพง จัดเรียง/กรองเองได้ พร้อมราคา BTU ประกัน จุดระวัง และตารางเทียบ อัปเดต 2 ก.ค. 2026"
  canonical="https://friendsay.com/th/best/air-conditioners-under-10000/"
  ogImage="/images/air-conditioners/candy-vpct-real-product-plain-1.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="page-hero budget-hero">
    <div class="container">
      <div class="badge-row">
        <span class="badge badge-coral">งบต่ำกว่าหมื่น</span>
        <span class="badge badge-teal">อัปเดต {updatedLabel}</span>
        <span class="badge badge-blue">6 รุ่นตรวจหลักฐานแล้ว</span>
      </div>
      <h1>แอร์ต่ำกว่า 10,000 บาท 2026: 6 รุ่นอินเวอร์เตอร์ที่ตรวจหลักฐานจริงมาแล้ว</h1>
      <p class="muted budget-hero-kicker">{intro.heroKicker}</p>
      <div class="roundup-actions">
        <a class="button button-primary" href="#picks">ดู 6 รุ่นเรียงถูกไปแพง</a>
        <a class="button" href="#compare">ตารางเทียบ</a>
        <a class="button" href="/th/guides/btu-calculator/">คิด BTU ห้องก่อน</a>
      </div>
    </div>
  </section>

  <section class="section" id="intro">
    <div class="container">
      <div class="budget-intro">
        {intro.introParagraphs.map((para) => <p>{para}</p>)}
      </div>
    </div>
  </section>

  <section class="section band" id="quick-pick">
    <div class="container">
      <p class="eyebrow">เลือกด่วนใน 15 วินาที</p>
      <h2 class="headline">3 ตัวเด่น 3 โจทย์</h2>
      <div class="scenario-grid" style="margin-top: 18px;">
        {quickPicks.map((pick) => (
          <article class="rainy-pick-card">
            <div class="badge-row">
              <span class="badge badge-coral">{pick.label}</span>
              <span class="badge badge-blue">{pick.rating.toFixed(1)}/5</span>
            </div>
            <a href={`#${pick.slug}`}>
              <img class="rainy-img" src={pick.image.url} alt={pick.image.alt} loading="lazy" />
            </a>
            <h3>{pick.name} · {pick.priceShort}</h3>
            <p>{pick.reason}</p>
            <a class="button button-primary" href={`#${pick.slug}`}>ดูรายละเอียด ↓</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="picks">
    <div class="wide-container">
      <p class="eyebrow">6 รุ่น · อัปเดต {updatedLabel}</p>
      <h2 class="headline">แอร์ต่ำกว่าหมื่นที่ตรวจหลักฐานแล้ว</h2>
      <p class="muted" style="max-width: 720px;">กดจัดเรียงหรือกรองเองได้ตามที่คุณให้ความสำคัญ — ค่าเริ่มต้นเรียงจากราคาถูกไปแพง</p>

      <div class="budget-toolbar" role="group" aria-label="จัดเรียงและกรองรายการ">
        <div class="budget-sort" role="group" aria-label="จัดเรียง">
          <span class="budget-toolbar-label">เรียงตาม</span>
          <button class="budget-sort-btn is-active" type="button" data-sort="price">ถูกสุดก่อน</button>
          <button class="budget-sort-btn" type="button" data-sort="reviews">รีวิวเยอะสุด</button>
          <button class="budget-sort-btn" type="button" data-sort="sold">ยอดขายสูงสุด</button>
          <button class="budget-sort-btn" type="button" data-sort="score">คะแนนรวม</button>
        </div>
        <label class="budget-filter">
          <input type="checkbox" id="budget-official-only" />
          <span>ซื้อจากร้านทางการ (ไม่รวม reseller)</span>
        </label>
      </div>
      <p class="budget-sort-note" id="budget-sort-note" aria-live="polite">เรียงตาม: ราคาถูกสุดก่อน · แสดง 6 รุ่น</p>

      <div class="budget-grid" id="budget-grid">
        {budgetProducts.map((product, index) => (
          <article
            class="budget-card"
            id={product.slug}
            data-price={product.priceNum}
            data-reviews={product.ratingsCount}
            data-sold={product.soldNum ?? 0}
            data-score={product.score}
            data-official={product.notReseller ? "true" : "false"}
          >
            <a
              class="budget-card-media"
              href={product.links.shopee}
              target="_blank"
              rel="sponsored noopener"
              data-affiliate-link
              data-affiliate-store="shopee"
              data-affiliate-context={`budget-air-photo-${product.slug}`}
            >
              <span class="budget-rank">฿{product.priceShort.replace("~", "").replace(".-", "")}</span>
              <img src={product.image.url} alt={product.image.alt} loading="lazy" />
              <small>{product.image.note}</small>
            </a>
            <div class="budget-card-body">
              <div class="badge-row">
                <span class="badge badge-dark">{storeBadgeLabel[product.storeStatus]}</span>
                <span class="badge badge-blue">{product.rating.toFixed(1)}/5 · {product.ratingsCount.toLocaleString("th-TH")} รีวิว</span>
              </div>
              <h3>{product.name}</h3>
              <div class="budget-facts">
                <div><span>ราคาที่พบ</span><strong>{product.priceShort}</strong></div>
                <div><span>BTU</span><strong>{product.btuRange}</strong></div>
                <div><span>ประกันคอมฯ</span><strong>{product.warrantyShort}</strong></div>
                <div><span>ยอดขายที่เห็น</span><strong>{product.soldLabel}</strong></div>
              </div>
              <p class="budget-whofor"><b>เหมาะกับ:</b> {product.whoFor}</p>
              <p class="budget-watch"><b>ระวัง:</b> {product.topWatch}</p>
              <p class="budget-store">ร้าน: {product.storeShort}{product.storeNote ? ` — ${product.storeNote}` : ""}</p>
              <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />
              <div class="budget-actions">
                <button class="button compare-toggle" type="button" data-air-compare-slug={product.slug}>+ เปรียบเทียบ</button>
                <a class="button button-primary" href={product.reviewHref}>{product.reviewHref.includes("#") ? "ดูในหน้า 10 อันดับ" : "อ่านรีวิวละเอียด"}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section band" id="compare">
    <div class="wide-container">
      <p class="eyebrow">ตารางเปรียบเทียบ · อัปเดต {updatedLabel}</p>
      <h2 class="headline">เทียบ 6 รุ่นต่ำกว่าหมื่นในตาเดียว</h2>
      <div class="compare-shell">
        <table class="compare-table">
          <thead>
            <tr>
              <th>รุ่น</th>
              <th>ราคาที่พบ</th>
              <th>BTU</th>
              <th>รีวิว Shopee</th>
              <th>ยอดขายที่เห็น</th>
              <th>ประกันคอมฯ</th>
              <th>ร้าน</th>
              <th>เช็กราคา</th>
            </tr>
          </thead>
          <tbody>
            {budgetProducts.map((product) => (
              <tr>
                <td>
                  <strong>{product.shortName}</strong>
                  <br />
                  <a class="compare-detail-link" href={`#${product.slug}`}>ดูรายละเอียด ↑</a>
                </td>
                <td class={product.priceNum === minPrice ? "is-best" : undefined}>{product.priceShort}</td>
                <td>{product.btuRange}</td>
                <td class={product.ratingsCount === maxReviews ? "is-best" : undefined}>{product.rating.toFixed(1)} ★ ({product.ratingsCount.toLocaleString("th-TH")})</td>
                <td class={(product.soldNum ?? 0) === maxSold && maxSold > 0 ? "is-best" : undefined}>{product.soldLabel}</td>
                <td class={product.slug === bestWarrantySlug ? "is-best" : undefined}>{product.warrantyShort}</td>
                <td>{storeColLabel[product.storeStatus]}</td>
                <td>
                  <a class="button button-primary compare-buy" href={product.links.shopee} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`budget-air-table-${product.slug}`}>Shopee</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="compare-note">✓ เขียว = ค่าที่ดีที่สุดของคอลัมน์ · ราคา ณ วันที่ {updatedLabel} ส่วนใหญ่เป็นราคาช่วงโปร เปลี่ยนได้ทุกวัน · "ไม่แสดง" = Shopee ไม่โชว์ยอดขายบนหน้าสินค้า เราจึงไม่อ้างตัวเลขเอง</p>

      <h3 class="headline" style="margin-top: 36px; font-size: 1.3rem;">เทียบราคาที่พบแบบเห็นภาพ</h3>
      <div class="rainy-chart" role="img" aria-label="กราฟแท่งเทียบราคาที่พบของทั้ง 6 รุ่น สั้นกว่าคือถูกกว่า">
        <svg viewBox={`0 0 900 ${budgetProducts.length * 46 + 10}`}>
          {budgetProducts.map((product, i) => {
            const y = i * 46 + 8;
            const barW = Math.max(40, (product.priceNum / chartMax) * 470);
            return (
              <g class="rainy-bar" style={`animation-delay:${i * 90}ms`}>
                <text x="0" y={y + 19} class="rainy-bar-name">{product.shortName}</text>
                <rect x="215" y={y} width={barW} height="28" rx="8" fill={product.priceNum === minPrice ? "#0ea5a0" : "#ff6b5a"} opacity="0.85" />
                <text x={222 + barW} y={y + 19} class="rainy-bar-value">{product.priceShort.replace("~", "")} · {product.ratingsCount.toLocaleString("th-TH")} รีวิว</text>
              </g>
            );
          })}
        </svg>
        <p class="compare-note">ความยาวแท่ง = ราคาที่พบ (สั้น = ถูกกว่า) · <span style="color:#0ea5a0">■</span> ถูกสุดในลิสต์ · ตัวเลขท้ายแท่งคือราคาและจำนวนรีวิว</p>
      </div>
    </div>
  </section>

  <section class="section" id="which-one">
    <div class="container">
