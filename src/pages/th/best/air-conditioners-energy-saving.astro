  { label: "หลักฐาน SEER ชัดสุด", slug: "haier-vqec-series", reason: "รุ่นเดียวที่ร้านแจ้ง SEER รายขนาด (18.08–18.97) มี Eco Mode ประกันคอม 10 ปี ในงบต่ำหมื่น" },
  { label: "งบต่ำหมื่น + ดูค่าไฟในแอป", slug: "xiaomi-mijia-air-inverter-eco", reason: "~7,924.- จากร้าน official ตามดูการใช้ไฟผ่านแอป Xiaomi Home ได้ทุกวัน" }
].map((pick) => {
  const p = rankedProducts.find((x) => x.slug === pick.slug)!;
  return { ...pick, name: p.shortName, image: p.image, priceShort: p.priceShort, rating: p.rating };
});

