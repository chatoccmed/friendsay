  <script is:inline data-astro-rerun>
    (() => {
      const grid = document.getElementById("energy-grid");
      const note = document.getElementById("energy-sort-note");
      const under10kOnly = document.getElementById("energy-under10k-only");
      if (!grid) return;

      const cards = Array.from(grid.children);
      const sortButtons = Array.from(document.querySelectorAll("[data-sort]"));
      const num = (card, key) => Number(card.getAttribute("data-" + key) || 0);
      const sortLabels = { energy: "คะแนนประหยัดไฟ", price: "ราคาถูกสุดก่อน", reviews: "รีวิวเยอะสุด", score: "คะแนนรวม" };
      let currentSort = "energy";

      const apply = () => {
        const onlyUnder10k = under10kOnly && under10kOnly.checked;

        const sorted = cards.slice().sort((a, b) => {
          if (currentSort === "price") return num(a, "price") - num(b, "price");
          if (currentSort === "reviews") return num(b, "reviews") - num(a, "reviews");
          if (currentSort === "score") return num(b, "score") - num(a, "score");
          // energy: คะแนนประหยัดไฟมากสุดก่อน tiebreak ด้วยคะแนนรวม
          const d = num(b, "energy") - num(a, "energy");
          return d !== 0 ? d : num(b, "score") - num(a, "score");
        });

        let visible = 0;
        sorted.forEach((card) => {
          const show = !onlyUnder10k || card.getAttribute("data-under10k") === "true";
          card.hidden = !show;
          if (show) {
            visible += 1;
            card.classList.remove("energy-pop");
            // reflow เพื่อรีสตาร์ท animation
            void card.offsetWidth;
            card.classList.add("energy-pop");
          }
          grid.appendChild(card);
        });

        if (note) {
          note.textContent = `เรียงตาม: ${sortLabels[currentSort]}` + (onlyUnder10k ? " · เฉพาะราคาที่พบต่ำกว่า 10,000 บาท" : "") + ` · แสดง ${visible} รุ่น`;
        }
      };

      sortButtons.forEach((btn) => {
        btn.addEventListener("click", () => {
          currentSort = btn.getAttribute("data-sort") || "energy";
          sortButtons.forEach((b) => b.classList.toggle("is-active", b === btn));
          apply();
        });
      });
      if (under10kOnly) under10kOnly.addEventListener("change", apply);
    })();
  </script>
