const vsIdxOf = (slug: string) => airConditioners.findIndex((p) => p.slug === slug);
const vsHref = (x: string, y: string) => {
  const [first, second] = vsIdxOf(x) < vsIdxOf(y) ? [x, y] : [y, x];
  return `/th/vs/${first}-vs-${second}/`;
};
const vsShort = (slug: string) => airConditioners.find((p) => p.slug === slug)?.shortName ?? slug;
const spokeVsPairs = [
  { a: "daikin-ftkb-sabai-series", b: "mitsubishi-msy-ka-vf-series", note: "สองญี่ปุ่นเบอร์ต้น เทียบประหยัดไฟ-ความเงียบชนกัน" },
  { a: "haier-vqec-series", b: "midea-celest-msce", note: "สองตัวคุ้มที่ชูประหยัดไฟ ราคาเบากว่าญี่ปุ่น" },
  { a: "daikin-ftkb-sabai-series", b: "haier-vqec-series", note: "ตัวท็อปประหยัดไฟ vs ตัวคุ้มที่แจง SEER รายขนาด" }
].map((p) => ({ href: vsHref(p.a, p.b), label: `${vsShort(p.a)} vs ${vsShort(p.b)}`, note: p.note }));

