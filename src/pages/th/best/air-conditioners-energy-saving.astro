// จัดอันดับ: energyComfort มาก→น้อย · เท่ากันตัดสินด้วยคะแนนรวม (score) · ตัดรุ่น Non-Inverter ออกจากอันดับ
const NON_INVERTER_SLUG = "panasonic-cs-cu-yn9ykt";
const bySlug = (slug: string) => airConditioners.find((p) => p.slug === slug)!;

const rankedProducts = Object.keys(energyExtras)
  .map((slug) => {
    const p = bySlug(slug);
    const ex = energyExtras[slug];
    return {
      slug,
      name: p.name,
      shortName: p.shortName,
      image: p.image,
      rating: p.rating,
      ratingsCount: p.ratingsCount,
      score: p.score,
      energyComfort: p.energyComfort,
      links: p.links,
      whoFor: prose[slug].whoFor,
      topWatch: prose[slug].topWatch,
      ...ex
    };
  })
  .sort((a, b) => (b.energyComfort - a.energyComfort) || (b.score - a.score));

// รุ่นที่ตัดออกจากอันดับ (Non-Inverter แต่ชื่อลิสติ้งใช้คำว่า "ประหยัดไฟ") — โชว์เป็นคำเตือน ไม่ใช่อันดับ
const nonInverter = bySlug(NON_INVERTER_SLUG);

// best-in-column (คิดจากข้อมูลจริง)
const maxEnergy = Math.max(...rankedProducts.map((p) => p.energyComfort));
const minPrice = Math.min(...rankedProducts.map((p) => p.priceNum));
const maxReviews = Math.max(...rankedProducts.map((p) => p.ratingsCount));
const bestWarrantySlug = "hisense-ce-series";

// quick-pick 3 ใบ
