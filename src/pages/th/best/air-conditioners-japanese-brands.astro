// จัดอันดับตามคะแนนรวม (score) จาก airConditioners.ts — ชุดเดียวกับหน้า 10 อันดับ
const bySlug = (slug: string) => airConditioners.find((p) => p.slug === slug)!;
const jpProducts = Object.keys(jpExtras)
  .map((slug) => {
    const p = bySlug(slug);
    return {
      slug,
      name: p.name,
      shortName: p.shortName,
      brand: p.brand,
      image: p.image,
      rating: p.rating,
      ratingsCount: p.ratingsCount,
      score: p.score,
      btuOptions: p.btuOptions,
      links: p.links,
      whoFor: prose[slug].whoFor,
      topWatch: prose[slug].topWatch,
      ...jpExtras[slug]
    };
  })
  .sort((a, b) => b.score - a.score);

// best-in-column (คิดจากข้อมูลจริง)
const maxScore = Math.max(...jpProducts.map((p) => p.score));
const minPrice = Math.min(...jpProducts.map((p) => p.priceNum));
const maxReviews = Math.max(...jpProducts.map((p) => p.ratingsCount));
const maxSold = Math.max(...jpProducts.map((p) => p.soldNum ?? 0));

