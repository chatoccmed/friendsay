  { label: "รู้ค่าติดตั้งล่วงหน้า", slug: "panasonic-cs-cu-yu9zkt", reason: "ร้าน official แจกแจงราคาอุปกรณ์ติดตั้งทุกรายการชัดสุดในกลุ่ม ไม่ต้องลุ้นค่าใช้จ่ายหน้างาน" }
].map((pick) => {
  const p = jpProducts.find((x) => x.slug === pick.slug)!;
  return { ...pick, name: p.shortName, image: p.image, priceShort: p.priceShort, rating: p.rating };
});

