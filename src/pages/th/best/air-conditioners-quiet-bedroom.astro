const faqs = [
  {
    q: "ร้านไม่บอกค่า dB แล้วจะรู้ได้ยังไงว่าแอร์เงียบจริง?",
    a: "วิธีที่เราใช้เองคืออ่านรีวิวที่มีวิดีโอ เพราะได้ยินเสียงจริงทั้งเสียงลมและเสียงคอยล์ร้อน ดีกว่าเชื่อคำว่าเงียบในชื่อสินค้า ในคลังของเรามีรุ่นเดียวที่เจอตัวเลขจริงคือ Daikin FTKB ที่รีวิวระบุคอยล์ร้อน 40dB นอกนั้นใช้สัญญาณจากรีวิวผู้ซื้อ เคล็ดลับเพิ่ม: อ่านรีวิวของ BTU ขนาดที่จะซื้อจริง เพราะเสียงต่างกันตามขนาดคอมเพรสเซอร์ อย่าง Haier VQEC มีรีวิวระบุว่ารุ่น 18,000 BTU เสียงดังกว่าที่คาด ซึ่งไม่ได้บอกอะไรเกี่ยวกับรุ่น 9,000 BTU"
  },
