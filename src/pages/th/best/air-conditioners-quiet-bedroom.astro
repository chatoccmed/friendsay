const bySlug = (slug: string) => airConditioners.find((p) => p.slug === slug)!;

// โซนแนะนำ: เรียงตามความชัดของธีมเสียงในรีวิวที่บันทึกไว้ (ไม่ใช่คะแนนตัวเลข — เราไม่มีเครื่องวัดเสียง)
const recommendedOrder = [
  "mitsubishi-msy-ka-vf-series",
  "daikin-ftkb-sabai-series",
  "xiaomi-mijia-air-inverter-eco",
  "hisense-ce-series",
  "candy-vpct-vpgt-series",
  "panasonic-cs-cu-yu9zkt"
];

const quietProducts = recommendedOrder.map((slug, index) => {
  const p = bySlug(slug);
  const ex = quietExtras[slug];
  return {
    slug,
    rank: index + 1,
    name: p.name,
    shortName: p.shortName,
    image: p.image,
    rating: p.rating,
    ratingsCount: p.ratingsCount,
    score: p.score,
    links: p.links,
    whoFor: prose[slug].whoFor,
    topWatch: prose[slug].topWatch,
    ...ex
  };
});

const checkFirstProducts = Object.keys(checkFirstExtras).map((slug) => {
  const p = bySlug(slug);
  return { slug, name: p.name, shortName: p.shortName, image: p.image, rating: p.rating, ratingsCount: p.ratingsCount, links: p.links, ...checkFirstExtras[slug] };
});

// best-in-column (คิดจากข้อมูลจริง)
const minPrice = Math.min(...quietProducts.map((p) => p.priceNum));
const maxReviews = Math.max(...quietProducts.map((p) => p.ratingsCount));
const bestWarrantySlug = "hisense-ce-series";

