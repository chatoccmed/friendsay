  { label: "เงียบ + รีวิวแน่นสุด", slug: "daikin-ftkb-sabai-series", reason: "รุ่นเดียวที่เจอตัวเลขจริง คอยล์ร้อน 40dB ยืนยันด้วยรีวิว 6,200+ คะแนนเต็ม 5.0 เห็นยอดขาย 10พัน+" },
  { label: "เงียบในงบต่ำหมื่น", slug: "xiaomi-mijia-air-inverter-eco", reason: "~7,924.- จากร้าน official รีวิวชมว่าเสียงไม่กวนห้องนอน ตั้งเวลาปิดผ่านแอปได้" }
].map((pick) => {
  const p = quietProducts.find((x) => x.slug === pick.slug)!;
  return { ...pick, name: p.shortName, image: p.image, priceShort: p.priceShort, rating: p.rating };
});

