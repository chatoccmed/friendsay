  },
  {
    q: "ราคาในหน้านี้เชื่อได้แค่ไหน แล้ว Friendsay ได้อะไร?",
    a: "ราคาทั้งหมดคือราคาที่เห็นจริงบนหน้า Shopee ณ รอบเก็บข้อมูล 2 ก.ค. 2026 ส่วนใหญ่เป็นราคาช่วงโปรที่เปลี่ยนได้ทุกวัน ให้ยึดราคาหน้าร้านจริงตอนคุณกดเข้าไปดู Friendsay ทำคนเดียวร่วมกับ AI ไม่มีสินค้าจริงในมือ ไม่เคยฟังเสียงเครื่องเอง ข้อมูลเรื่องเสียงทั้งหมดมาจากรีวิวผู้ซื้อที่เราบันทึกไว้ตอนเปิดหน้าสินค้าจริง ส่วน \"ไม่แสดง\" คือ Shopee ไม่โชว์ยอดขายบนหน้านั้น เราจึงไม่อ้างตัวเลขเอง และลิงก์ในเว็บเป็นลิงก์ affiliate ถ้ากดซื้อผ่านเรา เราอาจได้ค่าคอมมิชชั่นเล็กน้อยโดยคุณไม่จ่ายเพิ่ม"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "แอร์ห้องนอนเสียงเงียบ 2026: 6 รุ่นที่รีวิวผู้ซื้อชมเรื่องเสียงจริง",
  description:
    "คัดแอร์ห้องนอนเสียงเงียบ 6 รุ่นจากสัญญาณรีวิวผู้ซื้อจริงบน Shopee พร้อม 2 รุ่นที่ควรฟังเสียงจากวิดีโอรีวิวก่อนซื้อ ราคา จุดระวัง ตารางเทียบ และวิธีติดตั้งให้เงียบขึ้น",
  inLanguage: "th",
  dateModified: "2026-07-06",
  author: { "@type": "Organization", name: "Friendsay" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: quietProducts.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: product.name,
      url: `https://friendsay.com/th/best/air-conditioners-quiet-bedroom/#${product.slug}`
    }))
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a }
  }))
};

const allQuietPageSlugs = [...quietProducts.map((p) => p.slug), ...checkFirstProducts.map((p) => p.slug)];
const scenarioCards = scenarios.map((s) => ({
  ...s,
  picks: s.recommendedSlugs.map((slug) => {
    const inMain = quietProducts.find((x) => x.slug === slug);
    const inCheck = checkFirstProducts.find((x) => x.slug === slug);
    const p = inMain ?? inCheck!;
    return { slug, shortName: p.shortName, priceShort: p.priceShort };
  })
}));

// กราฟ: แท่งราคา (สั้น = ถูกกว่า) ของโซนแนะนำ + ป้ายรีวิว — สายเงียบงบต่างกันมาก เห็นภาพว่าจ่ายเพิ่มเพื่ออะไร
const chartMax = Math.max(...quietProducts.map((p) => p.priceNum));
