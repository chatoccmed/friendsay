---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";

const updatedLabel = "2 กรกฎาคม 2026";

import { rainySections, type RainyPick, type RainySection } from "../../../data/rainyGear";

const sections: RainySection[] = rainySections;

const allPicks = sections.flatMap((section) => section.picks);

const chartColors: Record<string, string> = { dryer: "#ff6b5a", shoes: "#0ea5a0", dehumidifier: "#3a86ff" };
const sectionIdOf = (pick: RainyPick) => sections.find((s) => s.picks.includes(pick))?.id || "dryer";

const faqs = [
  {
    q: "เครื่องอบผ้ากับตู้อบผ้าต่างกันยังไง?",
    a: "เครื่องอบผ้าฝาหน้า (หลักพันถึงหมื่น) ปั่นและเป่าลมร้อนให้ผ้าแห้งสนิทในเครื่องเดียว เหมาะซักเยอะซักบ่อย ส่วนตู้อบผ้า (หลักร้อย) คือโครงตู้ + ฮีตเตอร์เป่าลมร้อน เหมาะผ้าจำนวนน้อยและงบจำกัด แต่ใช้เวลานานกว่าและต้องแขวนผ้าเอง"
  },
  {
    q: "เครื่องลดความชื้นต่างจากเครื่องฟอกอากาศไหม?",
    a: "คนละหน้าที่ครับ เครื่องฟอกอากาศกรองฝุ่น/PM2.5 แต่ไม่ลดความชื้น ส่วนเครื่องลดความชื้นดูดไอน้ำออกจากอากาศเป็นน้ำในถัง — ปัญหาผนังขึ้นรา ตู้เสื้อผ้าเหม็นอับหน้าฝน ต้องใช้เครื่องลดความชื้นเท่านั้น"
  },
  {
    q: "ราคาในหน้านี้เชื่อได้แค่ไหน?",
    a: `ทุกตัวเลขคือราคาที่เราเห็นจริงบนหน้าร้าน ณ วันที่ ${updatedLabel} ส่วนใหญ่เป็นราคาช่วงโปรซึ่งเปลี่ยนได้ทุกวัน โปรดกดเช็กราคาปัจจุบันก่อนตัดสินใจเสมอ และสองรายการ (TCL, Deerma) ตอนเก็บข้อมูลขึ้นสถานะพรีออเดอร์ส่ง 30 วัน`
  },
  {
    q: "Friendsay ได้อะไรจากหน้านี้?",
    a: "ลิงก์ไปร้านค้าเป็นลิงก์พันธมิตร ถ้าซื้อผ่านลิงก์เราได้ค่าคอมมิชชันเล็กน้อยโดยคุณไม่จ่ายแพงขึ้น ทุกรายการคัดจากหลักฐานยอดขายและรีวิวจริงที่เราเปิดดูเองทีละหน้า ไม่ใช่รายการที่ร้านจ่ายเงินซื้อพื้นที่"
  }
];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "ของสู้หน้าฝน 2026: 7 ตัวช่วยผ้าแห้ง รองเท้าหอม บ้านไม่ขึ้นรา",
  description: "รวมเครื่องอบผ้า เครื่องอบรองเท้า และเครื่องลดความชื้นที่ขายจริงหลักพันถึงหมื่นชิ้นใน Shopee ตรวจหลักฐานรายชิ้น พร้อมจุดระวังก่อนจ่ายเงิน",
  inLanguage: "th",
  dateModified: "2026-07-02",
  author: { "@type": "Organization", name: "Friendsay" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: allPicks.map((pick, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: pick.name
    }))
  }
};

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a }
  }))
};
---

<BaseLayout
  title="ของสู้หน้าฝน 2026: 7 ตัวช่วยผ้าแห้ง รองเท้าหอม บ้านไม่ขึ้นรา | Friendsay"
  description="หน้าฝนผ้าไม่แห้ง รองเท้าเหม็นอับ ผนังขึ้นรา — รวม 7 ตัวช่วยที่ขายจริงหลักพันถึงหมื่นชิ้นใน Shopee: เครื่องอบผ้า เครื่องอบรองเท้า เครื่องลดความชื้น พร้อมราคาจริงและจุดระวัง อัปเดต 2 ก.ค. 2026"
  canonical="https://friendsay.com/th/best/rainy-season-gear/"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="page-hero">
    <div class="container">
      <div class="badge-row">
        <span class="badge badge-teal">ฤดูฝน 2026</span>
        <span class="badge badge-coral">อัปเดต {updatedLabel}</span>
      </div>
      <h1>ของสู้หน้าฝน: 7 ตัวช่วยผ้าแห้ง รองเท้าหอม บ้านไม่ขึ้นรา</h1>
      <p class="muted">
        ทุกชิ้นในหน้านี้เราเปิดหน้าสินค้าจริงและเห็นยอดขายจริงก่อนแนะนำ (ต่ำสุด 772 ชิ้น สูงสุด 10,000+ ชิ้น)
        แบ่งตาม 3 ปัญหาที่หน้าฝนชอบสร้าง — เลือกจากปัญหาของคุณได้เลย
      </p>
      <div class="roundup-actions">
        <a class="button button-primary" href="#dryer">ผ้าไม่แห้ง</a>
        <a class="button" href="#shoes">รองเท้าเปียก</a>
        <a class="button" href="#dehumidifier">ห้องชื้น/ขึ้นรา</a>
      </div>
    </div>
  </section>

  <section class="section" id="quick-pick">
    <div class="container">
      <p class="eyebrow">เลือกด่วนใน 15 วินาที</p>
      <h2 class="headline">สามตัวจบ สามปัญหา</h2>
      <div class="scenario-grid" style="margin-top: 18px;">
        <article class="rainy-pick-card">
          <div class="badge-row"><span class="badge badge-coral">ผ้าไม่แห้งจริงจัง</span></div>
          <img class="rainy-img" src="/images/rainy-gear/tcl-wt09kfdyw-real-product.jpg" alt="เครื่องอบผ้า TCL 9 กก. ภาพสินค้าจริงจากหน้าร้าน" loading="lazy" />
          <h3>TCL เครื่องอบผ้า 9 กก.</h3>
          <p>ยอดขาย 8พัน+ รีวิว 1.6พัน — เครื่องอบฝาหน้าตัวจริงราคาคุ้มสุด</p>
          <a class="button button-primary" href="#dryer">ดูรายละเอียด ↓</a>
        </article>
        <article class="rainy-pick-card">
          <div class="badge-row"><span class="badge badge-teal">คุ้มสุดไม่ถึงพัน</span></div>
          <img class="rainy-img" src="/images/rainy-gear/sothing-shoe-dryer-real-product.jpg" alt="เครื่องเป่ารองเท้า Sothing ภาพสินค้าจริงจากหน้าร้าน" loading="lazy" />
          <h3>Sothing อบรองเท้า ~319.-</h3>
          <p>ขายแล้ว 8พัน+ — เสียบข้ามคืน รองเท้าแห้งหอมพร้อมใส่ทุกเช้า</p>
          <a class="button button-primary" href="#shoes">ดูรายละเอียด ↓</a>
        </article>
        <article class="rainy-pick-card">
          <div class="badge-row"><span class="badge badge-blue">แก้ห้องชื้นทั้งห้อง</span></div>
          <img class="rainy-img" src="/images/rainy-gear/hafele-dehumidifier-real-product.jpg" alt="เครื่องลดความชื้น HAFELE ภาพสินค้าจริงจากหน้าร้าน" loading="lazy" />
          <h3>HAFELE ลดความชื้น</h3>
          <p>ขายแล้ว 6พัน+ รีวิว 2พัน — จบปัญหาผนังขึ้นราในห้อง ≤20 ตร.ม.</p>
          <a class="button button-primary" href="#dehumidifier">ดูรายละเอียด ↓</a>
        </article>
      </div>
    </div>
  </section>

  <section class="section band" id="compare">
    <div class="container">
      <p class="eyebrow">ตารางเปรียบเทียบ · อัปเดต {updatedLabel}</p>
      <h2 class="headline">เทียบครบทั้ง 7 ตัวในตาเดียว</h2>
      <div class="compare-shell">
        <table class="compare-table">
          <thead>
            <tr>
              <th>รายการ</th>
              <th>แก้ปัญหา</th>
              <th>ราคาที่พบ</th>
              <th>รีวิว Shopee</th>
              <th>ยอดขายที่เห็น</th>
              <th>เหมาะสุดกับ</th>
              <th>เช็กราคา</th>
            </tr>
          </thead>
          <tbody>
            {sections.flatMap((section) =>
              section.picks.map((pick) => (
                <tr>
                  <td><strong>{pick.name.split(" ").slice(0, 3).join(" ")}</strong></td>
                  <td>{section.pain}</td>
                  <td class={pick.priceNum === 319 ? "is-best" : undefined}>{pick.price}</td>
                  <td class={pick.rating === 5.0 ? "is-best" : undefined}>{pick.rating.toFixed(1)} ★ ({pick.reviews})</td>
                  <td class={pick.soldNum >= 10000 ? "is-best" : undefined}>{pick.sold.replace("ขายแล้ว ", "").replace(" ชิ้น", "")}</td>
                  <td>{pick.fitShort}</td>
                  <td>
                    <a class="button button-primary compare-buy" href={pick.affiliateUrl} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="rainy-gear-table">Shopee</a>
                  </td>
                </tr>
              ))
            )}
          </tbody>
        </table>
      </div>
      <p class="compare-note">✓ เขียว = ค่าที่ดีที่สุดของคอลัมน์ · ราคา ณ วันที่ {updatedLabel} ส่วนใหญ่เป็นราคาช่วงโปร เปลี่ยนได้ทุกวัน</p>

      <h3 class="headline" style="margin-top: 36px; font-size: 1.3rem;">ภาพรวมราคา × ความนิยม</h3>
      <div class="rainy-chart" role="img" aria-label="กราฟแท่งเทียบราคาและยอดขายของทั้ง 7 รายการ">
        <svg viewBox={`0 0 900 ${allPicks.length * 46 + 10}`}>
          {allPicks.map((pick, i) => {
            const y = i * 46 + 8;
            const barW = Math.max(30, (pick.priceNum / 7500) * 480);
            return (
              <g class="rainy-bar" style={`animation-delay:${i * 90}ms`}>
                <text x="0" y={y + 19} class="rainy-bar-name">{pick.name.split(" ").slice(0, 2).join(" ")}</text>
                <rect x="215" y={y} width={barW} height="28" rx="8" fill={chartColors[sectionIdOf(pick)]} opacity="0.85" />
                <text x={222 + barW} y={y + 19} class="rainy-bar-value">{pick.price.replace("~", "")} · ขาย {pick.sold.replace("ขายแล้ว ", "").replace(" ชิ้น", "")}</text>
              </g>
            );
          })}
        </svg>
        <p class="compare-note">ความยาวแท่ง = ราคา (สั้น = ถูกกว่า) · สี: <span style="color:#ff6b5a">■</span> อบผ้า <span style="color:#0ea5a0">■</span> อบรองเท้า <span style="color:#3a86ff">■</span> ลดความชื้น</p>
      </div>
    </div>
  </section>

  {sections.map((section) => (
    <section class="section" id={section.id}>
      <div class="container">
        <p class="eyebrow">{section.pain}</p>
        <h2 class="headline">{section.headline}</h2>
        <p class="muted" style="max-width: 720px;">{section.intro}</p>
        <div class="scenario-grid" style="margin-top: 22px;">
          {section.picks.map((pick) => (
            <article class="rainy-pick-card">
              <div class="badge-row">
                <span class="badge badge-coral">{pick.shortName}</span>
                <span class="badge badge-blue">{pick.rating.toFixed(1)}/5</span>
              </div>
              <a href={pick.affiliateUrl} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`rainy-gear-photo-${section.id}`}>
                <img class="rainy-img" src={pick.image} alt={`${pick.name} ภาพสินค้าจริงจากหน้าร้าน Shopee`} loading="lazy" />
              </a>
              <span class="rainy-img-note">ภาพสินค้าจริงจากหน้าร้าน Shopee (ครอปเฉพาะตัวสินค้า) — กดภาพเพื่อเช็กราคา</span>
              <h3>{pick.name}</h3>
              <div class="rainy-facts">
                <span><b>{pick.price}</b></span>
                <span>{pick.reviews}</span>
                <span><b>{pick.sold}</b></span>
              </div>
              <p class="rainy-shop">{pick.shopNote}</p>
              <p><b>เหมาะกับ:</b> {pick.best}</p>
              <p class="rainy-watch"><b>ระวัง:</b> {pick.watch}</p>
              <a
                class="button button-primary"
                href={pick.affiliateUrl}
                target="_blank"
                rel="sponsored noopener"
                data-affiliate-link
                data-affiliate-store="shopee"
                data-affiliate-context={`rainy-gear-${section.id}`}
              >เช็กราคาวันนี้ใน Shopee</a>
            </article>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="section band" id="faq">
    <div class="container">
      <p class="eyebrow">ก่อนกดซื้อ</p>
      <h2 class="headline">คำถามที่คนถามบ่อย</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
      <p class="compare-note">
        ราคาและสถานะสินค้าเก็บจากหน้า Shopee จริงวันที่ {updatedLabel} · ตัวเลขยอดขายคือตัวเลขที่แสดงบนหน้าร้าน ไม่ใช่การประมาณ ·
        อ่านมาตรฐานรีวิวของเราได้ที่ <a href="/editorial-policy/">Editorial Policy</a>
      </p>
    </div>
  </section>

  <AffiliateClickTracker />
</BaseLayout>
