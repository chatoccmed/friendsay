---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";

const updatedLabel = "2 กรกฎาคม 2026";

type RainyPick = {
  name: string;
  shortName: string;
  price: string;
  rating: number;
  reviews: string;
  sold: string;
  shopNote: string;
  best: string;
  watch: string;
  affiliateUrl: string;
  sourceUrl: string;
};

type RainySection = {
  id: string;
  pain: string;
  headline: string;
  intro: string;
  picks: RainyPick[];
};

// ข้อมูลทุกตัวเก็บจากหน้า Shopee จริง 2 ก.ค. 2026 — ลิงก์ affiliate ทดสอบ redirect แล้วทุกลิงก์
