---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import PriceButtons from "../../../components/PriceButtons.astro";
import AirCompareTray from "../../../components/AirCompareTray.astro";
import AffiliateClickTracker from "../../../components/AffiliateClickTracker.astro";
import { airConditioners } from "../../../data/airConditioners";

const updatedLabel = "2 กรกฎาคม 2026";

const rankedAirConditioners = airConditioners
  .slice()
  .sort((a, b) => b.score - a.score);

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: "แอร์ยี่ห้อไหนดี 2026: 10 รุ่นน่าซื้อจากรีวิวผู้ซื้อจริงใน Shopee",
  description: "จัดอันดับแอร์ติดผนัง 10 รุ่นจากข้อมูลรีวิวผู้ซื้อจริงใน Shopee ที่ตรวจหลักฐานรายรุ่น พร้อมราคา BTU จุดระวัง และเงื่อนไขติดตั้ง",
  inLanguage: "th",
  dateModified: "2026-07-02",
  author: { "@type": "Organization", name: "Friendsay" },
  mainEntity: {
    "@type": "ItemList",
    itemListElement: rankedAirConditioners.map((product, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: product.name,
      url: `https://friendsay.com/th/best/air-conditioners/#${product.slug}`
    }))
  }
};

const reviewLinks: Record<string, string> = {
  "candy-vpct-vpgt-series": "/th/reviews/candy-vpct-vpgt-air-conditioner/",
  "tcl-savein-ai-series": "/th/reviews/tcl-savein-ai-air-conditioner/",
  "xiaomi-mijia-air-inverter-eco": "/th/reviews/xiaomi-mijia-air-inverter-eco/",
  "midea-celest-msce": "/th/reviews/midea-celest-msce-air-conditioner/",
  "panasonic-cs-cu-yu9zkt": "/th/reviews/panasonic-cs-cu-yu9zkt-air-conditioner/",
  "panasonic-cs-cu-yn9ykt": "/th/reviews/panasonic-cs-cu-yn9ykt-air-conditioner/"
};

const pickScore = (slug: string) =>
  airConditioners.find((product) => product.slug === slug)?.score ?? 0;

const quickPicks = [
  {
    label: "ดีสุดโดยรวม",
    slug: "daikin-ftkb-sabai-series",
    name: "Daikin FTKB Sabai",
    reason: "รีวิว 6.2 พัน คะแนน 5.0 ขายแล้ว 10พัน+ เครื่อง"
  },
  {
    label: "คุ้มสุดต่ำหมื่น",
    slug: "hisense-ce-series",
    name: "Hisense CE",
    reason: "inverter ~8,452 บาท ประกันคอม 12 ปี จากร้าน official"
  },
  {
    label: "ห้องนอน/เงียบ",
    slug: "mitsubishi-msy-ka-vf-series",
    name: "Mitsubishi KA",
    reason: "ธีมรีวิวที่ชมซ้ำมากที่สุดคือความเงียบ"
  }
].map((pick) => ({ ...pick, score: pickScore(pick.slug) }));

// ไฮไลต์ค่าที่ดีที่สุดในตาราง (best-in-column) — คิดจากข้อมูลจริง
const bestScore = Math.max(...airConditioners.map((p) => p.score));
const bestReviews = Math.max(...airConditioners.map((p) => p.ratingsCount));
// อิงราคา/ประกัน/ยอดขายที่เห็นจริง ณ 2026-07-02 (ดู compareExtras) — อัปเดตพร้อมรอบราคา
const bestPriceSlug = "midea-celest-msce";
const bestWarrantySlug = "hisense-ce-series";
const bestSoldSlugs = ["daikin-ftkb-sabai-series", "hisense-ce-series"];

// ข้อมูลสรุปสำหรับตารางเทียบ — ยึดจากหลักฐานรอบ 2026-07-02; ช่องที่ไม่เห็นข้อมูลจริงเขียนว่าให้เช็ก/ถามร้าน
const compareExtras: Record<string, { priceShort: string; soldLabel: string; warrantyShort: string; fitShort: string }> = {
  "daikin-ftkb-sabai-series": { priceShort: "~12,875.-", soldLabel: "10พัน+", warrantyShort: "คอม 5 ปี", fitShort: "แบรนด์ญี่ปุ่นรีวิวแน่นสุด อยากจ้างช่างเองคุมงบ" },
  "hisense-ce-series": { priceShort: "~8,452.-", soldLabel: "10พัน+", warrantyShort: "คอม 12 ปี + onsite", fitShort: "งบต่ำสุดที่ได้ inverter จากร้าน official" },
  "haier-vqec-series": { priceShort: "~9,545.-", soldLabel: "8พัน+", warrantyShort: "คอม 10 ปี", fitShort: "เน้นประหยัดไฟ มีค่า SEER แจ้งชัดทุกขนาด" },
  "candy-vpct-vpgt-series": { priceShort: "~7,995.-", soldLabel: "ไม่แสดง", warrantyShort: "คอม 5 ปี", fitShort: "คอนโด/ห้องนอนคุมงบ รีวิวผู้ซื้อเยอะมาก" },
  "tcl-savein-ai-series": { priceShort: "~8,590.-", soldLabel: "ไม่แสดง", warrantyShort: "ถามร้านยืนยัน", fitShort: "Full DC Inverter ฟีเจอร์แน่น BTU ให้เลือกกว้าง" },
  "xiaomi-mijia-air-inverter-eco": { priceShort: "~7,924.-", soldLabel: "ไม่แสดง", warrantyShort: "ถามร้านยืนยัน", fitShort: "สาย Smart Home คุมผ่านแอป Mi Home" },
  "midea-celest-msce": { priceShort: "~7,490.-", soldLabel: "ไม่แสดง", warrantyShort: "ถามร้านยืนยัน", fitShort: "งบประหยัดที่อยากได้ WiFi ในตัว" },
  "mitsubishi-msy-ka-vf-series": { priceShort: "~14,668.-", soldLabel: "2พัน+", warrantyShort: "โรงงาน 5 ปี", fitShort: "ห้องนอน เน้นเงียบที่สุดในกลุ่ม" },
  "panasonic-cs-cu-yu9zkt": { priceShort: "~12,750.-", soldLabel: "267", warrantyShort: "ผู้ผลิต 5 ปี", fitShort: "ซื้อตรง official อยากรู้ค่าติดตั้งล่วงหน้า" },
  "panasonic-cs-cu-yn9ykt": { priceShort: "~12,750.-", soldLabel: "428", warrantyShort: "ผู้ผลิต (ถามปีคอม)", fitShort: "ตัวธรรมดา Non-Inverter เปิดใช้ช่วงสั้น ๆ" }
};

const faqs = [
  {
    q: "ราคาในหน้านี้ใช้ได้ถึงเมื่อไหร่?",
    a: "ราคาทั้งหมดคือราคาที่เห็นจริง ณ วันที่ 2 กรกฎาคม 2026 ส่วนใหญ่เป็นราคาช่วง Flash Sale ซึ่งเปลี่ยนได้ทุกวัน ก่อนตัดสินใจให้กดปุ่มเช็กราคาเพื่อดูราคาปัจจุบันบนหน้าร้านเสมอ"
  },
  {
    q: "ตัวเลขยอดขายและรีวิวเอามาจากไหน?",
    a: "เราเปิดหน้าสินค้าจริงบน Shopee ทีละรุ่นแล้วบันทึกเฉพาะตัวเลขที่แสดงบนหน้า ถ้ารุ่นไหน Shopee ไม่แสดงยอดขาย เราเขียนว่า 'ไม่แสดง' ตรง ๆ ไม่มีการประมาณเอง ทุกรุ่นมีหลักฐานวันที่เก็บข้อมูลกำกับ"
  },
  {
    q: "ซื้อแอร์ออนไลน์แล้วใครติดตั้งให้?",
    a: "ส่วนใหญ่กดเลือกบริการติดตั้งเพิ่มได้ตอนสั่งซื้อ (ทีมคิวช้างจะติดต่อนัดวัน) แต่ค่าติดตั้งที่เห็นตอนกดมักไม่ใช่ราคาจบ — 90% ของงานมีค่าอุปกรณ์หน้างานเพิ่ม เช่น รางครอบท่อ ขาแขวน ท่อส่วนเกิน ร้าน Daikin ในอันดับ 1 ถึงกับเขียนเตือนเรื่องนี้เอง ถ้าหาช่างใกล้บ้านแบบเหมาจ่ายได้จะคุมงบง่ายกว่า"
  },
  {
    q: "ทำไมบางยี่ห้อดัง ๆ ไม่อยู่ในอันดับ?",
    a: "หน้านี้ใส่เฉพาะรุ่นที่เราเปิดหน้าสินค้าจริงและผ่านเกณฑ์หลักฐานแล้วเท่านั้น (รีวิวมากพอ + ร้านน่าเชื่อถือ) ยี่ห้ออย่าง LG, Carrier, Samsung และ Sharp อยู่ระหว่างเก็บหลักฐานรอบถัดไป ผ่านเกณฑ์เมื่อไหร่จะเพิ่มเข้าอันดับทันที"
  },
  {
    q: "Friendsay ได้อะไรจากหน้านี้?",
    a: "ลิงก์ไปร้านค้าเป็นลิงก์พันธมิตร (affiliate) ถ้าคุณซื้อผ่านลิงก์ เราได้ค่าคอมมิชชันเล็กน้อยจาก Shopee โดยคุณไม่จ่ายแพงขึ้น ค่าคอมไม่มีผลต่ออันดับ — อันดับมาจากหลักฐานตามเกณฑ์ที่ประกาศไว้ อ่านเพิ่มได้ที่หน้านโยบายความโปร่งใส"
  }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a }
  }))
};
---

<BaseLayout
  title="แอร์ยี่ห้อไหนดี 2026: 10 รุ่นน่าซื้อจากรีวิวผู้ซื้อจริงใน Shopee | Friendsay"
  description="จัดอันดับแอร์ติดผนัง 10 รุ่นปี 2026 จากรีวิวผู้ซื้อจริงใน Shopee ที่ตรวจหลักฐานรายรุ่น — Daikin, Hisense, Haier, Mitsubishi, Panasonic ดูราคา BTU จุดระวัง เงื่อนไขติดตั้ง อัปเดต 2 ก.ค. 2026"
  canonical="https://friendsay.com/th/best/air-conditioners/"
  ogImage="/images/air-conditioners/wall-ac-condo-hero.jpg"
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

  <section class="roundup-hero air-roundup-hero">
    <img class="roundup-hero-image" src="/images/air-conditioners/wall-ac-condo-hero.jpg" alt="แอร์ติดผนังในคอนโดสว่างสบาย" loading="eager" />
    <div class="roundup-hero-shade" aria-hidden="true"></div>
    <div class="wide-container roundup-hero-inner">
      <div class="roundup-hero-copy">
        <div class="badge-row">
          <span class="badge badge-coral">Shopee 2026</span>
          <span class="badge badge-teal">อัปเดต {updatedLabel}</span>
        </div>
        <h1>แอร์ยี่ห้อไหนดี 2026: 10 รุ่นน่าซื้อจากรีวิวผู้ซื้อจริง</h1>
        <p>
          ทุกรุ่นในหน้านี้ผ่านการเปิดหน้าสินค้าจริงและตรวจหลักฐานรายรุ่น — คะแนนรีวิว จำนวนผู้ซื้อ
          เงื่อนไขติดตั้ง และประกัน ถ้าเราไม่เห็นยอดขายจริง เราไม่อ้างตัวเลข
          และทุกรุ่นมี "ไม่เหมาะกับใคร" บอกตรง ๆ
        </p>
        <div class="roundup-actions">
          <a class="button button-primary" href="#shortlist">ดูอันดับทั้งหมด</a>
          <a class="button button-dark" href="#how-we-rank">เกณฑ์การจัดอันดับ</a>
          <a class="button" href="/th/best/air-conditioners-under-10000/">งบไม่ถึงหมื่น? ดูเฉพาะแอร์ต่ำกว่า 10,000</a>
          <a class="button" href="/th/best/air-conditioners-energy-saving/">เน้นค่าไฟ? ดูอันดับแอร์ประหยัดไฟ</a>
          <a class="button" href="/th/best/air-conditioners-quiet-bedroom/">ห้องนอนต้องเงียบ? ดูรุ่นที่รีวิวชมเรื่องเสียง</a>
        </div>
      </div>

      <aside class="roundup-panel" aria-label="เลือกด่วนตามโจทย์">
        <span>เลือกด่วนใน 15 วินาที</span>
        <strong>สามตัวจบสำหรับสามโจทย์ที่คนถามบ่อยสุด</strong>
        <div class="roundup-picks">
          {quickPicks.map((pick) => (
            <a href={`#${pick.slug}`}>
              <span>{pick.score.toFixed(1)}</span>
              <strong>{pick.label} · {pick.name}</strong>
              <small>{pick.reason}</small>
            </a>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section class="roundup-signal-band">
    <div class="wide-container roundup-signals">
      <div>
        <span>รุ่นที่ผ่านเกณฑ์</span>
        <strong>{airConditioners.length} รุ่น</strong>
      </div>
      <div>
        <span>เห็นยอดขายจริง</span>
        <strong>6 รุ่น (สูงสุด 10พัน+)</strong>
      </div>
      <div>
        <span>ตัวเลขยอดขาย</span>
        <strong>ไม่ใช้ถ้าไม่เห็นจริง</strong>
      </div>
      <div>
        <span>อัปเดตล่าสุด</span>
        <strong>{updatedLabel}</strong>
      </div>
    </div>
  </section>

  <section class="section air-system-section" id="how-we-rank">
    <div class="wide-container">
      <div class="section-heading home-section-split">
        <div>
          <p class="eyebrow">เกณฑ์การจัดอันดับ</p>
          <h2 class="headline">อันดับมาจากหลักฐานที่ตรวจย้อนได้ ไม่ใช่ความรู้สึก</h2>
        </div>
        <p>
          ทุกรุ่นถูกเปิดหน้าสินค้าจริงและบันทึกหลักฐาน ณ วันที่ {updatedLabel} คะแนนเต็ม 10 ถ่วงน้ำหนักจาก
          ความนิยมจากรีวิวจริง ความน่าเชื่อถือของร้าน ความคุ้มราคา ความง่ายในการเลือกขนาด ความประหยัด/สบาย
          ความเสี่ยงงานติดตั้ง ประกัน และสัดส่วนคำร้องเรียน — ราคาเปลี่ยนได้ทุกวัน ควรกดเช็กหน้าร้านก่อนซื้อเสมอ
          และถ้ายังไม่แน่ใจว่าห้องคุณต้องใช้กี่ BTU <a href="/th/guides/btu-calculator/">ใช้เครื่องคิด BTU ของเราก่อน</a> ใช้เวลาไม่ถึงนาที
        </p>
      </div>
      <div class="source-grid air-source-grid">
        <article>
          <span>01</span>
          <h3>หา candidate จาก Shopee</h3>
          <p>เลือกเฉพาะรุ่นที่มีรีวิวมากกว่า 5 รีวิว และถ้าเห็นยอดขายต้องมากกว่า 10 เครื่องขึ้นไป</p>
        </article>
        <article>
          <span>02</span>
          <h3>ถ้ายอดขายไม่โชว์</h3>
          <p>ถ้าคะแนน คอมเมนต์ และรูปรีวิวมากพอ เราจะใช้ข้อมูลรีวิวแทน แต่จะไม่อ้างยอดขายเอง</p>
        </article>
        <article>
          <span>03</span>
          <h3>ดูงานติดตั้ง</h3>
          <p>แยกคะแนนเรื่องคิวช่าง ค่าอุปกรณ์เพิ่ม คอนโด บ้านเดี่ยว และความเรียบร้อยหลังติดตั้ง</p>
        </article>
        <article>
          <span>04</span>
          <h3>ค่อยทำรีวิว 2,000 คำ</h3>
          <p>รีวิวเดี่ยวต้องตอบว่าเหมาะกับใคร ไม่เหมาะกับใคร และมีเช็กลิสต์ก่อนกดซื้อ</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section" id="compare-table">
    <div class="wide-container">
      <p class="eyebrow">ตารางเปรียบเทียบ · อัปเดต {updatedLabel}</p>
      <h2 class="headline">เทียบครบ 10 รุ่นในตาเดียว</h2>
      <div class="compare-shell">
        <table class="compare-table">
          <thead>
            <tr>
              <th>อันดับ / รุ่น</th>
              <th>คะแนน</th>
              <th>ราคาที่พบ</th>
              <th>BTU</th>
              <th>รีวิว Shopee</th>
              <th>ยอดขายที่เห็น</th>
              <th>ประกันคอมฯ</th>
              <th>เหมาะสุดกับ</th>
              <th>เช็กราคา</th>
            </tr>
          </thead>
          <tbody>
            {rankedAirConditioners.map((product, index) => {
              const extra = compareExtras[product.slug];
              return (
                <tr>
                  <td>
                    <strong>{index + 1}. {product.shortName}</strong>
                    <br />
                    <a class="compare-detail-link" href={`#${product.slug}`}>ดูรายละเอียด ↓</a>
                  </td>
                  <td class={product.score === bestScore ? "is-best" : undefined}><span class="score-pill">{product.score.toFixed(1)}</span></td>
                  <td class={product.slug === bestPriceSlug ? "is-best" : undefined}>{extra?.priceShort}</td>
                  <td>{product.btuOptions[0]?.replace(" BTU", "")}–{product.btuOptions[product.btuOptions.length - 1]?.replace(" BTU", "")}</td>
                  <td class={product.ratingsCount === bestReviews ? "is-best" : undefined}>{product.rating.toFixed(1)} ★ ({product.ratingsCount.toLocaleString("th-TH")}+)</td>
                  <td class={bestSoldSlugs.includes(product.slug) ? "is-best" : undefined}>{extra?.soldLabel}</td>
                  <td class={product.slug === bestWarrantySlug ? "is-best" : undefined}>{extra?.warrantyShort}</td>
                  <td>{extra?.fitShort}</td>
                  <td>
                    <a class="button button-primary compare-buy" href={product.links.shopee} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`best-air-table-rank-${index + 1}`}>Shopee</a>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
      <p class="compare-note">ราคาคือราคาที่เห็นจริง ณ วันที่ {updatedLabel} (ส่วนใหญ่เป็นราคาช่วงโปร) เปลี่ยนได้ทุกวัน · "ไม่แสดง" = Shopee ไม่โชว์ยอดขายบนหน้าสินค้า เราจึงไม่อ้างตัวเลขเอง</p>
    </div>
  </section>

  <section class="section band" id="shortlist">
    <div class="wide-container">
      <p class="eyebrow">10 อันดับ · อัปเดต {updatedLabel}</p>
      <h2 class="headline">แอร์ติดผนังน่าซื้อ เรียงตามคะแนน Friendsay</h2>
      <div class="air-product-grid">
        {rankedAirConditioners.map((product, index) => (
          <article class={`product-card air-product-card${index < 3 ? ` podium podium-${index + 1}` : ""}`} id={product.slug}>
            <a class="product-photo" href={product.links.shopee} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context={`best-air-rank-${index + 1}-photo`}>
              <img src={product.image.url} alt={product.image.alt} loading="lazy" />
              <span>{product.image.note}</span>
            </a>
            <div class="product-card-head">
              <div>
                <div class="badge-row">
                  <span class="badge badge-dark">อันดับ {index + 1}</span>
                  <span class="badge badge-coral">{product.statusLabel}</span>
                  <span class="badge badge-blue">{product.rating.toFixed(1)}/5 Shopee</span>
                </div>
                <h3>{product.name}</h3>
                <p class="muted">{product.bestFor}</p>
              </div>
              <div class="product-score">
                <span>{product.score.toFixed(1)}</span>
                <small>/10</small>
              </div>
            </div>
            <div class="buyer-snapshot" aria-label="สรุปข้อมูลก่อนซื้อ">
              <div>
                <span>ราคา</span>
                <strong>{product.priceLabel}</strong>
              </div>
              <div>
                <span>BTU</span>
                <strong>{product.btuOptions.join(" / ")}</strong>
              </div>
              <div>
                <span>รีวิว</span>
                <strong>{product.ratingsCount.toLocaleString("th-TH")}+ คะแนน</strong>
              </div>
              <div class="watch">
                <span>ต้องระวัง</span>
                <strong>{product.watch[0]}</strong>
              </div>
            </div>
            <div class="product-mini-scores">
              <span>ความนิยม {product.popularity.toFixed(1)}</span>
              <span>คุ้มค่า {product.value.toFixed(1)}</span>
              <span>ติดตั้ง {product.installRisk.toFixed(1)}</span>
            </div>
            <p class="product-review-preview">
              {product.pros.join(" / ")} แต่ควรตรวจซ้ำเรื่อง {product.watch.slice(0, 2).join(" และ ")}
            </p>
            <PriceButtons links={product.links} label={`เช็กราคา ${product.name}`} />
            <div class="product-actions">
              <button class="button compare-toggle" type="button" data-air-compare-slug={product.slug}>
                + เปรียบเทียบ
              </button>
              {reviewLinks[product.slug] && (
                <a class="button button-primary" href={reviewLinks[product.slug]}>อ่านรีวิวละเอียด</a>
              )}
              <a class="button" href={product.links.shopee} target="_blank" rel="sponsored noopener" data-affiliate-link data-affiliate-store="shopee" data-affiliate-context="best-air-open-shopee">เปิด Shopee</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section" id="which-one">
    <div class="wide-container">
      <p class="eyebrow">เลือกตามโจทย์ของคุณ</p>
      <h2 class="headline">บอกสถานการณ์มา เดี๋ยวชี้รุ่นให้</h2>
      <div class="scenario-grid">
        <article>
          <h3>ห้องนอน อยากเงียบสุด</h3>
          <p>เอา <a href="#mitsubishi-msy-ka-vf-series">Mitsubishi KA</a> — ธีมรีวิวที่ชมซ้ำมากที่สุดคือความเงียบ แลกกับราคาสูงกว่าแบรนด์จีนราว 30-50%</p>
        </article>
        <article>
          <h3>งบจำกัด แต่อยากได้ inverter</h3>
          <p>เอา <a href="#hisense-ce-series">Hisense CE</a> (~8,452.-) จากร้าน official ประกันคอม 12 ปี หรือ <a href="#haier-vqec-series">Haier VQEC</a> (~9,545.-) ประกันคอม 10 ปี</p>
        </article>
        <article>
          <h3>อยากได้แบรนด์ญี่ปุ่นที่คนซื้อจริงเยอะสุด</h3>
          <p>เอา <a href="#daikin-ftkb-sabai-series">Daikin FTKB Sabai</a> — 6,200+ รีวิว คะแนนเต็ม 5.0 ขายแล้ว 10,000+ เครื่อง มี BTU ครบ 5 ขนาด</p>
        </article>
        <article>
          <h3>คอนโดห้องเล็ก คุมงบต่ำสุด</h3>
          <p>เอา <a href="#candy-vpct-vpgt-series">CANDY VPCT</a> (~7,995.-) หรือ <a href="#midea-celest-msce">Midea Celest</a> (~7,490.-) — สองตัวถูกสุดที่รีวิวยังแน่น</p>
        </article>
        <article>
          <h3>สาย Smart Home คุมผ่านมือถือ</h3>
          <p>เอา <a href="#xiaomi-mijia-air-inverter-eco">Xiaomi Mijia Eco</a> คุมผ่านแอป Mi Home หรือ <a href="#tcl-savein-ai-series">TCL SaveIN AI</a> ที่ฟีเจอร์ AI แน่นกว่า</p>
        </article>
        <article>
          <h3>เปิดแอร์แค่วันละ 2-3 ชั่วโมง</h3>
          <p>ตัวธรรมดาอย่าง <a href="#panasonic-cs-cu-yn9ykt">Panasonic YN-YKT</a> ก็พอ — แต่ถ้าเปิดยาวทุกคืน inverter คืนส่วนต่างราคาผ่านค่าไฟแน่นอน</p>
        </article>
      </div>
    </div>
  </section>

  <section class="section band" id="faq">
    <div class="wide-container">
      <p class="eyebrow">คำถามที่ถูกถามบ่อย</p>
      <h2 class="headline">ก่อนกดซื้อ อ่านตรงนี้ก่อน</h2>
      <div class="faq-list">
        {faqs.map((f) => (
          <details class="faq-item">
            <summary>{f.q}</summary>
            <p>{f.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <AirCompareTray products={airConditioners} />
  <AffiliateClickTracker />
</BaseLayout>
