---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Friendsay Tourist Shopping Hub | Thailand buying guides"
  description="Friendly buying guides for tourists in Thailand: practical products, shopping safety, eSIM, sunscreen, power banks, and useful local finds."
  lang="en"
  canonical="https://friendsay.com/en/tourist/"
>
  <section class="page-hero band">
    <div class="container page-hero-grid">
      <div>
        <p class="eyebrow">For tourists in Thailand</p>
        <h1 class="headline">Buy smarter while traveling in Thailand</h1>
        <p class="subhead">
          Practical shopping guides for visitors who need useful products, safer buying choices, and honest local context without feeling pushed to buy.
        </p>
      </div>
      <aside class="verdict-card">
        <h2>Start here</h2>
        <p>Power banks, eSIMs, sunscreen, plug adapters, waterproof bags, and local products that are actually useful in Thailand.</p>
      </aside>
    </div>
  </section>

  <section class="section">
    <div class="container grid-3">
      <article class="soft-card">
        <span class="badge badge-coral">Travel essentials</span>
        <h2>What to buy before visiting Thailand</h2>
        <p>Clear, practical guidance for heat, rain, transport, connectivity, and everyday convenience.</p>
      </article>
      <article class="soft-card">
        <span class="badge badge-teal">Shopping safety</span>
        <h2>Where to buy safely in Thailand</h2>
        <p>How to think about official stores, marketplace ratings, return policies, and suspiciously cheap listings.</p>
      </article>
      <article class="soft-card">
        <span class="badge badge-blue">Local finds</span>
        <h2>Useful things from Thai stores</h2>
        <p>Small products that can make travel easier, from convenience-store basics to weather-ready gear.</p>
      </article>
    </div>
  </section>
</BaseLayout>
